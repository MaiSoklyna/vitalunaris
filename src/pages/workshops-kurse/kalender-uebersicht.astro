---
import BaseLayout from '@layouts/BaseLayout.astro';
import WorkshopsHero from '@organisms/WorkshopsHero.astro';
import WorkshopsCalendar from '@organisms/WorkshopsCalendar.astro';
import EventCard from '@molecules/EventCard.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import FeaturedTestimonial from '@organisms/FeaturedTestimonial.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import { workshopEvents } from '../../data/workshops';

const pills = [
  {
    label: 'Alle',
    title: 'Alle Angebote',
    description: 'Von Monatsworkshops über systemisches Aufstellen, Hypnose und Numerologie bis hin zu Infoanlässen — hier findest du alle unsere Kurse und Workshops auf einen Blick.',
  },
  {
    label: 'Monats-Workshops',
    active: true,
    title: 'Monats-Workshops',
    description: 'Unsere Monatsworkshops orientieren sich am Rhythmus der Jahreszeiten und den Themen, die Menschen gerade bewegen — von persönlicher Entwicklung über Nervensystem und Energiearbeit bis hin zu Numerologie und praktischen Alltagswerkzeugen.',
  },
  {
    label: 'Systemisches Aufstellen',
    title: 'Systemisches Aufstellen',
    description: 'Verstehen, was unter der Oberfläche wirkt. Unsere Kurse führen dich Schritt für Schritt in die Welt der systemischen Aufstellungsarbeit — praxisnah, erfahrungsbasiert und offen für alle.',
  },
  {
    label: 'Hypnose',
    title: 'Hypnose',
    description: 'Der Zugang zu tieferen Schichten beginnt im Inneren. Unsere Hypnose-Kurse verbinden Theorie und Erleben — für alle, die diese wirkungsvolle Methode kennenlernen oder vertiefen möchten.',
  },
  {
    label: 'Numerologie',
    title: 'Numerologie',
    description: 'Zahlen erzählen Geschichten. Unsere Kurse zeigen dir, wie du Muster, Potenziale und Zusammenhänge lesen kannst — überraschend präzise und sofort anwendbar.',
  },
  {
    label: 'Infoanlässe',
    title: 'Infoanlässe',
    description: 'Du spürst, dass da mehr ist — und möchtest wissen, wohin der Weg führen könnte. Unsere Infoanlässe geben dir einen ersten ehrlichen Einblick in die Ausbildung Systemic Soulwork, ohne Druck und ohne Verpflichtung.',
  },
];

/* Calendar events derived from the real workshop schedule
   (src/data/workshops.ts) — each chip links to its detail page. */
const toCalEvent = (w: (typeof workshopEvents)[number]) => ({
  date: w.date,
  label: w.title,
  color: w.color,
  href: `/workshops-kurse/${w.slug}`,
});

/* One calendar dataset per filter pill: "Alle" shows every course, each
   named category shows only the courses that belong to it. The label
   maps to the pill so the hero can show/hide the matching calendar. */
const calendars = pills.map((p) => ({
  category: p.label,
  active: Boolean(p.active),
  events:
    p.label === 'Alle'
      ? workshopEvents.map(toCalEvent)
      : workshopEvents.filter((w) => w.category === p.label).map(toCalEvent),
}));

const upcoming = [
  {
    image: '/images/placeholder/Placeholder-12.jpg',
    eyebrow: 'MONATS-WORKSHOP | SEPTEMBER | 14.09.2026',
    title: 'SoulTap Einführungskurs',
    description: 'In diesem September lädt dich Theresia Jansen zu einem besonderen Monats-Workshop ein: EFT Meridian-Klopfen – eine sanfte und effektive Methode, um innere Ruhe, Sicherheit und Vertrauen in dir zu stärken.',
    price: 'CHF 66.–',
    duration: '120 Min. | Online',
    ctaText: 'Mehr erfahren',
    ctaHref: '/workshops-kurse/soultap-gegen-angst',
  },
  {
    image: '/images/placeholder/Placeholder-29.jpg',
    eyebrow: 'MONATS-WORKSHOP | OKTOBER | 22.10.2026',
    title: 'Im Vagusnerv liegt die Ruhe',
    description: 'Aktiviere und entspanne deinen Vagusnerv in diesem Oktober-Workshop. Lerne wirkungsvolle Techniken kennen, die dich unterstützen, dein Nervensystem zu stabilisieren und mehr Gelassenheit in deinen Alltag zu bringen.',
    price: 'CHF 66.–',
    duration: '210 Min. | Online',
    ctaText: 'Mehr erfahren',
    ctaHref: '/workshops-kurse/vagusnerv-ruhe',
  },
  {
    image: '/images/placeholder/Placeholder-31.jpg',
    eyebrow: 'MONATS-WORKSHOP | NOVEMBER | 24.11.2026',
    title: 'Cool down for Christmas',
    description: 'Bleibe in der hektischen Weihnachtszeit entspannt. Dieser November-Workshop hilft dir, dich bewusst zu entschleunigen und ruhiger in die Feiertage zu gehen.',
    price: 'CHF 66.–',
    duration: '210 Min. | Online',
    ctaText: 'Mehr erfahren',
    ctaHref: '/workshops-kurse/cool-down-for-christmas',
  },
];

const testimonials = [
  { quote: '„Der Numerologie-Workshop hat mich wirklich überrascht. Anfangs war ich einfach neugierig – doch plötzlich ergaben viele Verhaltensweisen einen ganz neuen Sinn. Besonders die Analyse im Schulalltag war für mich unglaublich hilfreich. Sie hat mir gezeigt, wie ich meine Schüler besser verstehen und gezielter auf ihre Bedürfnisse eingehen kann. Ein Workshop voller Aha-Momente und neuer Perspektiven.“', name: 'Marianne S.' },
  { quote: '„Ich bin ohne große Erwartungen in den Numerologie-Workshop gestartet – und wurde umso positiver überrascht. Der Workshop war sehr strukturiert und bot gleichzeitig viel Raum für persönliche Entwicklung. Besonders das liebevoll gestaltete Workbook hat mich begeistert. Man spürt sofort, wie viel Erfahrung und Herzblut in diesem Kurs steckt. Vielen Dank für diese inspirierende Erfahrung.“', name: 'Marina C.' },
  { quote: '„Ich bin noch immer beeindruckt, wie viel Kraft hinter diesem einfachen Klopftechnik-Konzept steckt. Der Kurs war informativ, abwechslungsreich und die Zeit ist wie im Flug vergangen. Besonders wertvoll: Die Werkzeuge lassen sich direkt im Alltag anwenden – für mich selbst und meine Familie. Ein praxisnaher Kurs, den ich von Herzen weiterempfehle.“', name: 'Sandra M.' },
  { quote: '„SoulReset hat mich absolut begeistert. Die Atemübungen und das Tapping haben mir geholfen, Druck abzubauen und wieder mehr Ruhe zu finden. Viele der Übungen konnte ich direkt in meinen Alltag integrieren – besonders im Familienleben spüre ich deutlich mehr Gelassenheit und weniger Stress. Praktische und wirkungsvolle Tools, die sich leicht umsetzen lassen. Vielen Dank!“', name: 'Desiree Z.' },
];

const faqItems = [
  { question: 'Für wen sind die Workshops geeignet?', answer: 'Für alle, die systemische Arbeit erleben möchten — ob als Einstieg, zur Vertiefung oder einfach aus Neugier. Vorwissen ist nicht nötig.' },
  { question: 'Was ist der Unterschied zwischen einem Workshop und der Ausbildung?', answer: 'Ein Workshop ist ein einzelnes, in sich geschlossenes Erlebnis. Die Ausbildung ist ein aufeinander aufbauender, längerer Weg mit Abschluss.' },
  { question: 'Brauche ich Vorkenntnisse für die Monats-Workshops?', answer: 'Nein. Die Monats-Workshops sind so gestaltet, dass du jederzeit einsteigen kannst — mit oder ohne Vorerfahrung.' },
  { question: 'Wie melde ich mich an?', answer: 'Du wählst deinen Workshop im Kalender, klickst auf «Mehr erfahren» und meldest dich direkt an. Bei Fragen erreichst du uns jederzeit.' },
  { question: 'Werden die Kosten von der Krankenkasse übernommen?', answer: 'Workshops sind in der Regel keine kassenpflichtige Leistung. Manche Zusatzversicherungen unterstützen Bildungsangebote — frag im Einzelfall nach.' },
  { question: 'Kann ich einen Workshop stornieren?', answer: 'Ja, bis zu einer bestimmten Frist vor Beginn. Die genauen Bedingungen findest du in der Anmeldebestätigung.' },
  { question: 'Gibt es auch Online-Formate?', answer: 'Ja. Viele Workshops bieten wir online oder hybrid an — du siehst das Format jeweils direkt beim Termin im Kalender.' },
  { question: 'Was passiert wenn ein Workshop ausgebucht ist?', answer: 'Du kannst dich auf die Warteliste setzen. Wird ein Platz frei oder kommt ein Zusatztermin, informieren wir dich zuerst.' },
];
---

<BaseLayout
  title="Workshops & Kurse | VitaLunaris"
  description="Tauche ein in die Systeme der Seele mit Theres und Axel — Monats-Workshops, systemisches Aufstellen, Hypnose und Numerologie. Kalender & Übersicht aller Termine."
  currentPath="/workshops-kurse/kalender-uebersicht"
>
  <WorkshopsHero
    logo="/images/ebene/Ebene_2.svg"
    eyebrow="Workshops & Kurse"
    title={`Tauche ein in die<br /><em>Systeme der Seele</em> mit<br />Theres und Axel`}
    subtitle="Ob du deine Praxis erweitern oder einfach etwas Neues entdecken willst — hier ist der Raum für deine Entfaltung."
    pills={pills}
  >
    <Fragment slot="calendar">
      {calendars.map((c) => (
        <div class="cal-panel" data-cal-category={c.category} hidden={!c.active}>
          <WorkshopsCalendar
            events={c.events}
            emptyLabel={
              c.category === 'Alle'
                ? 'Aktuell sind keine Kurse geplant.'
                : `Aktuell sind keine Kurse zur Kategorie ${c.category} geplant.`
            }
          />
        </div>
      ))}
    </Fragment>
  </WorkshopsHero>

  {/* ===================== Nächste Kurse und Workshops ===================== */}
  <section class="upcoming">
    <div class="upcoming__inner">
      <Heading level={2} variant="h1" class="upcoming__title">Nächste Kurse und Workshops:</Heading>
      <div class="upcoming__grid">
        {upcoming.map((e) => <EventCard {...e} />)}
      </div>
    </div>
  </section>

  {/* ===================== Testimonials ===================== */}
  <TestimonialsBlock title="Was unsere Kunden sagen" testimonials={testimonials} />

  {/* ===================== Tiefes Wissen — lavender ===================== */}
  <section class="deep">
    <div class="deep__inner">
      <div class="deep__art" aria-hidden="true">
        <img src="/images/ebene/Ebene_2-12.svg" alt="" class="deep__art-img" loading="lazy" decoding="async" />
      </div>
      <div class="deep__content">
        <Heading level={2} variant="h1" class="deep__title">Tiefes Wissen, das nicht nur erklärt wird</Heading>
        <Text size="p1" class="deep__body">Unsere Workshops und Kurse sind kein Frontalunterricht. Sie sind Erfahrungsräume, in denen Wissen lebendig wird. Räume, in denen du Zusammenhänge nicht nur verstehst, sondern selbst erlebst. Denn manches kann erklärt werden. Anderes erschliesst sich erst, wenn wir es fühlen, beobachten und erfahren.</Text>
        <Text size="p1" class="deep__body">Ob du zum ersten Mal mit systemischer Arbeit, Numerologie oder Energiearbeit in Berührung kommst oder dein Wissen vertiefen möchtest – hier findest du Formate, die praxisnah, inspirierend und nachhaltig sind.Lernen darf berühren. Lernen darf verändern. Lernen darf Freude machen.</Text>
      </div>
    </div>
  </section>

  {/* ===================== Theresia & Axel Jansen ===================== */}
  <FeaturedTestimonial
    name={`Theresia &<br /><em>Axel Jansen</em>`}
    role=""
    tone="spring-wood"
    quote={`Was unsere Workshops besonders macht, ist nicht nur das Wissen — sondern die Erfahrung, aus der es entstanden ist. Seit Jahrzehnten begleiten wir Menschen in Veränderungsprozessen. Nicht in der Theorie, sondern im echten Leben.<br /><br />Theresia bringt Erfahrung aus systemischer Arbeit, Körperarbeit und Nervensystemwissen ein. Axel ergänzt durch Numerologie, Hypnose und seine Fähigkeit, komplexe Zusammenhänge alltagstauglich zu vermitteln.<br /><br />Gemeinsam schaffen wir Lernräume, in denen Menschen nicht nur Neues erfahren, sondern wachsen können. Denn Wissen wird erst nachhaltig, wenn es erlebt wird.`}
    image="/images/placeholder/placeholder-4.jpg"
    imageSide="right"
    ctaText="Mehr über uns"
    ctaHref="/ueber-uns"
  />

  {/* ===================== FAQ (dark) ===================== */}
  <Faq theme="dark" title="FAQ" items={faqItems} />

  {/* ===================== Newsletter ===================== */}
  <NewsletterBlock
    eyebrow="Newsletter"
    title="Ein Blick hinter die <br />Kulissen"
    body="Im Newsletter teilen wir Einblicke aus Ausbildungen und Praxis, Impulse für den Alltag und neue Termine — oft bevor sie öffentlich sind.I m Newsletter teile ich Einblicke aus Ausbildungen und Praxis, Impulse für den Alltag und neue Termine — oft bevor sie öffentlich sind. Wenn dich Workshops, Kurse oder die Ausbildung interessieren, bist du hier genau richtig."
    placeholder="E-mail Adresse"
    submitText="Anmelden"
  />
</BaseLayout>

<style>
  /* ============================================================
     UPCOMING — "Nächste Kurse und Workshops:" (3 event cards)
     ============================================================ */
  .upcoming { background: var(--c-spring-wood); padding: 40px 20px 60px; }
  @media (min-width: 768px)  { .upcoming { padding: 40px 32px 80px; } }
  @media (min-width: 1280px) { .upcoming { padding: 40px 60px 90px; } }
  @media (min-width: 1920px) { .upcoming { padding: 40px 90px 120px; } }

  .upcoming__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }
  @media (min-width: 1920px) { .upcoming__inner { gap: 64px; } }

  .upcoming__title { color: var(--c-cherrywood); text-align: center; margin: 0; }

  .upcoming__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    width: 100%;
  }
  @media (min-width: 640px)  { .upcoming__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .upcoming__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

  /* ============================================================
     DEEP — "Tiefes Wissen, das nicht nur erklärt wird" (lavender)
     ============================================================ */
  .deep { background: var(--c-lavender); color: var(--c-white); padding: 64px 20px; overflow: hidden; }
  @media (min-width: 768px)  { .deep { padding: 96px 32px; } }
  @media (min-width: 1280px) { .deep { padding: 120px 60px; } }
  @media (min-width: 1920px) { .deep { padding: 150px 90px; } }

  .deep__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1024px) {
    .deep__inner { flex-direction: row; align-items: center; justify-content: space-between; gap: 80px; }
  }
  @media (min-width: 1920px) { .deep__inner { gap: 160px; } }

  /* Decorative brand graphic */
  .deep__art {
    flex: 0 0 auto;
    width: 240px;
    height: 240px;
  }
  @media (min-width: 1280px) { .deep__art { width: 320px; height: 320px; } }
  @media (min-width: 1920px) { .deep__art { width: 380px; height: 380px; } }
  .deep__art-img { width: 100%; height: 100%; object-fit: contain; display: block; }

  .deep__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    max-width: 760px;
  }
  @media (min-width: 1024px) { .deep__content { gap: 32px; } }

  .deep__title {
    color: var(--c-white);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .deep__body { color: var(--c-white); font-size: var(--p1-size); line-height: 1.5; }
</style>
