---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@organisms/Hero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import InfoCardsRow from '@organisms/InfoCardsRow.astro';
import ProcessSteps from '@organisms/ProcessSteps.astro';
import CalendarBooking from '@organisms/CalendarBooking.astro';
import Faq from '@organisms/Faq.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

/* ----- "Wir schauen auf:" — outcomes arc (4 cards) ----- */
const outcomes = [
  {
    title: 'Beziehungen & Bindungsdynamiken',
    description: 'Wie gestalten wir Beziehungen — beruflich und privat? Was beeinflusst, wie wir uns verbinden, abgrenzen oder verlieren?',
  },
  {
    title: 'Eigene Muster & Loyalitäten',
    description: 'Warum wiederholen sich bestimmte Themen? Was steckt hinter den Entscheidungen, die wir immer wieder treffen?',
  },
  {
    title: 'Familiensysteme & Herkunft',
    description: 'Was haben wir mitbekommen? Was tragen wir — oft ohne es zu wissen? Loyalitäten, Verstrickungen und Muster, die sich durch Generationen ziehen.',
  },
  {
    title: 'Grundlagen systemischer Begleitung',
    description: 'Für alle, die auch andere begleiten möchten: die Grundhaltung, die Sprache und die ersten Schritte systemischer Arbeit — mit dem Aufstellungsbrett und mit Menschen.',
  },
];

/* ----- "Stimmen aus der Ausbildung" — star reviews ----- */
const reviews = [
  {
    quote: '«Diese Ausbildung hat mir eine völlig neue Perspektive eröffnet. Ich war lange eher im Kopf als im Körper — genau das beginnt sich zu verändern. Die Arbeit mit Familienkonstellationen hat mir geholfen, Klarheit zu gewinnen. Wo vorher Chaos war, entsteht heute mehr Ruhe und Vertrauen. Ich fühle mich mehr bei mir selbst angekommen.»',
    name: 'Jana L.',
  },
  {
    quote: '«In dieser Ausbildungsgruppe fühle ich mich so getragen, dass ich mit allem da sein kann, was ich bin. So habe ich mich in einer Gruppe noch nie gefühlt. In mir ist eine grosse Welle in Bewegung gekommen — früher hätte ich solche Gefühle verdrängt, heute gehe ich durch sie hindurch. Diese Ausbildung ist für mich weit mehr als Lernen. Sie ist ein Raum für Heilung, Wachstum und echtes Menschsein.»',
    name: 'Silvia F.',
  },
  {
    quote: '«Diese Ausbildung zeigt die Magie des systemischen Aufstellens — und ich könnte mir keinen Ort vorstellen, an dem ich mich wohler fühle. Ein geschützter Raum, in dem jede einfach sie selbst sein darf. Theresia schafft diesen Rahmen mit einer einfühlsamen Art, die es möglich macht, sich wirklich zu öffnen. Was diese Ausbildung besonders macht: die Erfahrung, selbst Teil eines solchen Prozesses zu sein.»',
    name: 'Corina B.',
  },
];

/* ----- "Alles was du wissen musst." — fact cards ----- */
const infoCards = [
  { eyebrow: 'Nächster Start', body: '1.8.2026' },
  { eyebrow: 'Dauer', body: '3 Monate' },
  { eyebrow: 'Durchführung', body: 'online oder hybrid, max. 6 Personen' },
  { eyebrow: 'Investition', body: 'CHF 3800.–' },
];

/* ----- FAQ — first 4 fill the left column, next 4 the right ----- */
const faqItems = [
  { question: 'Ist Level 1 vollständig oder nur ein Einstieg in Level 2?', answer: 'Level 1 ist ein vollwertiger, in sich geschlossener Ausbildungsabschnitt — und zugleich die Grundlage für Level 2. Du lernst das systemische Handwerk an dir selbst und kannst danach entscheiden, ob du weitergehen möchtest.' },
  { question: 'Für wen ist diese Ausbildung geeignet?', answer: 'Für alle, die mit Tiefe arbeiten wollen — ob um andere zu begleiten oder um sich selbst besser zu verstehen. Du brauchst keinen fachlichen Hintergrund, nur Offenheit und die Bereitschaft, dein eigenes System anzuschauen.' },
  { question: 'Muss ich nach Level 1 als Systemic Soulcoach arbeiten?', answer: 'Nein. Viele machen Level 1 für die eigene Entwicklung. Ob du das Gelernte beruflich einsetzt, bleibt vollständig dir überlassen.' },
  { question: 'Welche Vorkenntnisse brauche ich?', answer: 'Keine fachlichen. Wichtiger als Vorwissen sind deine Offenheit und die Bereitschaft, dich selbst und das eigene System wirklich anzuschauen.' },
  { question: 'Was ist der Unterschied zu einer klassischen Ausbildung?', answer: 'Wir arbeiten erfahrungsbasiert statt rein theoretisch. Du lernst nicht über Systeme, sondern in ihnen — an deinem eigenen System und an dem der Gruppe.' },
  { question: 'Wie gross ist die Gruppe?', answer: 'Bewusst klein: maximal 6 Personen. So bleibt genug Raum für jede:n — beim Aufstellen, im Austausch und in der persönlichen Begleitung durch Theresia.' },
  { question: 'Was kostet Level 1 und wie wird bezahlt?', answer: 'Die Investition für Level 1 beträgt CHF 3800.–. Ratenzahlung ist möglich — die Details besprechen wir gerne im Erstgespräch.' },
  { question: 'Kann ich rein online teilnehmen?', answer: 'Ja. Es gibt eine separate Online-Gruppe. Das ändert nichts am Umfang oder Startdatum — du bist genauso Teil der Ausbildung.' },
];
---

<BaseLayout
  title="Systemic Soulcoach Level 1 – VitaLunaris"
  description="Level 1 der Ausbildung zum Systemic Soulcoach bei Theresia Jansen — drei Monate, in denen du dein eigenes System verstehst und das Fundament für systemische Begleitung legst."
  currentPath="/ausbildung/soulcoach-level-1"
>
  <Hero
    eyebrow="Ausbildung · Systemic Soulwork Level 1 · 3 Monate"
    title="Entfalte deine<br />systemische Praxis"
    subtitle="Systemische Arbeit lernen wie sie gelernt werden sollte — an dir selbst. Drei Monate, in denen du endlich verstehst, warum sich bestimmte Dinge in deinem Leben immer wieder wiederholen. Warum bestimmte Beziehungen so sind wie sie sind. Warum du manchmal reagierst, obwohl du eigentlich gar nicht willst. Du räumst auf. Du schaust hin. Du verstehst. Für dich selbst, oder als Fundament, um Systemischer Coach zu werden."
    ctaText="Kostenloses Erstgespräch vereinbaren"
    ctaHref="#termin"
    image="/images/placeholder/Placeholder-9.jpg"
    imageFocus="center 15%"
  />

  {/* ===================== Narrative — lavender ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image="/images/placeholder/Placeholder-10.jpg"
    imageAlt=""
    title="Du kannst andere nur so weit begleiten, wie du selbst gegangen bist."
    body="Systemische Arbeit schaut nicht auf die Person allein — sondern auf das System dahinter. Die Familie, die Geschichte, die Muster die von Generation zu Generation weitergehen.<br /><br />Systemic Soulwork Level 1 ist nicht nur eine Ausbildung — es ist eine persönliche Reise. Die Inhalte, die du lernst, erlebst du gleichzeitig an dir selbst. Familienkonstellationen, eigene Muster, Bindungsdynamiken — du verstehst sie nicht nur theoretisch. Du spürst sie.<br /><br />Viele Teilnehmer:innen kommen, weil sie andere begleiten möchten. Manche kommen, weil sie sich selbst besser verstehen wollen. Andere einfach, weil sie spüren, dass da etwas ist, das Aufmerksamkeit braucht. Alle drei Wege sind richtig."
  />

  {/* ===================== Wir schauen auf: — outcomes arc ===================== */}
  <section class="outcomes">
    <header class="outcomes__header">
      <Heading level={2} variant="h1" class="outcomes__title">In den drei Monaten tauchen wir tief in:</Heading>
    </header>

    {/* Desktop (≥1024px): single curve + absolutely positioned cards at ≥1072 */}
    <div class="outcomes__desktop">
      <img src="/images/ebene/process-curve.svg" alt="" class="outcomes__curve" />
      <div class="outcomes__cards">
        {outcomes.map((o, i) => (
          <article class={`outcomes__card outcomes__card--${i + 1}`}>
            <Heading level={3} class="outcomes__card-title">{o.title}</Heading>
            <Text size="p1" class="outcomes__card-body">{o.description}</Text>
          </article>
        ))}
      </div>
    </div>

    {/* Mobile/tablet (<1024px): two halves, each with its own curve + 2 cards */}
    <div class="outcomes__mobile">
      {[0, 2].map((startIdx) => (
        <div class="outcomes__mobile-section">
          <div class="outcomes__mobile-curve">
            <img
              src={startIdx === 0 ? '/images/ebene/process-curve-1.svg' : '/images/ebene/process-curve-2.svg'}
              alt=""
            />
          </div>
          <div class="outcomes__mobile-cards">
            {outcomes.slice(startIdx, startIdx + 2).map((o) => (
              <article class="outcomes__mobile-card">
                <Heading level={3} class="outcomes__card-title">{o.title}</Heading>
                <Text size="p1" class="outcomes__card-body">{o.description}</Text>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="outcomes__cta">
      <Button href="/kontakt" variant="primary" size="lg">Jetzt für Level 1 anmelden</Button>
    </div>
  </section>

  {/* ===================== Was dich nach drei Monaten erwartet ===================== */}
  <NarrativeBlock
    tone="light"
    imageSide="left"
    image="/images/placeholder/placeholder-3.jpg"
    imageAlt=""
    title="Was dich nach drei Monaten erwartet"
    body="Die meisten Teilnehmer:innen verstehen sich selbst, ihre Beziehungen und ihre Lebensgeschichte mit anderen Augen. Was vorher verwirrend oder wiederkehrend war, wird verständlicher und leichter. Viele erleben mehr Vertrauen in sich selbst, mehr Gelassenheit im Umgang mit Herausforderungen — und das Gefühl, ihrem eigenen Weg wieder näher gekommen zu sein."
  />

  {/* ===================== Stimmen aus der Ausbildung ===================== */}
  <TestimonialsBlock title="Stimmen aus der Ausbildung" testimonials={reviews} />

  {/* ===================== Theresia Jansen — gold, image right ===================== */}
  <section class="lehrerin">
    <div class="lehrerin__inner">
      <div class="lehrerin__content">
        <Heading variant="eyebrow" class="lehrerin__eyebrow">Theresia Jansen</Heading>
        <Heading level={2} variant="h1" class="lehrerin__name">Entfalte was in dir ist, um weiterzugeben was du weisst.</Heading>
        <Text size="p1" class="lehrerin__body">
          Theresia Jansen lehrt nicht, was sie gelesen hat — sondern was sie über 30 Jahre hinweg erprobt, durchlebt und verfeinert hat. Kein importiertes Curriculum, sondern echte Praxis mit echten Menschen in der Deutschschweiz.
        </Text>
        <Text size="p1" class="lehrerin__body">
          In Level 1 begleitet Theresia die Gruppe sowohl methodisch als auch in der Tiefe des Prozesses. Sie bringt ein, was sie selbst durchlebt und erprobt hat.
        </Text>
      </div>
      <div class="lehrerin__media">
        <img src="/images/placeholder/Placeholder-8.jpg" alt="Theresia Jansen" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  {/* ===================== In drei Schritten zu deinem Platz ===================== */}
  <ProcessSteps
    title="In drei Schritten zu deinem Platz"
    steps={[
      { number: '1', title: 'Erstgespräch', description: 'Wir nehmen uns 45 Minuten Zeit füreinander. Du erzählst, wo du gerade stehst und was dich bewegt. Ich erzähle dir von der Ausbildung und beantworte dir all deine Fragen. Dann schauen wir gemeinsam, ob es passt.', color: 'purple' },
      { number: '2', title: 'Anmeldung', description: 'Wenn es für uns beide stimmt, erhältst du deinen Anmeldelink und reservierst dir da deinen Platz verbindlich.', color: 'raspberry' },
      { number: '3', title: 'Anfang', description: 'Du erhältst alle Zugänge und alles was du brauchst und startest am nächsten Startdatum in der Gruppe – nur online oder hybrid vor Ort.', color: 'aurora' },
    ]}
    ctaText="Kostenloses Erstgespräch vereinbaren"
    ctaHref="#termin"
  />

  {/* ===================== Alles was du wissen musst. ===================== */}
  <section class="wissen">
    <div class="wissen__inner">
      <Heading level={2} variant="h1" class="wissen__title">Alles was du wissen musst.</Heading>
    </div>
  </section>

  <InfoCardsRow cards={infoCards} />

  <section class="wissen-foot">
    <div class="wissen-foot__inner">
      <Text size="p1" class="wissen-foot__caption">Die Präsenztage finden jeden Donnerstag von 16:00 bis 18:00 statt. Solltest du die Ausbildung nur Online machen wollen, ist das kein Problem, es gibt eine separate Online-Gruppe und ändert nichts am Umfang oder Startdatum.</Text>
      <div class="wissen-foot__cta">
        <Button href="#termin" variant="primary" size="lg" class="wissen-foot__btn">Kostenloses Erstgespräch vereinbaren</Button>
        <Button href="/kontakt" variant="header" size="lg" class="wissen-foot__btn">Fragen? Schreib uns.</Button>
      </div>
    </div>
  </section>

  {/* ===================== Termin buchen ===================== */}
  <CalendarBooking
    slug="soulcoach-level-1-gespraech"
    eyebrow="Dein Gespräch zu Level 1"
    title="Buche dein Gespräch"
    intro="45 Minuten, unverbindlich. Deine Fragen, deine Eignung und die nächsten Schritte zur Ausbildung."
  />

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />

  {/* ===================== Infoanlass — dark CTA with form ===================== */}
  <section class="infoanlass">
    <div class="infoanlass__card">
      <div class="infoanlass__content">
        <Heading variant="eyebrow" class="infoanlass__eyebrow">Infoanlass</Heading>
        <Heading level={2} variant="h1" class="infoanlass__title">Komm zum<br />nächsten Infoanlass.</Heading>
        <Text size="p1" class="infoanlass__body">Du möchtest mehr über die Systemic Soulwork Ausbildung zum Systemic Soulcoach erfahren? Beim kostenlosen Online-Infoabend via Zoom erhältst du einen ehrlichen Einblick in Inhalte, Aufbau und Arbeitsweise — und Raum für alle deine Fragen.</Text>
        <form class="infoanlass__form" action="#" method="POST" novalidate data-mailto-form data-recipient="info@vitalunaris.ch" data-subject="Anmeldung Infoanlass — Systemic Soulcoach Level 1">
          <label for="infoanlass-email" class="infoanlass__label">E-Mail-Adresse</label>
          <input
            id="infoanlass-email"
            type="email"
            name="email"
            class="infoanlass__input"
            placeholder="E-mail Adresse"
            required
            autocomplete="email"
          />
          <button type="submit" class="infoanlass__submit">Für Infoanlass anmelden</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    function initMailtoForms() {
      document.querySelectorAll('[data-mailto-form]').forEach((form) => {
        const el = form as HTMLFormElement & { dataset: DOMStringMap };
        if (el.dataset.bound) return;
        el.dataset.bound = 'true';

        el.addEventListener('submit', (e) => {
          e.preventDefault();
          const input = el.querySelector('input[type="email"]') as HTMLInputElement | null;
          const email = input?.value.trim();
          if (!email || !input?.checkValidity()) { input?.reportValidity(); return; }

          const recipient = el.dataset.recipient || 'info@vitalunaris.ch';
          const subject = el.dataset.subject || 'Anmeldung';
          const lines = [
            'Ich möchte mich für den Infoanlass anmelden.',
            '',
            `E-Mail-Adresse: ${email}`,
          ];
          window.location.href =
            `mailto:${recipient}` +
            `?subject=${encodeURIComponent(subject)}` +
            `&body=${encodeURIComponent(lines.join('\n'))}`;
        });
      });
    }

    initMailtoForms();
    document.addEventListener('astro:page-load', initMailtoForms);
  </script>
</BaseLayout>

<style>
  /* ============================================================
     OUTCOMES — "Wir schauen auf:" (dome arc, 4 cards + CTA)
     Mobile/tablet (<1024): two halves with separate curves (-1, -2)
     Desktop (≥1024): single process-curve.svg
     Desktop++ (≥1072): cards + CTA absolutely positioned per Figma
     ============================================================ */
  .outcomes {
    background: var(--c-spring-wood);
    padding: 64px 8px;
    overflow: hidden;
  }
  @media (min-width: 768px)  { .outcomes { padding: 96px 8px; } }
  @media (min-width: 1024px) { .outcomes { padding: 120px 8px; } }

  .outcomes__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 12px;
    max-width: 1106px;
    margin: 0 auto;
  }
  .outcomes__title { text-align: center; color: var(--c-cherrywood); margin: 0; }

  .outcomes__card-title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }
  .outcomes__card-body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }

  .outcomes__cta {
    display: flex;
    justify-content: center;
    padding: 24px 12px 0;
  }

  .outcomes__desktop { display: none; }
  .outcomes__mobile  { display: block; margin-top: 24px; }

  @media (min-width: 1024px) {
    .outcomes__desktop { display: block; margin-top: 32px; }
    .outcomes__mobile  { display: none; }
    .outcomes__curve { display: block; width: 100%; height: auto; margin: 0; }
  }

  @media (min-width: 1024px) and (max-width: 1071.98px) {
    .outcomes__cards {
      position: relative;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      padding: 0 90px;
      margin-top: 40px;
      min-height: 0;
      box-sizing: border-box;
    }
    .outcomes__card {
      position: static;
      width: auto;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      color: var(--c-cherrywood);
    }
  }

  @media (min-width: 1072px) {
    .outcomes {
      position: relative;
      --cv: min(100vw, 1920px);
      --cx: calc((100vw - var(--cv)) / 2);
      min-height: calc(0.68177 * var(--cv));
      padding: 120px 0;
    }
    .outcomes__header { max-width: 1106px; padding: 0 12px; margin: 0 auto; }

    .outcomes__desktop {
      position: static;
      width: 100%;
      max-width: 1920px;
      margin: 32px auto 0;
    }
    .outcomes__curve { max-width: none; }
    .outcomes__cards { position: static; display: block; padding: 0; margin: 0; }

    .outcomes__card {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(16px, 2.1vw, 40px);
      color: var(--c-cherrywood);
    }
    .outcomes__card--1 { left: calc(var(--cx) + 0.05000 * var(--cv)); top: calc(0.37344 * var(--cv)); width: calc(0.20104 * var(--cv)); }
    .outcomes__card--2 { left: calc(var(--cx) + 0.27552 * var(--cv)); top: calc(0.29792 * var(--cv)); width: calc(0.20104 * var(--cv)); }
    .outcomes__card--3 { left: calc(var(--cx) + 0.50677 * var(--cv)); top: calc(0.28958 * var(--cv)); width: calc(0.20000 * var(--cv)); }
    .outcomes__card--4 { left: calc(var(--cx) + 0.73698 * var(--cv)); top: calc(0.38177 * var(--cv)); width: calc(0.20000 * var(--cv)); }

    .outcomes__card-title { font-size: clamp(24px, 2.1vw, 40px); line-height: 1.15; }
    .outcomes__card-body  { font-size: clamp(16px, 1.2vw, 23px); line-height: 1.5; }

    .outcomes__cta {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      top: calc(0.59583 * var(--cv));
      padding: 0;
      justify-content: center;
    }
  }

  .outcomes__mobile-section { margin-top: 24px; }
  .outcomes__mobile-section:first-child { margin-top: 0; }

  .outcomes__mobile-curve {
    width: auto;
    aspect-ratio: 600 / 130;
    overflow: visible;
    margin-left: -8px;
    margin-right: -8px;
    padding: 0;
    box-sizing: content-box;
  }
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .outcomes__mobile-curve { padding-top: 16px; }
  }
  .outcomes__mobile-curve img { display: block; width: 100%; height: 100%; }

  .outcomes__mobile-cards {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 16px 12px 0;
  }
  @media (min-width: 480px) and (max-width: 1023.98px) {
    .outcomes__mobile-cards {
      flex-direction: row;
      gap: 28px;
      padding: 24px 12px 0;
      align-items: flex-start;
    }
    .outcomes__mobile-cards > .outcomes__mobile-card {
      flex: 1 1 0;
      min-width: 0;
      max-width: calc(50% - 14px);
    }
  }
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .outcomes__mobile-cards { gap: 44px; padding: 32px 44px 0; }
    .outcomes__mobile-cards > .outcomes__mobile-card { max-width: calc(50% - 22px); }
  }

  .outcomes__mobile-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
    text-align: left;
    color: var(--c-cherrywood);
  }
  @media (min-width: 768px) { .outcomes__mobile-card { gap: 26.67px; } }

  /* ============================================================
     LEHRERIN — "Theresia Jansen" (Pale Gold, text left / image right)
     ============================================================ */
  .lehrerin { background: var(--c-pale-gold); padding: 60px 20px; }
  @media (min-width: 768px)  { .lehrerin { padding: 80px 32px; } }
  @media (min-width: 1280px) { .lehrerin { padding: 90px 60px; } }
  @media (min-width: 1920px) { .lehrerin { padding: 90px; } }

  .lehrerin__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) { .lehrerin__inner { flex-direction: row; align-items: center; gap: 64px; } }
  @media (min-width: 1920px) { .lehrerin__inner { gap: 100px; } }

  .lehrerin__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: 16.67px;
    background: rgba(96, 29, 29, 0.06);
    aspect-ratio: 4 / 5;
    order: -1;
  }
  @media (min-width: 1024px) { .lehrerin__media { width: 46%; border-radius: 20px; order: 0; } }
  @media (min-width: 1920px) { .lehrerin__media { width: 711px; border-radius: 25px; aspect-ratio: 711 / 826; } }
  .lehrerin__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .lehrerin__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
  }
  @media (min-width: 1024px) { .lehrerin__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .lehrerin__content { gap: 32px; max-width: 813px; } }

  .lehrerin__eyebrow { color: var(--c-cherrywood); }
  .lehrerin__name {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .lehrerin__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }

  /* ============================================================
     WISSEN — "Alles was du wissen musst." (header + cards + footer)
