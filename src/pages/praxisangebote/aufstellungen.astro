---
import BaseLayout from '@layouts/BaseLayout.astro';
import CourseHero from '@organisms/CourseHero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import ProcessSteps from '@organisms/ProcessSteps.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import PersonBio from '@organisms/PersonBio.astro';
import BrandCtaBlock from '@organisms/BrandCtaBlock.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';
import { getEmDashEntry } from 'emdash';
import { nl2br, imageUrl, getTestimonials } from '@lib/cms';

// ── CMS: editable at /_emdash/admin (falls back to original copy) ──────────
const { entry } = await getEmDashEntry('praxisangebote', 'aufstellungen');
const d: Record<string, any> = entry?.data ?? {};
const { entry: person } = await getEmDashEntry('team', d.practitioner || 'theresia-jansen');
const pd: Record<string, any> = person?.data ?? {};

const bookingUrl = d.hero_cta_href || 'https://app.healthadvisor.ch/bookings/c364704cac70ab94901c6b34b25bb825';

const steps = d.process_steps?.length ? d.process_steps : [
  { number: '01', title: 'Buchen', description: 'Du kannst hier direkt einen Termin buchen, vor Ort oder Online.' },
  { number: '02', title: 'Thema klären', description: 'Was bringst du mit? Was soll sich zeigen? Theresia hört zu und hilft, das Thema systemisch zu fassen.' },
  { number: '03', title: 'Aufstellen', description: 'Mit Bodenanker oder Aufstellungsbrett — das System wird im Raum sichtbar. Was zeigt sich? Was will sich bewegen?' },
  { number: '04', title: 'Integrieren', description: 'Was du mitnimmst. Was sich gezeigt hat. Was als nächstes kommen darf.' },
];

const _ts = await getTestimonials('praxis-aufstellungen');
const testimonials = _ts.length ? _ts : [
  { quote: '«Danke von ganzem Herzen. Durch deine Begleitung und die systemische Arbeit habe ich vieles über mich erkannt und den Mut gefunden, meinen eigenen Weg zu gehen. Heute bin ich selbständig – etwas, das ich mir früher kaum zugetraut hätte.»', name: 'Steffi K.' },
  { quote: '«Unsere Sitzung hat mich kurz danach durch ein wichtiges Gespräch getragen — klar, wach und ganz bei mir. Ich danke dir von Herzen für diese liebevolle und tiefwirkende Begleitung.»', name: 'Zsannet T. Nagy' },
  { quote: '«Erkenntnisse. Aha-Momente. Gänsehaut. Ein Nervensystem, das sich so tief beruhigt hat wie noch nie. Stolz. Klar. Frei. Von Herzen danke, Theresia.»', name: 'Christina G.' },
  { quote: '«Du hast mich von Anfang an unterstützt, verstanden und nicht locker gelassen. Heute fliesst es einfach. Ich übe meinen Traumjob aus und fühle mich am richtigen Ort zur richtigen Zeit. Von Herzen danke.»', name: 'Nicole S.' },
];

const faqItems = d.faq_items?.length ? d.faq_items : [
  { question: 'Muss ich bereits Erfahrung mit Aufstellungen haben?', answer: 'Nein. Du brauchst kein Vorwissen. Theresia begleitet dich Schritt für Schritt — du musst nur offen sein für das, was sich zeigt.' },
  { question: 'Funktioniert eine Aufstellung auch ohne Gruppe?', answer: 'Ja. Im geschützten Einzelsetting schauen wir gemeinsam auf dein Anliegen — mit Bodenankern vor Ort oder am Aufstellungsbrett online.' },
  { question: 'Welche Themen können aufgestellt werden?', answer: 'Familiengeschichte, Kinderwunsch, Partnerschaft, berufliche Entscheidungen, wiederkehrende Muster oder Körpersymptome.' },
  { question: 'Muss ich meine ganze Familiengeschichte kennen?', answer: 'Nein. Es genügt, was du weisst. Oft zeigen sich Zusammenhänge gerade dort, wo wir bewusst (noch) keine Erklärung haben.' },
  { question: 'Ist eine Sitzung auch online möglich?', answer: 'Ja. Vor Ort arbeite ich je nach Thema mit Bodenankern oder dem Aufstellungsbrett mit Figuren.<br /><br />Online nutze ich ein spezielles digitales Aufstellungsbrett, das eine Aufstellung nahezu 1:1 ermöglicht. Du kannst deine Figuren selbst bewegen, Positionen verändern und aktiv am Prozess teilnehmen – genau wie in einer Präsenzsitzung.<br /><br />Die Erfahrung zeigt, dass beide Formate gleichermassen wirkungsvoll sind. Entscheidend ist nicht, ob wir online oder vor Ort arbeiten, sondern die Bereitschaft, das eigene Thema anzuschauen und neue Perspektiven zuzulassen.' },
  { question: 'Was passiert nach der Sitzung?', answer: 'Was sich gezeigt hat, darf sich in deinem Alltag setzen. Auf Wunsch begleiten wir dich mit einem 7- oder 30-tägigen Online-Support, um das Erlebte zu stabilisieren und zu integrieren.' },
];

const bioParagraphs = pd.bio_paragraphs?.length
  ? pd.bio_paragraphs.map((p: any) => p.text)
  : [
      'Ich glaube, dass hinter vielen Herausforderungen nicht mangelnde Stärke steckt, sondern Zusammenhänge, die bisher nicht sichtbar waren.',
      'Seit über 30 Jahren begleite ich Menschen dabei, diese Zusammenhänge zu erkennen, festgefahrene Muster zu verstehen und neue Wege zu finden.',
      'Was ich weitergebe, stammt aus vielen Ausbildungen, tausenden Begegnungen mit Menschen – und aus meinem eigenen Leben. Ich begleite als Mensch, der selbst Höhen und Tiefen erlebt hat und weiss, dass Veränderung möglich ist.',
    ];
---

<BaseLayout
  title={d.seo_title || '1:1 Aufstellung mit Theresia Jansen | VitaLunaris'}
  description={d.seo_description || 'Systemisches Aufstellen im Einzelsetting mit Theresia Jansen — individuelle Begleitung für dein persönliches Anliegen, achtsam und lösungsorientiert.'}
  currentPath="/praxisangebote/aufstellungen"
>
  <CourseHero
    categoryMeta={d.hero_category || 'Systemisches Aufstellen | 1:1 Aufstellung'}
    title={d.hero_title || '1:1 Aufstellung<br />mit Theresia Jansen'}
    description={d.hero_description || 'Systemische Aufstellungen machen sichtbar, was unter der Oberfläche wirkt — Loyalitäten, Verstrickungen und unbewusste Dynamiken aus der Familiengeschichte. Was sich wiederholt oder festgefahren anfühlt, hat oft tiefere Zusammenhänge. Das hier ist die individuelle Begleitung für dein persönliches Anliegen – achtsam, lösungsorientiert und in deinem Tempo.'}
    durationMeta={d.hero_duration || 'Einzelsitzung | 90–120 Min. | Online oder vor Ort'}
    price={d.hero_price || 'CHF 240.–'}
    note={d.hero_note || 'Optional: Begleitender Online-Support — 7 Tage CHF 77.– · 30 Tage CHF 222.–'}
    ctaText={d.hero_cta_text || 'Termin buchen'}
    ctaHref={bookingUrl}
    image={imageUrl(d.hero_image) || '/images/placeholder/placeholder-2.jpg'}
  />

  {/* ===================== Einzelsetting (image left) ===================== */}
  <NarrativeBlock
    tone="light"
    imageSide="left"
    image={imageUrl(d.narrative_image) || '/images/placeholder/Placeholder-24.jpg'}
    imageAlt=""
    title={d.narrative_title || 'Systemisches Aufstellen im Einzelsetting.'}
    body={nl2br(d.narrative_body) || 'Du brauchst keine Gruppe, um von einer Aufstellung zu profitieren. Im geschützten Einzelsetting schauen wir gemeinsam auf dein Anliegen – online oder vor Ort in der Praxis. Dabei arbeiten wir mit Bodenankern oder dem Aufstellungsbrett.'}
  />

  {/* ===================== Process ===================== */}
  <ProcessSteps steps={steps} ctaText="Termin buchen" ctaHref={bookingUrl} />

  {/* ===================== Lavender quote ===================== */}
  <NarrativeBlock
    tone="purple"
    imageSide="right"
    image={imageUrl(d.quote_image) || '/images/placeholder/Placeholder-25.jpg'}
    imageAlt=""
    title={d.quote_text || '„Nicht alles, was dich belastet, gehört zu dir. Manches möchte einfach gesehen und an seinen richtigen Platz gestellt werden.”'}
    body={d.quote_attribution || 'Theresia Jansen'}
  />

  {/* ===================== Testimonials ===================== */}
  <TestimonialsBlock title="Was unsere Kunden sagen" testimonials={testimonials} tone={d.testimonials_tone || 'gold'} />

  {/* ===================== Bio ===================== */}
  <PersonBio
    eyebrow={pd.eyebrow || 'wer dich begleitet'}
    name={pd.name || 'Theresia Jansen'}
    paragraphs={bioParagraphs}
    image={imageUrl(pd.image) || '/images/placeholder/Placeholder-8.jpg'}
    imageSide="right"
  />

  {/* ===================== Brand CTA ===================== */}
  <BrandCtaBlock
    title={d.brand_cta_title || 'Bereit, tiefer<br />zu gehen?'}
    body={d.brand_cta_body || 'Ein konkretes Thema, ein gewisses Gefühl, eine Sehnsucht. Theresia begleitet dich dorthin, wo sich wirklich etwas bewegt. Termin buchen — in deinem Tempo, auf deinem Weg.'}
    ctaText={d.brand_cta_text || 'Termin buchen'}
    ctaHref={d.brand_cta_href || bookingUrl}
  />

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />

  {/* ===================== Newsletter ===================== */}
  <NewsletterBlock
    eyebrow="Newsletter"
    title="Erforsche die Systeme<br />deiner Seele"
    body="Noch nicht bereit für eine Sitzung? Kein Problem. In meinem Newsletter teile ich regelmässig Inspirationen, systemische Gedankenanstösse und Impulse für mehr Klarheit und innere Balance. Ich freue mich, wenn wir in Verbindung bleiben."
    placeholder="E-mail Adresse"
    submitText="Newsletter anmelden"
  />
</BaseLayout>
