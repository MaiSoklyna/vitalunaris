---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

type Tone = 'light' | 'dark';
type ImageSide = 'left' | 'right';

interface Props {
  eyebrow: string;
  title: string;
  body: string;
  image: string;
  imageAlt?: string;
  imageSide?: ImageSide;
  tone?: Tone;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  eyebrow,
  title,
  body,
  image,
  imageAlt = '',
  imageSide = 'left',
  tone = 'light',
  primaryText,
  primaryHref = '/kontakt',
  secondaryText,
  secondaryHref = '#',
} = Astro.props;

/* Dark rows show a single full-width outline button; light rows show the
   filled primary + outline secondary pair. */
const isDark = tone === 'dark';
---

<article class={`offer-row offer-row--${tone} offer-row--image-${imageSide}`}>
  <div class="offer-row__media">
    <img src={image} alt={imageAlt} class="offer-row__image" loading="lazy" decoding="async" />
  </div>

  <div class="offer-row__content">
    <Heading variant="eyebrow" class="offer-row__eyebrow">{eyebrow}</Heading>
    <Heading level={2} variant="h2" class="offer-row__title"><Fragment set:html={title} /></Heading>
    <Text size="p1" class="offer-row__body">{body}</Text>

    <div class="offer-row__cta">
      {primaryText && (
        <Button
          href={primaryHref}
          variant={isDark ? 'secondary' : 'primary'}
          size="sm"
          fullWidth={isDark}
          class="offer-row__btn"
        >{primaryText}</Button>
      )}
      {secondaryText && (
        <Button
          href={secondaryHref}
          variant={isDark ? 'insert' : 'header'}
          size={isDark ? 'lg' : 'sm'}
          class="offer-row__btn"
        >{secondaryText}</Button>
      )}
    </div>
  </div>
</article>

<style>
  /* ============================================================
     PRACTICE OFFER ROW — bordered card, image + text side-by-side.
     Mobile: stacked (image on top). ≥768px: row.
     Light = Spring Wood card w/ Cherrywood border + text.
     Dark  = Cherrywood card, Spring Wood text (Jawort variant).
     ============================================================ */
  .offer-row {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-radius: 16.67px;
    padding: 16px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .offer-row {
      flex-direction: row;
      align-items: stretch;
      gap: 32px;
      padding: 20px;
      border-radius: 20px;
    }
    .offer-row--image-right { flex-direction: row-reverse; }
  }
  @media (min-width: 1280px) {
    .offer-row { gap: 48px; padding: 24px; border-radius: 25px; }
  }
  @media (min-width: 1920px) {
    .offer-row { gap: 64px; padding: 32px; }
  }

  /* ----- tones ----- */
  .offer-row--light {
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    color: var(--c-cherrywood);
  }
  .offer-row--dark {
    background: var(--c-cherrywood);
    border: 1px solid var(--c-cherrywood);
    color: var(--c-spring-wood);
  }

  /* ----- media ----- */
  .offer-row__media {
    flex: 0 0 auto;
    width: 100%;
    aspect-ratio: 16 / 11;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(96, 29, 29, 0.06);
  }
  @media (min-width: 768px) {
    .offer-row__media {
      width: 42%;
      aspect-ratio: auto;
      border-radius: 14px;
      align-self: stretch;
    }
  }
  @media (min-width: 1280px) {
    .offer-row__media { width: 40%; border-radius: 16px; }
  }
  .offer-row__image { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ----- content ----- */
  .offer-row__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 14px;
    flex: 1 1 auto;
    min-width: 0;
    padding: 4px 4px 8px;
  }
  @media (min-width: 768px)  { .offer-row__content { gap: 16px; padding: 8px 0; } }
  @media (min-width: 1280px) { .offer-row__content { gap: 20px; padding: 16px 24px 16px 0; } }
  .offer-row--image-right .offer-row__content { padding-right: 0; }
  @media (min-width: 1280px) {
    .offer-row--image-right .offer-row__content { padding-left: 24px; padding-right: 0; }
  }

  .offer-row__eyebrow {
    color: inherit;
    align-self: stretch;
  }
  .offer-row__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h2-size);
    line-height: 1.15;
    color: inherit;
    margin: 0;
    align-self: stretch;
  }
  .offer-row__body {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    color: inherit;
    align-self: stretch;
    max-width: 60ch;
  }

  /* ----- CTA group ----- */
  .offer-row__cta {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
    width: 100%;
  }
  .offer-row__cta :global(.offer-row__btn) {
    min-height: 44px;
    padding: 12px 24px;
    border-radius: 100px;
    font-size: var(--button-size);
  }
  /* Dark row: Spring Wood "Primary Button L" (Cherrywood border + text), auto width */
  .offer-row--dark .offer-row__cta :global(.offer-row__btn) {
    flex: 0 0 auto;
    border: 1.25px solid var(--c-cherrywood);
    padding: 20px 40px;
  }
</style>
