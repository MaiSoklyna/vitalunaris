---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@organisms/Hero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import InfoCardsRow from '@organisms/InfoCardsRow.astro';
import Faq from '@organisms/Faq.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';
import { getEmDashEntry } from 'emdash';
import { nl2br, imageUrl, getTestimonials } from '@lib/cms';

// Editable at /_emdash/admin/content/ausbildung_programs (falls back to copy below).
const { entry } = await getEmDashEntry('ausbildung_programs', 'soulcoach-level-2');
const d: Record<string, any> = entry?.data ?? {};

/* Shared CTA labels (used in several sections) */
const CTA_ANMELDEN = d.hero_primary_cta_text || 'Jetzt für Level 2 anmelden';
const CTA_ERSTGESPRAECH = 'Kostenloses Erstgespräch vereinbaren';
const CTA_HREF = d.hero_primary_cta_href || '/kontakt';

/* ----- "In den drei Monaten tauchen wir tief in:" — outcomes arc (4 modules) ----- */
const outcomes = d.outcomes?.length ? d.outcomes : [
  {
    title: 'Modul 1 — Aufstellen & Wahrnehmen',
    description: 'Das Aufstellungsbrett, Raumaufstellungen und Bodenanker: Du lernst, systemische Prozesse sichtbar zu machen, Dynamiken im Raum wahrzunehmen und Aufstellungen sicher anzuleiten.',
  },
  {
    title: 'Modul 2 — Nervensystem & Tiefe',
    description: 'Wie Veränderungsprozesse auf das Nervensystem wirken und wie du Intuition mit systemischer Wahrnehmung verbindest. Du begleitest Menschen sicher durch emotionale Prozesse.',
  },
  {
    title: 'Modul 3 — Energie & Ahnenlinien',
    description: 'Energetische Dynamiken erkennen, Ahnenlinien einbeziehen und auch bei komplexen oder herausfordernden Themen den Überblick behalten.',
  },
  {
    title: 'Modul 4 — Prozessführung & Abschluss',
    description: 'Du entwickelst deinen eigenen Stil als Coach, gewinnst Sicherheit in der Gesprächsführung und integrierst alle Inhalte für deine eigenständige Arbeit.',
  },
];

/* ----- "In drei Schritten zu deinem Platz" — 3-step onboarding ----- */
const steps = [
  {
    number: '1',
    title: 'Vorgespräch',
    description: 'Wir schauen gemeinsam, ob Level 2 der richtige nächste Schritt für dich ist. Du erzählst, wo du gerade stehst — ich erzähle dir, was dich erwartet.',
  },
  {
    number: '2',
    title: 'Anmeldung',
    description: 'Wenn es für uns beide stimmt, erhältst du den Anmeldelink und sicherst dir deinen Platz in der Gruppe.',
  },
  {
    number: '3',
    title: 'Anfang',
    description: 'Du erhältst alle Zugänge und alles was du brauchst und startest am nächsten Startdatum.',
  },
];

/* ----- "Stimmen aus der Ausbildung" — star reviews ----- */
const _reviews = await getTestimonials('ausbildung');
const reviews = _reviews.length ? _reviews : [
  {
    quote: '«Diese Ausbildung hat mir eine völlig neue Perspektive eröffnet. Ich war lange eher im Kopf als im Körper — genau das beginnt sich zu verändern. Die Arbeit mit Familienkonstellationen hat mir geholfen, Klarheit zu gewinnen. Wo vorher Chaos war, entsteht heute mehr Ruhe und Vertrauen. Ich fühle mich mehr bei mir selbst angekommen.»',
    name: 'Jana L.',
  },
  {
    quote: '«In dieser Ausbildungsgruppe fühle ich mich so getragen, dass ich mit allem da sein kann, was ich bin. So habe ich mich in einer Gruppe noch nie gefühlt. In mir ist eine grosse Welle in Bewegung gekommen — früher hätte ich solche Gefühle verdrängt, heute gehe ich durch sie hindurch. Diese Ausbildung ist für mich weit mehr als Lernen. Sie ist ein Raum für Heilung, Wachstum und echtes Menschsein.»',
    name: 'Silvia F.',
  },
  {
    quote: '«Diese Ausbildung zeigt die Magie des systemischen Aufstellens — und ich könnte mir keinen Ort vorstellen, an dem ich mich wohler fühle. Ein geschützter Raum, in dem jede einfach sie selbst sein darf. Theresia schafft diesen Rahmen mit einer einfühlsamen Art, die es möglich macht, sich wirklich zu öffnen. Was diese Ausbildung besonders macht: die Erfahrung, selbst Teil eines solchen Prozesses zu sein.»',
    name: 'Corina B.',
  },
];

/* ----- "Alles was du wissen musst." — fact cards ----- */
const infoCards = d.info_cards?.length ? d.info_cards : [
  { eyebrow: 'Nächster Start', body: 'Noch unbekannt' },
  { eyebrow: 'Dauer', body: '3 Monate' },
  { eyebrow: 'Durchführung', body: 'online oder hybrid, max. 6 Personen' },
  { eyebrow: 'Investition', body: 'CHF 5200.–' },
];

/* ----- FAQ — first 4 fill the left column, next 4 the right ----- */
const faqItems = d.faq_items?.length ? d.faq_items : [
  { question: 'Muss ich Level 1 gemacht haben?', answer: 'Ja. Level 2 baut direkt auf der Selbsterfahrung aus Level 1 auf — du kannst andere nur dorthin begleiten, wo du selbst schon warst. Hast du eine vergleichbare systemische Selbsterfahrungsausbildung absolviert, sprich uns an.' },
  { question: 'Kann ich rein online teilnehmen?', answer: 'Ja. Es gibt eine separate Online-Gruppe. Am Umfang und am Startdatum ändert das nichts.' },
  { question: 'Bekomme ich ein Zertifikat?', answer: 'Ja. Nach erfolgreichem Abschluss von Level 2 erhältst du ein Zertifikat als Systemic Soulcoach.' },
  { question: 'Kann ich danach selbständig als Coach arbeiten?', answer: 'Ja. Du kannst eigenständig systemisch begleiten — Einzel- und Gruppenaufstellungen führen und die Methode in deine Arbeit integrieren oder als eigene Praxis anbieten.' },
  { question: 'Welche Vorkenntnisse brauche ich über Level 1 hinaus?', answer: 'Keine weiteren fachlichen. Die wichtigste Voraussetzung ist Level 1 — oder eine vergleichbare systemische Selbsterfahrung. Alles andere lernst du in Level 2.' },
  { question: 'Wie gross ist die Gruppe?', answer: 'Die Gruppen sind bewusst klein — maximal 6 Personen. So bleibt genug Raum für Tiefe und persönliche Begleitung.' },
  { question: 'Was kostet Level 2 und wie wird bezahlt?', answer: 'Die Investition für Level 2 beträgt CHF 5200.–. Ratenzahlung ist möglich — die Details besprechen wir gerne im Erstgespräch.' },
  { question: 'Was wenn ich schon eine vergleichbare systemische Selbsterfahrungsausbildung wie Level 1 gemacht habe?', answer: 'Dann ist ein Einstieg in Level 2 nach Rücksprache möglich. Melde dich für ein kostenloses Erstgespräch — wir schauen gemeinsam, ob deine Vorerfahrung passt.' },
];
---

<BaseLayout
  title="Systemic Soulwork Level 2 – VitaLunaris"
  description="Level 2 der Systemic-Soulwork-Ausbildung bei Theresia Jansen — die professionelle Ausbildung für Absolvent:innen von Level 1: andere systemisch begleiten mit Methode, Haltung und eigener Erfahrung."
  currentPath="/ausbildung/soulcoach-level-2"
>
  <Hero
    eyebrow={d.hero_eyebrow || 'Ausbildung · Systemic Soulcoach Level 2 · 3 Monate'}
    title={d.hero_title || 'Vertiefe deine<br />systemische Praxis<br />und gib sie weiter.'}
    subtitle={d.hero_subtitle || 'Level 2 ist die professionelle Ausbildung für Absolvent:innen von Level 1. In drei Monaten lernst du, andere systemisch zu begleiten — mit Methode, Haltung und dem Fundament eigener Erfahrung. Du hast erlebt, wie tiefgründig systemische Arbeit sein kann. Jetzt lernst du, andere auf diesem Weg zu begleiten.'}
    ctaText={CTA_ANMELDEN}
    ctaHref={CTA_HREF}
    image={imageUrl(d.hero_image) || '/images/placeholder/Placeholder-8.jpg'}
  />

  {/* ===================== Narrative — gold gradient ===================== */}
  <NarrativeBlock
    tone="light"
    imageSide="left"
    image={imageUrl(d.narrative_image) || '/images/placeholder/Placeholder-11.jpg'}
    imageAlt=""
    title={d.narrative_title || 'Was du in dir entfaltet hast, kannst du jetzt für andere öffnen.'}
    body={nl2br(d.narrative_body) || 'Vielleicht hast du während Systemic Soulwork gemerkt, dass dich diese Arbeit nicht nur für dein eigenes Leben begeistert. Genau hier setzt Level 2 an. Du lernst, systemische Prozesse professionell zu begleiten und Menschen achtsam und verantwortungsvoll durch Veränderungsprozesse zu führen. Schritt für Schritt. Von der Teilnehmerin zur Coachin.'}
  />

  {/* ===================== In den drei Monaten — outcomes arc ===================== */}
  <section class="outcomes">
    <header class="outcomes__header">
      <Heading level={2} variant="h1" class="outcomes__title">{d.outcomes_title || 'In den drei Monaten tauchen wir tief in:'}</Heading>
    </header>

    {/* Desktop (≥1024px): single curve + absolutely positioned cards at ≥1072 */}
    <div class="outcomes__desktop">
      <img src="/images/ebene/process-curve.svg" alt="" class="outcomes__curve" />
      <div class="outcomes__cards">
        {outcomes.map((o, i) => (
          <article class={`outcomes__card outcomes__card--${i + 1}`}>
            <Heading level={3} class="outcomes__card-title">{o.title}</Heading>
            <Text size="p1" class="outcomes__card-body">{o.description}</Text>
          </article>
        ))}
      </div>
    </div>

    {/* Mobile/tablet (<1024px): two halves, each with its own curve + 2 cards */}
    <div class="outcomes__mobile">
      {[0, 2].map((startIdx) => (
        <div class="outcomes__mobile-section">
          <div class="outcomes__mobile-curve">
            <img
              src={startIdx === 0 ? '/images/ebene/process-curve-1.svg' : '/images/ebene/process-curve-2.svg'}
              alt=""
            />
          </div>
          <div class="outcomes__mobile-cards">
            {outcomes.slice(startIdx, startIdx + 2).map((o) => (
              <article class="outcomes__mobile-card">
                <Heading level={3} class="outcomes__card-title">{o.title}</Heading>
                <Text size="p1" class="outcomes__card-body">{o.description}</Text>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="outcomes__cta">
      <Button href={CTA_HREF} variant="primary" size="lg">{CTA_ANMELDEN}</Button>
    </div>
  </section>

  {/* ===================== Was dich nach der Ausbildung erwartet ===================== */}
  <NarrativeBlock
    tone="light"
    imageSide="left"
    image={imageUrl(d.narrative2_image) || '/images/placeholder/Placeholder-13.jpg'}
    imageAlt=""
    title={d.narrative2_title || 'Was dich nach der Ausbildung erwartet'}
    body={nl2br(d.narrative2_body) || 'Du verfügst über fundiertes systemisches Wissen, praktische Erfahrung und die Sicherheit, eigenständig zu arbeiten. Du kannst systemische Methoden in deine bestehende Tätigkeit integrieren — oder als Systemic Soulcoach selbständig damit arbeiten.'}
  />

  {/* ===================== Stimmen aus der Ausbildung ===================== */}
  <TestimonialsBlock title="Stimmen aus der Ausbildung" testimonials={reviews} tone={d.testimonials_tone || 'spring-wood'} />

  {/* ===================== Theresia Jansen — gold band, image right ===================== */}
  <section class="lehrerin">
    <div class="lehrerin__inner">
      <div class="lehrerin__content">
        <Heading variant="eyebrow" class="lehrerin__eyebrow">{d.lehrerin_eyebrow || 'Theresia Jansen'}</Heading>
        <Heading level={2} variant="h1" class="lehrerin__name">{d.lehrerin_title || 'Das Handwerk von jemandem, der es täglich lebt.'}</Heading>
        <Text size="p1" class="lehrerin__body"><Fragment set:html={nl2br(d.lehrerin_body) || 'Theresia Jansen begleitet seit über 30 Jahren Menschen in systemischer Arbeit und Heilkunde. In Level 2 gibt sie weiter, was sie selbst erprobt und verfeinert hat — kein importiertes Curriculum, sondern gelebte Praxis aus der Deutschschweiz.<br/><br/>In Level 2 begegnet dir Theresia auf eine neue Art: direkter, fordernder, auf Augenhöhe. Du bringst das Fundament mit — sie holt das Beste daraus heraus.'} /></Text>
      </div>
      <div class="lehrerin__media">
        <img src={imageUrl(d.lehrerin_image) || '/images/placeholder/placeholder-4.jpg'} alt="Theresia Jansen" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  {/* ===================== In drei Schritten zu deinem Platz ===================== */}
  <section class="steps">
    <header class="steps__header">
      <Heading level={2} variant="h1" class="steps__title">In drei Schritten zu deinem Platz</Heading>
    </header>

    {/* Tablet/Desktop (≥768px): full-bleed 3-dot curve above the columns */}
    <div class="steps__curve" aria-hidden="true">
      <img src="/images/ebene/process-curve-3.svg" alt="" loading="lazy" decoding="async" />
    </div>

    <ol class="steps__list">
      {steps.map((step) => (
        <li class="steps__item">
          <span class="steps__number">{step.number}</span>
          <Heading level={3} class="steps__item-title">{step.title}</Heading>
          <Text size="p1" class="steps__item-body">{step.description}</Text>
        </li>
      ))}
    </ol>

    <div class="steps__cta">
      <Button href={CTA_HREF} variant="primary" size="lg">{CTA_ERSTGESPRAECH}</Button>
    </div>
  </section>

  {/* ===================== Alles was du wissen musst. ===================== */}
  <section class="wissen">
    <div class="wissen__inner">
      <Heading level={2} variant="h1" class="wissen__title">Alles was du wissen musst.</Heading>
    </div>
  </section>

  <InfoCardsRow cards={infoCards} />

  <section class="wissen-foot">
    <div class="wissen-foot__inner">
      <Text size="p1" class="wissen-foot__caption">
        <Fragment set:html={d.schedule_caption || 'Die Präsenztage finden jeden Donnerstag von 16:00 bis 18:00 statt.<br />Voraussetzung: Abschluss von Level 1 — bei VitaLunaris oder einer vergleichbaren systemischen Selbsterfahrungsausbildung (Rücksprache erforderlich).'} />
      </Text>
      <div class="wissen-foot__cta">
        <Button href={CTA_HREF} variant="primary" size="lg" class="wissen-foot__btn">{CTA_ANMELDEN}</Button>
        <Button href={CTA_HREF} variant="header" size="lg" class="wissen-foot__btn">Fragen? Schreib uns.</Button>
      </div>
    </div>
  </section>

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />

  {/* ===================== Infoanlass — dark CTA with form ===================== */}
  <section class="infoanlass">
    <div class="infoanlass__card">
      <div class="infoanlass__content">
        <Heading variant="eyebrow" class="infoanlass__eyebrow">{d.infoanlass_eyebrow || 'Infoanlass'}</Heading>
        <Heading level={2} variant="h1" class="infoanlass__title"><Fragment set:html={d.infoanlass_title || 'Komm zum<br />nächsten Infoanlass.'} /></Heading>
        <Text size="p1" class="infoanlass__body">{d.infoanlass_body || 'Du möchtest mehr über die Systemic-Soulwork-Ausbildung zum Systemic Soulcoach erfahren? Beim kostenlosen Online-Infoabend via Zoom erhältst du einen ehrlichen Einblick in Inhalte, Aufbau und Arbeitsweise — und Raum für alle deine Fragen.'}</Text>
        <form class="infoanlass__form" action="#" method="POST" novalidate data-mailto-form data-recipient="info@vitalunaris.ch" data-subject="Anmeldung Infoanlass — Systemic Soulwork Level 2">
          <label for="infoanlass-email" class="infoanlass__label">E-Mail-Adresse</label>
          <input
            id="infoanlass-email"
            type="email"
            name="email"
            class="infoanlass__input"
            placeholder="E-mail Adresse"
            required
            autocomplete="email"
          />
          <button type="submit" class="infoanlass__submit">Für Infoanlass anmelden</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    function initMailtoForms() {
      document.querySelectorAll('[data-mailto-form]').forEach((form) => {
        const el = form as HTMLFormElement & { dataset: DOMStringMap };
        if (el.dataset.bound) return;
        el.dataset.bound = 'true';

        el.addEventListener('submit', (e) => {
          e.preventDefault();
          const input = el.querySelector('input[type="email"]') as HTMLInputElement | null;
          const email = input?.value.trim();
          if (!email || !input?.checkValidity()) { input?.reportValidity(); return; }

          const recipient = el.dataset.recipient || 'info@vitalunaris.ch';
          const subject = el.dataset.subject || 'Anmeldung';
          const lines = [
            'Ich möchte mich für den Infoanlass anmelden.',
            '',
            `E-Mail-Adresse: ${email}`,
          ];
          window.location.href =
            `mailto:${recipient}` +
            `?subject=${encodeURIComponent(subject)}` +
            `&body=${encodeURIComponent(lines.join('\n'))}`;
        });
      });
    }

    initMailtoForms();
    document.addEventListener('astro:page-load', initMailtoForms);
  </script>
</BaseLayout>

<style>
  /* Testimonials-Hintergrund ist jetzt im Admin wählbar (Feld „Stimmen · Hintergrund"). */
</style>

<style>
  /* ============================================================
     OUTCOMES — "In den drei Monaten tauchen wir tief ein:"
     (dome arc, 4 cards + CTA).
     Mobile/tablet (<1024): two halves with separate curves (-1, -2)
     Desktop (≥1024): single process-curve.svg
     Desktop++ (≥1072): cards + CTA absolutely positioned per Figma
     ============================================================ */
  .outcomes {
    background: var(--c-spring-wood);
    padding: 64px 8px;
    overflow: hidden;
  }
  @media (min-width: 768px)  { .outcomes { padding: 96px 8px; } }
  @media (min-width: 1024px) { .outcomes { padding: 120px 8px; } }

  .outcomes__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 12px;
    max-width: 1106px;
    margin: 0 auto;
  }
  .outcomes__title { text-align: center; color: var(--c-cherrywood); margin: 0; }

  .outcomes__card-title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }
  .outcomes__card-body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }

  .outcomes__cta {
    display: flex;
    justify-content: center;
    padding: 24px 12px 0;
  }

  .outcomes__desktop { display: none; }
  .outcomes__mobile  { display: block; margin-top: 24px; }

  @media (min-width: 1024px) {
    .outcomes__desktop { display: block; margin-top: 32px; }
    .outcomes__mobile  { display: none; }
    .outcomes__curve { display: block; width: 100%; height: auto; margin: 0; }
  }

  @media (min-width: 1024px) and (max-width: 1071.98px) {
    .outcomes__cards {
      position: relative;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      padding: 0 90px;
      margin-top: 40px;
      min-height: 0;
      box-sizing: border-box;
    }
    .outcomes__card {
      position: static;
      width: auto;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      color: var(--c-cherrywood);
    }
  }

  @media (min-width: 1072px) {
    .outcomes {
      position: relative;
      --cv: min(100vw, 1920px);
      --cx: calc((100vw - var(--cv)) / 2);
      min-height: calc(0.68177 * var(--cv));
      padding: 120px 0;
    }
    .outcomes__header { max-width: 1106px; padding: 0 12px; margin: 0 auto; }

    .outcomes__desktop {
      position: static;
      width: 100%;
      max-width: 1920px;
      margin: 32px auto 0;
    }
    .outcomes__curve { max-width: none; }
    .outcomes__cards { position: static; display: block; padding: 0; margin: 0; }

    .outcomes__card {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(16px, 2.1vw, 40px);
      color: var(--c-cherrywood);
    }
    .outcomes__card--1 { left: calc(var(--cx) + 0.05000 * var(--cv)); top: calc(0.37344 * var(--cv)); width: calc(0.20104 * var(--cv)); }
    .outcomes__card--2 { left: calc(var(--cx) + 0.27552 * var(--cv)); top: calc(0.29792 * var(--cv)); width: calc(0.20104 * var(--cv)); }
    .outcomes__card--3 { left: calc(var(--cx) + 0.50677 * var(--cv)); top: calc(0.28958 * var(--cv)); width: calc(0.20000 * var(--cv)); }
    .outcomes__card--4 { left: calc(var(--cx) + 0.73698 * var(--cv)); top: calc(0.38177 * var(--cv)); width: calc(0.20000 * var(--cv)); }

    .outcomes__card-title { font-size: clamp(24px, 2.1vw, 40px); line-height: 1.15; }
    .outcomes__card-body  { font-size: clamp(16px, 1.2vw, 23px); line-height: 1.5; }

    .outcomes__cta {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      top: calc(0.59583 * var(--cv));
      padding: 0;
      justify-content: center;
    }
  }

  .outcomes__mobile-section { margin-top: 24px; }
  .outcomes__mobile-section:first-child { margin-top: 0; }

  .outcomes__mobile-curve {
    width: auto;
    aspect-ratio: 600 / 130;
    overflow: visible;
    margin-left: -8px;
    margin-right: -8px;
    padding: 0;
    box-sizing: content-box;
  }
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .outcomes__mobile-curve { padding-top: 16px; }
  }
  .outcomes__mobile-curve img { display: block; width: 100%; height: 100%; }

  .outcomes__mobile-cards {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 16px 12px 0;
  }
  @media (min-width: 480px) and (max-width: 1023.98px) {
    .outcomes__mobile-cards {
      flex-direction: row;
      gap: 28px;
      padding: 24px 12px 0;
      align-items: flex-start;
    }
    .outcomes__mobile-cards > .outcomes__mobile-card {
      flex: 1 1 0;
      min-width: 0;
      max-width: calc(50% - 14px);
    }
  }
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .outcomes__mobile-cards { gap: 44px; padding: 32px 44px 0; }
    .outcomes__mobile-cards > .outcomes__mobile-card { max-width: calc(50% - 22px); }
  }

  .outcomes__mobile-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
    text-align: left;
    color: var(--c-cherrywood);
  }
  @media (min-width: 768px) { .outcomes__mobile-card { gap: 26.67px; } }

  /* ============================================================
     LEHRERIN — "Theresia Jansen" (Pale Gold, text left / image right)
     ============================================================ */
  .lehrerin { background: var(--c-pale-gold); padding: 60px 20px; }
  @media (min-width: 768px)  { .lehrerin { padding: 80px 32px; } }
  @media (min-width: 1280px) { .lehrerin { padding: 90px 60px; } }
  @media (min-width: 1920px) { .lehrerin { padding: 90px; } }

  .lehrerin__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) { .lehrerin__inner { flex-direction: row; align-items: center; gap: 64px; } }
  @media (min-width: 1920px) { .lehrerin__inner { gap: 100px; } }

  .lehrerin__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
