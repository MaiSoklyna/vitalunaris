---
import BaseLayout from '@layouts/BaseLayout.astro';
import CourseHero from '@organisms/CourseHero.astro';
import InfoCardsRow from '@organisms/InfoCardsRow.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import EventCard from '@molecules/EventCard.astro';
import Faq from '@organisms/Faq.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

/* ----- "Alles auf einen Blick" — Wann / Wo / Für wen ----- */
const infoCards = [
  { eyebrow: 'Wann?', body: 'Der Infoabend findet am 24.06.2026 von 18.30 bis ca. 20.00 Uhr statt.' },
  { eyebrow: 'Wo?', body: 'Online via Zoom. Den Link bekommst du nach der Anmeldung per E-Mail.' },
  { eyebrow: 'Für wen?', body: 'Für alle, die sich fragen, ob eine Ausbildung in systemischer Arbeit der nächste richtige Schritt ist.' },
];

/* ----- "Das erwartet dich" — agenda bullets ----- */
const agenda = [
  'Vorstellung von Systemic Soulwork & Systemic Soulcoach',
  'Überblick über die Ausbildungsstruktur',
  'Einblick in die Inhalte und Module',
  'Informationen zu Terminen und Investition',
  'Raum für Fragen und Austausch',
];

/* ----- "Weitere Kurse und Workshops:" — 3 event cards ----- */
const furtherCourses = [
  {
    image: '/images/placeholder/Placeholder-12.jpg', 
    eyebrow: 'MONATS-WORKSHOP | SEPTEMBER | 14.09.2026',
    title: 'SoulTap Einführungskurs',
    description: 'Im September lädt dich Theresia Jansen zu einem besonderen Monats-Workshop ein: EFT-Meridian-Klopfen – eine einfache und gleichzeitig wirkungsvolle Methode für mehr innere Ruhe, Sicherheit und Vertrauen.',
    price: 'CHF 66.–',
    duration: '120 Min. | Online',
    ctaHref: '/workshops-kurse/soultap-gegen-angst',
  },
  {
    image: '/images/placeholder/Placeholder-29.jpg',
    eyebrow: 'MONATS-WORKSHOP | OKTOBER | 22.10.2026',
    title: 'Im Vagusnerv liegt die Ruhe',
    description: 'Der Vagusnerv verstehen und aktivieren – unser Monats-Workshop im Oktober lädt dich ein, deinen Körper dabei zu verstehen und mit einfachen Werkzeug mehr Ruhe und Gelassenheit in deinen Alltag zu bringen.',
    price: 'CHF 66.–',
    duration: '210 Min. | Online',
    ctaHref: '/workshops-kurse/vagusnerv-ruhe',
  },
  {
    image: '/images/placeholder/Placeholder-32.jpg',
    eyebrow: 'MONATS-WORKSHOP | DEZEMBER | 01.12.2026',
    title: 'Adventsgeschichten für Herz und Seele',
    description: 'Eine besinnliche Reise durch die Adventszeit – Geschichten, kleine Rituale und Momente der Stille, die dein Herz wärmen und dir mitten im Trubel innere Ruhe schenken.',
    price: 'CHF 66.–',
    duration: '210 Min. | Online',
    ctaHref: '/workshops-kurse/adventsgeschichten',
  },
];

/* ----- FAQ — first 4 fill the left column, next 4 the right ----- */
const faqItems = [
  { question: 'Für wen sind die Workshops geeignet?', answer: 'Für alle, die systemische Arbeit erleben möchten — ob als Einstieg, zur Vertiefung oder einfach aus Neugier. Vorwissen ist nicht nötig.' },
  { question: 'Was ist der Unterschied zwischen einem Workshop und der Ausbildung?', answer: 'Ein Workshop ist ein einzelnes, in sich geschlossenes Erlebnis. Die Ausbildung ist ein aufeinander aufbauender, längerer Weg mit Abschluss.' },
  { question: 'Brauche ich Vorkenntnisse für die Monats-Workshops?', answer: 'Nein. Die Workshops sind so gestaltet, dass du jederzeit einsteigen kannst — mit oder ohne Vorerfahrung.' },
  { question: 'Wie melde ich mich an?', answer: 'Du klickst auf «Jetzt anmelden», füllst das kurze Formular aus und erhältst alle Infos sowie den Zoom-Link per E-Mail.' },
  { question: 'Werden die Kosten von der Krankenkasse übernommen?', answer: 'Der Infoabend ist kostenlos. Workshops sind in der Regel keine kassenpflichtige Leistung — manche Zusatzversicherungen unterstützen Bildungsangebote, frag im Einzelfall nach.' },
  { question: 'Kann ich einen Workshop stornieren?', answer: 'Ja, bis zu einer bestimmten Frist vor Beginn. Die genauen Bedingungen findest du in der Anmeldebestätigung.' },
  { question: 'Gibt es auch Online-Formate?', answer: 'Ja. Der Infoabend und unsere Workshops finden online via Zoom statt — den Link bekommst du nach der Anmeldung per E-Mail.' },
  { question: 'Was passiert wenn ein Workshop ausgebucht ist?', answer: 'Du kannst dich auf die Warteliste setzen. Wird ein Platz frei oder kommt ein Zusatztermin, informieren wir dich zuerst.' },
];
---

<BaseLayout
  title="Systemic Soulcoach Infoabend | VitaLunaris"
  description="Kostenloser Online-Infoabend zur Ausbildung Systemic Soulcoach — ehrlicher Einblick in Inhalte, Aufbau und Arbeitsweise, mit Raum für alle deine Fragen."
  currentPath="/ausbildung/infoanlaesse"
>
  <CourseHero
    categoryMeta="AUSBILDUNG | INFOABEND | 24.06.2026"
    title="Systemic Soulcoach <br /> Infoabend"
    description="Du möchtest mehr über die Systemic Soulwork Ausbildung zum Systemic Soulcoach erfahren? Beim kostenlosen Online-Infoabend via Zoom erhältst du einen ehrlichen Einblick in Inhalte, Aufbau und Arbeitsweise — und Raum für alle deine Fragen."
    durationMeta="24.06.2026 | 18.30 bis ca. 20.00 Uhr | Online"
    price="Kostenlos :)"
    ctaText="Jetzt anmelden"
    ctaHref="#anmelden"
    image="/images/placeholder/Placeholder-12.jpg"
  />

  <InfoCardsRow cards={infoCards} />

  {/* ===================== Das erwartet dich — lavender, image left ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image="/images/placeholder/Placeholder-33.jpg"
    imageAlt=""
    eyebrow="Was wir anschauen"
    title="Das erwartet dich"
    bullets={agenda}
    body="Der Online-Infoabend ist kostenlos und unverbindlich. Ich freue mich darauf, dich kennenzulernen."
  />

  {/* ===================== Anmeldung — Alchemy form ===================== */}
  <section class="info-anmeldung" id="anmelden">
    <div class="info-anmeldung__inner">
      <div class="info-anmeldung__head">
        <Heading variant="eyebrow" class="info-anmeldung__eyebrow">Anmeldung</Heading>
        <Heading level={2} variant="h1" class="info-anmeldung__title">Zum Infoabend anmelden</Heading>
        <Text size="p1" class="info-anmeldung__intro">
          Kostenlos und unverbindlich. Trag dich ein — du erhältst den Zoom-Link rechtzeitig per E-Mail.
        </Text>
      </div>
      <div class="info-anmeldung__frame-wrap">
        <iframe
          class="info-anmeldung__frame"
          src="https://opus.alchemy.zuerich/api/f/gNZatXNfROlxM1luEKAz5w/page"
          title="Anmeldung Infoabend"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  {/* ===================== Theresia & Axel Jansen — light, image right ===================== */}
  <section class="about">
    <div class="about__inner">
      <div class="about__content">
        <Heading level={2} variant="h1" class="about__name">Theresia &<br /><em>Axel Jansen</em></Heading>
        <Text size="p1" class="about__body">
          Theresia Jansen begleitet seit über 30 Jahren Menschen zu mehr Klarheit und Veränderung – gestützt auf umfangreiche Ausbildungen und jahrzehntelange Praxiserfahrung. Axel Jansen bringt Hypnose, Numerologie und einen präzisen Blick für Zusammenhänge ein – humorvoll und geerdet.
        </Text>
        <Text size="p1" class="about__body">
          Als Ehepaar und Team ergänzen sich ihre Stärken auf natürliche Weise. Was sie verbindet: die Überzeugung, dass Veränderung dort beginnt, wo Menschen sich gesehen und sicher fühlen. So entstehen Räume für Erkenntnis und neue Perspektiven – ehrlich, menschlich, mit echter Lebenserfahrung.
        </Text>
        <div class="about__cta">
          <Button href="/ueber-uns" variant="primary" size="lg">Mehr über uns</Button>
        </div>
      </div>
      <div class="about__media">
        <img src="/images/placeholder/placeholder-4.jpg" alt="Theresia & Axel Jansen" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  {/* ===================== Weitere Kurse und Workshops — dark ===================== */}
  <section class="further">
    <div class="further__inner">
      <Heading level={2} variant="h1" class="further__title">Weitere Kurse und Workshops:</Heading>
      <div class="further__grid">
        {furtherCourses.map((e) => <EventCard {...e} />)}
      </div>
    </div>
  </section>

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />
</BaseLayout>

<style>
  /* Info cards — body text in full black per design */
  :global(.info-cards .info-cards__body) {
    color: #000000;
  }

  /* ===================== Anmeldung — Alchemy form (iframe, Scribe auto-resizes) ===================== */
  .info-anmeldung { background: var(--c-spring-wood); padding: 60px 20px; scroll-margin-top: 100px; }
  @media (min-width: 768px)  { .info-anmeldung { padding: 80px 32px; } }
  @media (min-width: 1280px) { .info-anmeldung { padding: 90px 60px; } }

  .info-anmeldung__inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .info-anmeldung__head { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .info-anmeldung__eyebrow { color: var(--c-cherrywood); }
  .info-anmeldung__title {
    font-family: 'ES Park', serif; color: var(--c-cherrywood); font-weight: var(--weight-regular);
    font-size: var(--h2-size); line-height: 1.1; margin: 0;
  }
  .info-anmeldung__intro {
    font-family: 'ES Park', serif; color: var(--c-cherrywood); font-size: var(--p1-size);
    line-height: 1.5; max-width: 52ch; margin: 0;
  }
  .info-anmeldung__frame-wrap { width: 100%; }
  .info-anmeldung__frame {
    width: 100%;
    height: 760px;          /* sensible default before Scribe sizes it to the form */
    min-height: 520px;
    border: 0;
    display: block;
    transition: height 200ms ease;
  }

  /* ============================================================
     ABOUT — "Theresia & Axel Jansen" (Spring Wood, text left / image right)
     ============================================================ */
  .about { background: var(--c-spring-wood); padding: 60px 20px; }
  @media (min-width: 768px)  { .about { padding: 80px 32px; } }
  @media (min-width: 1280px) { .about { padding: 90px 60px; } }
  @media (min-width: 1920px) { .about { padding: 90px; } }

  .about__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) { .about__inner { flex-direction: row; align-items: center; gap: 64px; } }
  @media (min-width: 1920px) { .about__inner { gap: 100px; } }

  .about__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: 16.67px;
    background: rgba(96, 29, 29, 0.06);
    aspect-ratio: 4 / 5;
    order: -1;
  }
  @media (min-width: 1024px) { .about__media { width: 46%; border-radius: 20px; order: 0; } }
  @media (min-width: 1920px) { .about__media { width: 711px; border-radius: 25px; aspect-ratio: 711 / 826; } }
  .about__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .about__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
  }
  @media (min-width: 1024px) { .about__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .about__content { gap: 32px; max-width: 813px; } }

  .about__name {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .about__name :global(em) { font-style: italic; }
  .about__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }
  .about__cta { margin-top: 8px; }

  /* ============================================================
     FURTHER — "Weitere Kurse und Workshops:" (Cherrywood, 3 cards)
     ============================================================ */
  .further { background: var(--c-cherrywood); padding: 60px 20px; }
  @media (min-width: 768px)  { .further { padding: 80px 32px; } }
  @media (min-width: 1280px) { .further { padding: 90px 60px; } }
  @media (min-width: 1920px) { .further { padding: 120px 90px; } }

  .further__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1920px) { .further__inner { gap: 64px; } }

  .further__title {
    color: var(--c-spring-wood);
    text-align: center;
    margin: 0;
    max-width: 862px;
  }

  .further__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    width: 100%;
  }
  @media (min-width: 640px)  { .further__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .further__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
</style>
