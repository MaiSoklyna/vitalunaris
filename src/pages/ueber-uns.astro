---
import BaseLayout from '@layouts/BaseLayout.astro';
import AboutHero from '@organisms/AboutHero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import PersonBio from '@organisms/PersonBio.astro';
import ValueCardsBlock from '@organisms/ValueCardsBlock.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';
import { getEmDashEntry } from 'emdash';
import { jsonArray, nl2br, imageUrl } from '@lib/cms';

// Bespoke block page — editable at /_emdash/admin/content/pages (slug "ueber-uns").
const { entry } = await getEmDashEntry('pages', 'ueber-uns');
const d: Record<string, any> = entry?.data ?? {};
const sec = (t: string): Record<string, any> => (d.sections ?? []).find((s: any) => s.type === t) ?? {};
const heroS = sec('hero'), intro = sec('intro'), valuesS = sec('values'), quote = sec('quote'), nlx = sec('newsletter');
const heroParagraphs = jsonArray(heroS.items).length ? jsonArray(heroS.items) : [
  'VitaLunaris ist mehr als eine Praxis. Es ist ein Ort, an dem systemisches Wissen, intuitive Wahrnehmung und jahrzehntelange Erfahrung zusammenkommen.',
  'Gegründet von Theresia und Axel Jansen. Verwurzelt in der Deutschschweiz. Entstanden aus der Leidenschaft, Menschen auf ihrem Weg zu mehr Klarheit, Verständnis und Veränderung zu begleiten.',
  'Für alle, die nicht nur auf Symptome schauen, sondern tiefer verstehen möchten, was hinter Herausforderungen, Beziehungen und Lebenswegen wirkt.',
];

const team = jsonArray(sec('team').items).length ? jsonArray(sec('team').items) : [
  {
    eyebrow: 'Gründerin · VitaLunaris',
    name: 'Theresia Jansen',
    role: 'Systemisches Aufstellen · Anerkannte Therapeutin<br />Autogenes Training Nr. ZSR O 256662',
    image: '/images/placeholder/placeholder-30.jpg', 
    imageSide: 'left' as const,
    paragraphs: [
      'Persönliche Erfahrungen — Verlust, Kinderwunsch, Herausforderungen — haben meinen Blick auf das Leben geprägt und meine Neugier für die Fragen geweckt, die uns Menschen wirklich bewegen.',
      'Mein Weg führte von kaufmännischen Berufen über die Heilkunde bis zur systemischen Aufstellungsarbeit — dem grössten Wendepunkt meines Lebens. Seit über zwanzig Jahren begleite ich Menschen, halte geschützte Räume und gebe mein Wissen in Aufstellungen, EFT und Ausbildungen weiter.',
      'Mehr Verständnis. Mehr Klarheit. Mehr Bewusstsein für die Zusammenhänge, die unser Leben prägen.',
    ],
  },
  {
    eyebrow: 'Gründer · VitaLunaris',
    name: 'Axel Jansen',
    role: 'Hypnose · Numerologie · Energiearbeit',
    image: '/images/persons/AxelJansen.jpg', 
    imageSide: 'right' as const,
    paragraphs: [
      'Schon früh faszinierte mich, dass hinter den sichtbaren Dingen oft tiefere Muster wirken. Diese Neugier hat mich nie losgelassen — sie ist bis heute der Antrieb hinter meiner Arbeit.',
      'Mein Weg führte über viele Stationen hin zur Hypnose und Numerologie. Heute verbinde ich beides mit systemischem Denken und Energiearbeit zu einer Begleitung, die Verstand und Unterbewusstsein zusammenbringt.',
      'Mehr Klarheit. Neue Perspektiven. Und Zugänge, die im Alltag tatsächlich tragen.',
    ],
  },
  {
    eyebrow: 'Team · VitaLunaris',
    name: 'Marlen Berger',
    role: 'Fussreflexzonen · Körperarbeit',
    image: '/images/persons/MarlenBerger.jpg', 
    imageSide: 'left' as const,
    paragraphs: [
      'Mein Weg begann in der Küche. Als ausgebildete Diätköchin arbeitete ich viele Jahre in Spitälern und Kliniken — immer mit dem Blick darauf, was Menschen wirklich nährt und in Balance bringt.',
      'Über die Fussreflexzonenarbeit fand ich zu einer Methode, die spürbar in die Tiefe geht. Heute arbeite ich präzise, intuitiv und nach den Prinzipien der TCM — für Entlastung auf körperlicher und emotionaler Ebene.',
    ],
  },
];

// Per-person uploadable team photos (override the photo in the team list when set).
const teamImages = [d.team_image_1, d.team_image_2, d.team_image_3];

const values = jsonArray(valuesS.items).length ? jsonArray(valuesS.items) : [
  {
    icon: '/images/ebene/Ebene-14.svg',
    title: 'Tiefe statt<br />Oberfläche',
    body: 'Wir arbeiten nicht nur an Symptomen — wir schauen auf die Zusammenhänge dahinter. Was sich wiederholt, hat Wurzeln. Diese Wurzel zu erkennen und zu verstehen, ist oft der erste Schritt für echte Veränderung.',
  },
  {
    icon: '/images/ebene/Ebene_2.svg',
    title: 'Erfahrung statt<br />Theorie',
    body: 'Was wir weitergeben, haben wir selbst erlebt und hinterfragt — kein Wissen aus zweiter Hand, sondern gewachsen durch Ausbildungen, Erfahrungen und die Begleitung von Menschen. Im Mittelpunkt stehen nicht Methoden, sondern Menschen und ihre individuellen Wege.',
  },
  {
    icon: '/images/ebene/Ebene_2-8.svg',
    title: 'Der Mensch als<br />Ganzes',
    body: 'Körper, Geist, Lebensgeschichte und System lassen sich nicht voneinander trennen. Deshalb vereint VitaLunaris verschiedene Zugänge, die den Menschen in seiner Ganzheit betrachten — mit Respekt für das, was war, und Vertrauen in das, was entstehen darf.',
  },
];
---

<BaseLayout
  title="Über uns | VitaLunaris"
  description="VitaLunaris ist ein Ort, an dem systemisches Wissen, intuitive Wahrnehmung und jahrzehntelange Erfahrung zusammenkommen. Lerne Theresia, Axel und Marlen kennen."
  currentPath="/ueber-uns"
>
  {/* ===================== Hero ===================== */}
  <AboutHero
    eyebrow={heroS.eyebrow || 'Über uns'}
    title={heroS.title || `Wo Wissen auf<br />Erfahrung trifft.`}
    paragraphs={heroParagraphs}
    image={imageUrl(heroS.image) || '/images/placeholder/placeholder-4.jpg'}
    imageAlt="Theresia & Axel Jansen"
    imageSide="right"
  />

  {/* ===================== Intro — über 30 Jahre Erfahrung ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image={imageUrl(intro.image) || '/images/placeholder/Placeholder-29.jpg'}
    imageAlt=""
    title={intro.title || 'Über 30 Jahre Erfahrung. Eine klare Haltung.'}
    body={nl2br(intro.body) || 'VitaLunaris steht für Arbeit, die in die Tiefe geht. Nicht als Methode um der Methode willen, sondern als Begegnung, die etwas in Bewegung bringt.<br /><br />Über Jahre haben Theresia und Axel Jansen einen Ort geschaffen, an dem Menschen und ihre Geschichten bestehen dürfen. Systemisches Aufstellen, Hypnose und Numerologie sind dabei keine Gegensätze, sondern verschiedene Zugänge zu demselben Ziel:<br /><br />Mehr Verständnis. Mehr Klarheit. Mehr Bewusstsein für die Zusammenhänge, die unser Leben prägen.'}
  />

  {/* ===================== Team bios ===================== */}
  {team.map((person, i) => (
    <PersonBio
      eyebrow={person.eyebrow}
      name={person.name}
      role={person.role}
      paragraphs={person.paragraphs}
      image={imageUrl(teamImages[i]) || imageUrl(person.image)}
      imageAlt={person.name}
      imageSide={person.imageSide}
    />
  ))}

  {/* ===================== Was uns antreibt ===================== */}
  <ValueCardsBlock title={valuesS.title || 'Was uns antreibt'} cards={values} />

  {/* ===================== Founders' quote ===================== */}
  <NarrativeBlock
    tone="gold"
    imageSide="right"
    image={imageUrl(quote.image) || '/images/placeholder/Placeholder-5.jpg'}
    imageAlt="Theresia & Axel Jansen im Gespräch"
    title={quote.title || `„Veränderung beginnt nicht dort, wo wir uns bekämpfen, sondern dort, wo wir beginnen zu verstehen. Denn was sichtbar wird, kann sich verändern. Und was verstanden wird, verliert oft seine Schwere.“`}
    attribution={quote.body || 'Theresia & Axel Jansen · VitaLunaris'}
  />

  {/* ===================== Newsletter ===================== */}
  <NewsletterBlock
    eyebrow="Newsletter"
    title={nlx.title || 'Unsere Gedanken<br />passen nicht alle auf<br />eine Webseite.'}
    body={nlx.body || 'Deshalb schreiben wir jede Woche einen Newsletter. Mit Geschichten, Inspirationen, Axels Zahlenmagie, Einblicken aus unserem Alltag und Gedanken über das Leben, die Menschen und die Zusammenhänge, die uns bewegen.'}
    placeholder="E-mail Adresse"
    submitText="Kostenlos anmelden"
  />
</BaseLayout>
