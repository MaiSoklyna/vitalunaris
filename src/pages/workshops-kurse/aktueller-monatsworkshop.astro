---
import BaseLayout from '@layouts/BaseLayout.astro';
import CourseHero from '@organisms/CourseHero.astro';
import InfoCardsRow from '@organisms/InfoCardsRow.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import EventCard from '@molecules/EventCard.astro';
import Faq from '@organisms/Faq.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';
import { getEmDashEntry, getEmDashCollection } from 'emdash';
import { jsonArray, nl2br, imageUrl, getTestimonials } from '@lib/cms';

// Editable at /_emdash/admin/content/workshops (entry "aktueller-monatsworkshop").
// "Current month's workshop" — defaults to featuring the next workshop; edit each month in the admin.
const { entry } = await getEmDashEntry('workshops', 'aktueller-monatsworkshop');
const d: Record<string, any> = entry?.data ?? {};
const sec = (t: string): Record<string, any> => (d.sections ?? []).find((s: any) => s.type === t) ?? {};
const heroS = sec('hero'), nar = sec('narrative'), about = sec('about');

const infoCards = d.info_cards?.length ? d.info_cards : [
  { eyebrow: 'Wann?', body: 'Der Kurs findet am 14.09.2026 von 13:30 bis 16:00 Uhr statt (ca. 2 h).' },
  { eyebrow: 'Wo?', body: 'Online via Zoom. Den Link bekommst du nach der Anmeldung per E-Mail.' },
  { eyebrow: 'Für wen?', body: 'Für Menschen, die neugierig sind, erste Erfahrungen mit systemischer Arbeit machen möchten und spüren, dass sich etwas bewegen will.' },
];

// Real, attributed workshop reviews (the previous "Maria S." Lorem testimonials were fabricated).
const _ts = await getTestimonials('workshop-aktueller');
const testimonials = _ts.length ? _ts : [
  { quote: '„Anfangs war ich neugierig – am Ende begeistert. Plötzlich ergaben viele Verhaltensweisen viel mehr Sinn. Voller Aha-Momente und ein neuer Blick auf Menschen.“', name: 'Marianne S.' },
  { quote: '„Der Workshop war klar strukturiert, verständlich und mit viel Herz gestaltet. Besonders das liebevoll gestaltete Workbook hat mich begeistert. Vielen Dank für diesen inspirierenden Tag!“', name: 'Marina C.' },
  { quote: '„Ich bin noch immer erstaunt, wie viel Kraft hinter dieser einfachen Klopftechnik steckt. Ein Werkzeug, das ich jederzeit anwenden kann. Herzlichen Dank für diesen praxisnahen Kurs!“', name: 'Sandra M.' },
  { quote: '„Die Atemübungen und das Tapping helfen mir konkret, wenn Druck entsteht. Ich merke, dass ich im Familienalltag ruhiger bin. Viele praktische Werkzeuge, die sich leicht umsetzen lassen.“', name: 'Desiree Z.' },
];

const faqItems = d.faq_items?.length ? d.faq_items : [
  { question: 'Für wen sind die Workshops geeignet?', answer: 'Für alle, die systemische Arbeit erleben möchten — ob als Einstieg, zur Vertiefung oder einfach aus Neugier. Vorwissen ist nicht nötig.' },
  { question: 'Was ist der Unterschied zwischen einem Workshop und der Ausbildung?', answer: 'Ein Workshop ist ein einzelnes, in sich geschlossenes Erlebnis. Die Ausbildung ist ein aufeinander aufbauender, längerer Weg mit Abschluss.' },
  { question: 'Brauche ich Vorkenntnisse für den Kurs?', answer: 'Nein. Der Kurs ist so gestaltet, dass du jederzeit einsteigen kannst — mit oder ohne Vorerfahrung.' },
  { question: 'Wie melde ich mich an?', answer: 'Du klickst auf «Jetzt anmelden», füllst das kurze Formular aus und erhältst alle Infos sowie den Zoom-Link per E-Mail.' },
  { question: 'Werden die Kosten von der Krankenkasse übernommen?', answer: 'Workshops sind in der Regel keine kassenpflichtige Leistung. Manche Zusatzversicherungen unterstützen Bildungsangebote — frag im Einzelfall nach.' },
  { question: 'Kann ich einen Workshop stornieren?', answer: 'Ja, bis zu einer bestimmten Frist vor Beginn. Die genauen Bedingungen findest du in der Anmeldebestätigung.' },
  { question: 'Gibt es auch Online-Formate?', answer: 'Ja. Dieser Kurs findet online via Zoom statt — den Link bekommst du nach der Anmeldung per E-Mail.' },
  { question: 'Was passiert wenn ein Workshop ausgebucht ist?', answer: 'Du kannst dich auf die Warteliste setzen. Wird ein Platz frei oder kommt ein Zusatztermin, informieren wir dich zuerst.' },
];

// "Weitere Kurse" pulled from the editable workshops collection.
const { entries: allWs } = await getEmDashCollection('workshops', { orderBy: { date: 'asc' } });
// Only real, dated workshops — skip the two overview pages (they live in this
// collection with no date and would otherwise render as empty cards).
const furtherCourses = (allWs ?? []).filter((e: any) => e.data?.date).slice(0, 3).map((e: any) => ({
  image: imageUrl(e.data?.card_image),
  eyebrow: e.data?.card_eyebrow,
  title: e.data?.card_title,
  description: e.data?.card_description,
  price: e.data?.hero_price,
  duration: e.data?.card_duration,
  ctaText: 'Mehr erfahren',
  ctaHref: `/workshops-kurse/${e.id}`,
}));

const aboutParas = (d.about_paragraphs?.length ? d.about_paragraphs.map((p: any) => p.text) : [
  'Theresia Jansen begleitet seit über 30 Jahren Menschen in systemischer Arbeit und Heilkunde. In ihren Workshops verbindet sie Aufstellungen, EFT, Nervensystem-Arbeit und Heilkunde zu einem Erfahrungsraum, der seinesgleichen sucht.',
  'Axel Jansen bringt Hypnose und Numerologie in Workshops ein, die gleichermassen präzise wie zugänglich sind. Zahlenmagie ohne Kitsch, Hypnose ohne Bühnentricks. Zusammen bieten Theres und Axel ein Spektrum, das in dieser Form in der Deutschschweiz einzigartig ist.',
]) as string[];
---

<BaseLayout
  title={d.seo_title || 'Aktueller Monatsworkshop | VitaLunaris'}
  description={d.seo_description || 'Aktueller Monatsworkshop — Termine, Details und Anmeldung.'}
  currentPath="/workshops-kurse/aktueller-monatsworkshop"
>
  <CourseHero
    categoryMeta={heroS.category_meta || 'MONATS-WORKSHOP | SEPTEMBER | 14.09.2026'}
    durationMeta={heroS.duration_meta || '14.09.2026 · 13:30 Uhr · 120 Min. · Online'}
    title={heroS.title || 'SoulTap gegen<br />deine Angst'}
    description={heroS.description || 'EFT-Meridian-Klopfen – eine einfache und gleichzeitig wirkungsvolle Methode für mehr innere Ruhe, Sicherheit und Vertrauen. Ein Werkzeug, das du sofort anwenden kannst und das dich noch viele Jahre begleiten wird.'}
    price={heroS.price || 'CHF 66.–'}
    ctaText={heroS.cta_text || 'Jetzt anmelden'}
    ctaHref={heroS.cta_href || '/kontakt'}
    image={imageUrl(heroS.image) || '/images/placeholder/Placeholder-34.jpg'}
  />

  <InfoCardsRow cards={infoCards} />

  {/* ===================== Was wir anschauen — lavender ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image={imageUrl(nar.image) || '/images/placeholder/Placeholder-35.jpg'}
    imageAlt=""
    eyebrow={nar.eyebrow || 'Was wir anschauen'}
    title={nar.title || 'Die Angst hinter der Angst'}
    body={nl2br(nar.body) || 'Oft steckt hinter einer Angst noch etwas ganz anderes: die Angst, nicht zu genügen. Die Angst vor Ablehnung oder Veränderung.<br/><br/>Genau dort setzt SoulTap an — mit EFT, einem der einfachsten und gleichzeitig wirkungsvollsten Werkzeuge zur Selbsthilfe. Durch das sanfte Beklopfen von Meridianpunkten können Stress, Ängste und emotionale Belastungen oft erstaunlich schnell reduziert werden.'}
  />

  {/* ===================== Was Menschen zu unseren Kursen sagen ===================== */}
  <TestimonialsBlock
    title="Was Menschen zu unseren Kursen sagen"
    testimonials={testimonials}
    tone={d.testimonials_tone || 'gold'}
  />

  {/* ===================== Theresia & Axel Jansen — gold ===================== */}
  <section class="about">
    <div class="about__inner">
      <div class="about__content">
        <Heading level={2} variant="h1" class="about__name"><Fragment set:html={about.title || 'Theresia &<br /><em>Axel Jansen</em>'} /></Heading>
        {aboutParas.map((p: string) => (
          <Text size="p1" class="about__body"><Fragment set:html={p} /></Text>
        ))}
        <div class="about__cta">
          <Button href="/ueber-uns" variant="primary" size="lg">Mehr über uns</Button>
        </div>
      </div>
      <div class="about__media">
        <img src={imageUrl(about.image) || '/images/placeholder/placeholder-4.jpg'} alt="Theresia & Axel Jansen" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  {/* ===================== Weitere Kurse und Workshops — dark ===================== */}
  <section class="further">
    <div class="further__inner">
      <Heading level={2} variant="h1" class="further__title">Weitere Kurse und Workshops:</Heading>
      <div class="further__grid">
        {furtherCourses.map((e) => <EventCard {...e} />)}
      </div>
    </div>
  </section>

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />
</BaseLayout>

<style>
  /* ============================================================
     ABOUT — "Theresia & Axel Jansen" (Pale Gold, text left / image right)
     ============================================================ */
  .about { background: var(--c-spring-wood); padding: 60px 20px; }
  @media (min-width: 768px)  { .about { padding: 80px 32px; } }
  @media (min-width: 1280px) { .about { padding: 90px 60px; } }
  @media (min-width: 1920px) { .about { padding: 90px; } }

  .about__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) { .about__inner { flex-direction: row; align-items: center; gap: 64px; } }
  @media (min-width: 1920px) { .about__inner { gap: 100px; } }

  .about__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-card-sm);
    background: rgba(96, 29, 29, 0.06);
    aspect-ratio: 4 / 5;
    order: -1;
  }
  @media (min-width: 1024px) { .about__media { width: 46%; border-radius: var(--radius-card); order: 0; } }
  @media (min-width: 1920px) { .about__media { width: 711px; border-radius: var(--radius-card-lg); aspect-ratio: 711 / 826; } }
  .about__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .about__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
  }
  @media (min-width: 1024px) { .about__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .about__content { gap: 32px; max-width: 813px; } }

  .about__name {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .about__name :global(em) { font-style: italic; }
  .about__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }
  .about__cta { margin-top: 8px; }

  /* ============================================================
     FURTHER — "Weitere Kurse und Workshops:" (Cherrywood, 3 cards)
     ============================================================ */
  .further { background: var(--c-cherrywood); padding: 60px 20px; }
  @media (min-width: 768px)  { .further { padding: 80px 32px; } }
  @media (min-width: 1280px) { .further { padding: 90px 60px; } }
  @media (min-width: 1920px) { .further { padding: 120px 90px; } }

  .further__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1920px) { .further__inner { gap: 64px; } }

  .further__title {
    color: var(--c-spring-wood);
    text-align: center;
    margin: 0;
    max-width: 862px;
  }

  .further__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    width: 100%;
  }
  @media (min-width: 640px)  { .further__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .further__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
</style>
