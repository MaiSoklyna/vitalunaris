---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  placeholder?: string;
  submitText?: string;
  action?: string;
  /** Inbox the signup is sent to (opens the visitor's mail client). */
  recipient?: string;
  privacyText?: string;
}

const {
  eyebrow,
  title,
  body,
  privacyText,
} = Astro.props;

/* Single Alchemy Labs newsletter form for the whole site. Submitting writes
   the lead into Alchemy (replaces the old mailto). Scribe (loaded in
   BaseLayout) auto-resizes the iframe to the form's height. */
const FORM_EMBED = 'UuYncQmBeBO5V0a5rByUZw';
const formSrc = `https://opus.alchemy.zuerich/api/f/${FORM_EMBED}/page`;
---

<section class="newsletter">
  <div class="newsletter__card max-w-layout">
    <img
      src="/images/ebene/Ebene_1 (4).svg"
      alt=""
      aria-hidden="true"
      class="newsletter__decor newsletter__decor--tl"
    />
    <img
      src="/images/ebene/Ebene_1 (6).svg"
      alt=""
      aria-hidden="true"
      class="newsletter__decor newsletter__decor--br"
    />

    <div class="newsletter__content">
      {eyebrow && <Heading variant="eyebrow" class="newsletter__eyebrow">{eyebrow}</Heading>}
      <Heading level={2} variant="h1" class="newsletter__title">
        <Fragment set:html={title} />
      </Heading>
      {body && <Text size="p1" class="newsletter__body"><Fragment set:html={body} /></Text>}

      <div class="newsletter__form-wrap">
        <iframe
          class="newsletter__frame"
          src={formSrc}
          title="Newsletter-Anmeldung"
          loading="lazy"
        ></iframe>
      </div>

      {privacyText && <Text size="p3" class="newsletter__privacy">{privacyText}</Text>}
    </div>
  </div>
</section>

<style>
  .newsletter {
    background: var(--c-spring-wood);
    padding: 40px 20px;
  }
  @media (min-width: 768px) { .newsletter { padding: 64px 32px; } }
  @media (min-width: 1280px) { .newsletter { padding: 90px 60px; } }

  .newsletter__card {
    position: relative;
    overflow: hidden;
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    border-radius: 25px;
    padding: 80px 24px;
    min-height: 480px;
    width: 100%;
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (min-width: 768px) { .newsletter__card { padding: 120px 48px; min-height: 640px; } }
  @media (min-width: 1280px) { .newsletter__card { padding: 180px 60px; min-height: 901px; } }

  .newsletter__decor {
    position: absolute;
    pointer-events: none;
    user-select: none;
    height: auto;
    opacity: 1;
  }

  /* Figma: 935 × 634 at left -297, top -95.5 inside a 1740 × 901 card */
  .newsletter__decor--tl {
    width: 53.74%;
    top: -10.6%;
    left: -17.07%;
  }

  /* Figma: 865 × 577 at left 1084, top 513.5 inside a 1740 × 901 card */
  .newsletter__decor--br {
    width: 49.71%;
    bottom: -21.03%;
    right: -12.01%;
  }

  /* The corner flourishes are sized/placed for the wide desktop card; on the
     tall narrow mobile card they bleed in as clipped fragments. Hide them. */
  @media (max-width: 767.98px) {
    .newsletter__decor { display: none; }
  }

  .newsletter__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    max-width: 856px;
    width: 100%;
  }
  @media (min-width: 1024px) { .newsletter__content { gap: 40px; } }

  .newsletter__eyebrow { color: var(--c-cherrywood); opacity: 0.8; }

  .newsletter__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .newsletter__body {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    max-width: 720px;
    text-align: center;
  }

  /* Alchemy newsletter form (iframed hosted page; Scribe auto-resizes height).
     Form background is spring-wood, so it blends into the card seamlessly. */
  .newsletter__form-wrap {
    width: 100%;
    max-width: 706px;
  }
  .newsletter__frame {
    width: 100%;
    height: 220px;          /* sensible default before Scribe sizes it */
    min-height: 180px;
    border: 0;
    display: block;
    transition: height 200ms ease;
  }

  .newsletter__privacy { color: var(--c-cherrywood); opacity: 0.6; margin-top: 4px; }
</style>
