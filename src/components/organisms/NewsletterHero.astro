---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

interface Props {
  /** Optional brand symbol shown centered above the eyebrow. */
  logo?: string;
  eyebrow?: string;
  title: string;
  /** One or more centered intro paragraphs. */
  paragraphs?: string[];
  placeholder?: string;
  submitText?: string;
  action?: string;
  /** Inbox the signup is sent to (opens the visitor's mail client). */
  recipient?: string;
}

const {
  logo,
  eyebrow,
  title,
  paragraphs = [],
} = Astro.props;

/* Same Alchemy Labs newsletter form as NewsletterBlock (leads land in
   Alchemy; Scribe auto-resizes the iframe). */
const FORM_EMBED = 'UuYncQmBeBO5V0a5rByUZw';
const formSrc = `https://opus.alchemy.zuerich/api/f/${FORM_EMBED}/page`;
---

<section class="news-hero">
  <div class="news-hero__inner">
    {logo && <img src={logo} alt="" aria-hidden="true" class="news-hero__logo" />}
    {eyebrow && <Heading variant="eyebrow" class="news-hero__eyebrow">{eyebrow}</Heading>}

    <Heading level={1} class="news-hero__title">
      <Fragment set:html={title} />
    </Heading>

    {paragraphs.length > 0 && (
      <div class="news-hero__copy">
        {paragraphs.map((p) => (
          <Text size="p1" class="news-hero__body"><Fragment set:html={p} /></Text>
        ))}
      </div>
    )}

    <div class="news-hero__form-wrap">
      <iframe
        class="news-hero__frame"
        src={formSrc}
        title="Newsletter-Anmeldung"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     NEWS HERO — centered newsletter signup on Spring Wood.
     Logo → eyebrow → H1 → intro paragraphs → email + submit.
     ============================================================ */
  .news-hero {
    background: var(--c-spring-wood);
    /* Top padding clears the fixed nav. */
    padding: 100px 20px 60px;
    display: flex;
    justify-content: center;
  }
  @media (min-width: 768px)  { .news-hero { padding: 140px 32px 80px; } }
  @media (min-width: 1280px) { .news-hero { padding: 160px 60px 100px; } }
  @media (min-width: 1920px) { .news-hero { padding: 180px 90px 120px; } }

  .news-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    width: 100%;
    max-width: 860px;
  }
  @media (min-width: 1280px) { .news-hero__inner { gap: 32px; } }

  .news-hero__logo {
    display: block;
    width: 56px;
    height: 56px;
    margin: 0 auto 4px;
  }
  @media (min-width: 1280px) { .news-hero__logo { width: 64px; height: 64px; } }

  .news-hero__eyebrow {
    color: var(--c-cherrywood);
    text-align: center;
  }

  .news-hero__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-cherrywood);
    margin: 0;
    text-align: center;
  }
  .news-hero__title :global(em) { font-style: italic; }

  .news-hero__copy {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 720px;
  }

  .news-hero__body {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    text-align: center;
    margin: 0;
  }

  /* ----- Alchemy newsletter form (iframed; Scribe auto-resizes) ----- */
  .news-hero__form-wrap {
    width: 100%;
    max-width: 480px;
    margin-top: 8px;
  }
  .news-hero__frame {
    width: 100%;
    height: 220px;          /* sensible default before Scribe sizes it */
    min-height: 180px;
    border: 0;
    display: block;
    transition: height 200ms ease;
  }
</style>
