---
import BaseLayout from '@layouts/BaseLayout.astro';
import OverviewHero from '@organisms/OverviewHero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';
import { getEmDashEntry } from 'emdash';
import { jsonArray, nl2br, imageUrl, getTestimonials } from '@lib/cms';

// Editable at /_emdash/admin/content/ausbildung_programs (entry "uebersicht").
// Design/CSS stay in this file; text + card arrays come from the CMS section bag.
const { entry } = await getEmDashEntry('ausbildung_programs', 'uebersicht');
const d: Record<string, any> = entry?.data ?? {};
const sec = (t: string): Record<string, any> => (d.sections ?? []).find((s: any) => s.type === t) ?? {};
const nar = sec('narrative'), stg = sec('stages'), out = sec('outcomes'),
      leh = sec('lehrerin'), uq = sec('uquote'), nlx = sec('newsletter');

/* ----- "Drei Stufen, ein Weg" — three stage cards (image + eyebrow + title + body + CTA) -----
   Editable as the "Stufen-Karten" repeater on the ausbildung_programs/uebersicht entry
   (labeled inputs + image upload per card — no JSON). Falls back to the original copy. */
const stages = (d.stage_cards?.length ? d.stage_cards : [
  {
    image: '/images/cards/card-1.jpg',
    eyebrow: 'Teil 1 — Grundlagen',
    title: 'Der Einstieg in die systemische Arbeit',
    body: 'Du lernst die Grundlagen des systemischen Aufstellens — was Systeme sind, wie sie funktionieren, und was passiert, wenn sich etwas in ihnen festgesetzt hat. Du stellst, du wirst aufgestellt, du lernst durch Erleben.',
    cta_href: '/ausbildung/soulcoach-level-1',
  },
  {
    image: '/images/cards/card-2.jpg',
    eyebrow: 'Teil 2 — Vertiefung',
    title: 'Vom Verständnis zur Praxis',
    body: 'Du vertiefst dein methodisches Handwerk. Komplexere Systeme, schwierigere Dynamiken, dein eigener Stil als Begleitperson. Nach Teil 2 bist du bereit, eigenständig zu arbeiten.',
    cta_href: '/ausbildung/soulcoach-level-2',
  },
  {
    image: '/images/cards/card-3.jpg',
    eyebrow: 'Begleitung & Circle',
    title: 'In der Praxis bleiben und weiterlernen',
    body: 'Einmal im Monat gemeinsames Aufstellen in der Gruppe. Für alle, die nach der Ausbildung nicht aufhören wollen, die das Handwerk lebendig halten und weiter wachsen wollen. Zugang nur nach abgeschlossener Ausbildung.',
    cta_href: '/kontakt',
  },
]) as Array<Record<string, any>>;

/* ----- "Nach dieser Ausbildung arbeitest du anderst." — outcomes arc (4 cards) ----- */
const outcomes = d.outcomes?.length ? d.outcomes : [
  {
    title: 'Du siehst Systeme.',
    description: 'Muster, Dynamiken, Loyalitäten — du erkennst sie früher. In der Arbeit mit anderen, und in deinem eigenen Leben.',
  },
  {
    title: 'Du begleitest sicher.',
    description: 'Nicht nur auf der Oberfläche — sondern dort wo sich wirklich etwas hält. Mit Methode und Haltung.',
  },
  {
    title: 'Du hältst die Spannung.',
    description: 'Konflikte, Widerstand, schwierige Momente — du weichst nicht aus. Du bist Boden für andere.',
  },
  {
    title: 'Du arbeitest aus Erfahrung.',
    description: 'Nicht aus Theorie. Was du weitergibst, hast du selbst durchlebt. Das ist der Unterschied.',
  },  
];

/* ----- "Stimmen aus der Ausbildung" — star reviews ----- */
const _reviews = await getTestimonials('ausbildung');
const reviews = _reviews.length ? _reviews : [
  {
    quote: '«Diese Ausbildung hat mir eine völlig neue Perspektive eröffnet. Ich war lange eher im Kopf als im Körper — genau das beginnt sich zu verändern. Die Arbeit mit Familienkonstellationen hat mir geholfen, Klarheit zu gewinnen. Wo vorher Chaos war, entsteht heute mehr Ruhe und Vertrauen. Ich fühle mich mehr bei mir selbst angekommen.»',
    name: 'Jana L.',
  },
  {
    quote: '«In dieser Ausbildungsgruppe fühle ich mich so getragen, dass ich mit allem da sein kann, was ich bin. So habe ich mich in einer Gruppe noch nie gefühlt. In mir ist eine grosse Welle in Bewegung gekommen — früher hätte ich solche Gefühle verdrängt, heute gehe ich durch sie hindurch. Diese Ausbildung ist für mich weit mehr als Lernen. Sie ist ein Raum für Heilung, Wachstum und echtes Menschsein.»',
    name: 'Silvia F.',
  },
  {
    quote: '«Diese Ausbildung zeigt die Magie des systemischen Aufstellens — und ich könnte mir keinen Ort vorstellen, an dem ich mich wohler fühle. Ein geschützter Raum, in dem jede einfach sie selbst sein darf. Theresia schafft diesen Rahmen mit einer einfühlsamen Art, die es möglich macht, sich wirklich zu öffnen. Was diese Ausbildung besonders macht: die Erfahrung, selbst Teil eines solchen Prozesses zu sein.»',
    name: 'Corina B.',
  },
];

const faqItems = d.faq_items?.length ? d.faq_items : [
  {
    question: 'Brauche ich Vorkenntnisse für die Ausbildung?',
    answer: 'Nein. Du musst keine therapeutische oder psychologische Vorbildung mitbringen. Wichtiger als Vorwissen sind deine Offenheit und die Bereitschaft, dich selbst und das eigene System wirklich anzuschauen.',
  },
  {
    question: 'Kann ich direkt mit der Ausbildung zum Systemic Soulcoach starten?',
    answer: 'Ja. Die Ausbildung ist so aufgebaut, dass du ohne Vorerfahrung im systemischen Arbeiten einsteigen kannst. Wir beginnen bei den Grundlagen und gehen Schritt für Schritt in die Tiefe. Im Erstgespräch klären wir gemeinsam, ob der Einstieg für dich stimmig ist.',
  },
  {
    question: 'Ist die Ausbildung eher theoretisch oder praktisch ausgerichtet?',
    answer: 'Klar praktisch. Du lernst durch Erleben — du stellst auf, wirst aufgestellt und begleitest. Die nötige Theorie ordnet das Erlebte ein, doch der Schwerpunkt liegt auf der gelebten Erfahrung in der Gruppe.',
  },
  {
    question: 'Kann ich nach der Ausbildung selbst Menschen begleiten?',
    answer: 'Ja. Nach abgeschlossener Ausbildung hast du das methodische Handwerk und die Haltung, um eigenständig systemisch zu begleiten — mit Sicherheit, Tiefe und einem klaren Verständnis dafür, was zwischen Menschen wirkt.',
  },
  {
    question: 'Eignet sich die Ausbildung auch für Menschen, die bereits im Gesundheits-, Coaching- oder Beratungsbereich tätig sind?',
    answer: 'Sehr. Wenn du bereits mit Menschen arbeitest, gibt dir die systemische Perspektive ein kraftvolles zusätzliches Werkzeug. Du erkennst Muster und Dynamiken früher und kannst dort begleiten, wo sich wirklich etwas hält.',
  },
  {
    question: 'Werden die Kosten von der Krankenkasse übernommen?',
    answer: 'Systemisches Aufstellen ist eine Form der persönlichen und beruflichen Entwicklung und in der Regel keine kassenpflichtige Leistung. Für die Ausbildung erhältst du im Erstgespräch eine detaillierte Übersicht der Investition.',
  },
  {
    question: 'Was passiert, wenn ich einmal einen Termin nicht wahrnehmen kann?',
    answer: 'Das lässt sich in der Regel lösen. Die Module bauen aufeinander auf, und wir finden gemeinsam einen Weg, ein verpasstes Treffen zu integrieren, damit du den Anschluss nicht verlierst. Sprich uns einfach frühzeitig an.',
  },
  {
    question: 'Was unterscheidet diese Ausbildung von anderen Ausbildungsprogrammen?',
    answer: 'Hier geht es um mehr als Methodenlernen. Aufgebaut auf über 30 Jahren gelebter Praxis verbindet die Ausbildung Handwerk und Haltung — und du durchlebst selbst, was du später weitergibst. Diese Tiefe macht den Unterschied.',
  },
];

const lehrerinParagraphs = (d.lehrerin_paragraphs?.length ? d.lehrerin_paragraphs.map((p: any) => p.text) : [
  'Über 30 Jahre Erfahrung in der Begleitung von Menschen – körperlich, systemisch und energetisch.',
  'Theresia Jansen lehrt nicht, was sie gelesen hat — sondern was sie über 30 Jahre hinweg erprobt, durchlebt und verfeinert hat. Kein importiertes Curriculum, sondern echte Praxis mit echten Menschen in der Deutschschweiz.',
  'Wer bei ihr lernt, erhält nicht nur Wissen und Werkzeuge. Für viele wird die Ausbildung zu einer persönlichen Reise, die weit über fachliches Lernen hinausgeht.',
]) as string[];
---

<BaseLayout
  title="Übersicht – Systemic Soulcoach Ausbildung bei VitaLunaris"
  description="Die Ausbildung zum Systemic Soulcoach bei Theresia Jansen. Für Menschen die mit Menschen arbeiten wollen — und die Tiefe suchen, die oberflächliche Methoden nicht erreichen. In zwei Stufen, aufgebaut auf über 30 Jahren Praxis in der Deutschschweiz."
  currentPath="/ausbildung/uebersicht"
>
  <OverviewHero
    eyebrow={d.hero_eyebrow || 'Systemic Soulcoach Ausbildung'}
    title={d.hero_title || 'Systemische Arbeit.<br />Professionell begleiten<br />und wirklich tief gehen.'}
    subtitle={d.hero_subtitle || 'Die Ausbildung zum Systemic Soulcoach bei Theresia Jansen. Für Menschen, die mit Tiefe arbeiten wollen — und die Tiefe suchen, die oberflächliche Methoden nicht erreichen. In zwei Stufen, aufgebaut auf über 30 Jahren gelebter Praxis in der Deutschschweiz.'}
  />

  {/* ===================== Methode. Haltung. Tiefe. ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image={imageUrl(nar.image) || '/images/placeholder/Placeholder-7.jpg'}
    imageAlt=""
    title={nar.title || 'Methode.<br />Haltung. Tiefe.'}
    body={nl2br(nar.body) || 'Systemische Arbeit schaut nicht auf die Person allein — sondern auf das System dahinter. Die Familie, die Geschichte, die Muster die von Generation zu Generation weitergehen ohne je ausgesprochen zu werden.<br/> <br/> Was sich im Leben einer Person immer wiederholt, sitzt selten nur in ihr. Ein Systemic Soulcoach sieht das System hinter der Person — und weiss, wie er es begleiten kann.'}
  />

  {/* ===================== Drei Stufen, ein Weg ===================== */}
  <section class="stages">
    <div class="stages__inner">
      <div class="stages__header">
        <Heading level={2} variant="h1" class="stages__title">{stg.title || 'Drei Stufen, ein Weg'}</Heading>
        <Text size="p1" class="stages__intro">
          {stg.body || 'Jede Stufe baut auf der vorherigen auf. Du entscheidest nach Level 1 — aber die meisten wollen tiefer.'}
        </Text>
      </div>
      <div class="stages__grid">
        {stages.map((s) => (
          <article class="stage-card">
            <div class="stage-card__media">
              <img src={imageUrl(s.image)} alt="" loading="lazy" decoding="async" />
            </div>
            <div class="stage-card__text">
              <Heading variant="eyebrow" class="stage-card__eyebrow">{s.eyebrow}</Heading>
              <Heading level={3} variant="h2" class="stage-card__title">{s.title}</Heading>
              <Text size="p1" class="stage-card__body">{s.body}</Text>
            </div>
            <div class="stage-card__cta">
              <Button href={s.cta_href} variant="primary" size="lg" fullWidth>{s.cta_text || 'Mehr erfahren'}</Button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ===================== Nach dieser Ausbildung arbeitest du anderst. ===================== */}
  <section class="outcomes">
    <header class="outcomes__header">
      <Heading level={2} variant="h1" class="outcomes__title">{out.title || 'Nach dieser Ausbildung arbeitest du anderst.'}</Heading>
    </header>

    {/* Desktop (≥1024px): single curve + absolutely positioned cards at ≥1072 */}
    <div class="outcomes__desktop">
      <img src="/images/ebene/process-curve.svg" alt="" class="outcomes__curve" />
      <div class="outcomes__cards">
        {outcomes.map((o, i) => (
          <article class={`outcomes__card outcomes__card--${i + 1}`}>
            <Heading level={3} class="outcomes__card-title">{o.title}</Heading>
            <Text size="p1" class="outcomes__card-body">{o.description}</Text>
          </article>
        ))}
      </div>
    </div>

    {/* Mobile/tablet (<1024px): two halves, each with its own curve + 2 cards */}
    <div class="outcomes__mobile">
      {[0, 2].map((startIdx) => (
        <div class="outcomes__mobile-section">
          <div class="outcomes__mobile-curve">
            <img
              src={startIdx === 0 ? '/images/ebene/process-curve-1.svg' : '/images/ebene/process-curve-2.svg'}
              alt=""
            />
          </div>
          <div class="outcomes__mobile-cards">
            {outcomes.slice(startIdx, startIdx + 2).map((o) => (
              <article class="outcomes__mobile-card">
                <Heading level={3} class="outcomes__card-title">{o.title}</Heading>
                <Text size="p1" class="outcomes__card-body">{o.description}</Text>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* ===================== Deine Lehrerin — Theresia Jansen ===================== */}
  <section class="lehrerin">
    <div class="lehrerin__inner">
      <div class="lehrerin__media">
        <img src={imageUrl(leh.image) || '/images/placeholder/Placeholder-8.jpg'} alt="Theresia Jansen" loading="lazy" decoding="async" />
      </div>
      <div class="lehrerin__content">
        <Heading variant="eyebrow" class="lehrerin__eyebrow">{leh.eyebrow || 'Deine Lehrerin'}</Heading>
        <Heading level={2} variant="h1" class="lehrerin__name">{leh.title || 'Theresia Jansen'}</Heading>
        {lehrerinParagraphs.map((p: string) => (
          <Text size="p1" class="lehrerin__body"><Fragment set:html={p} /></Text>
        ))}
        <div class="lehrerin__cta">
          <Button href="/ueber-uns" variant="primary" size="lg">Mehr über Theresia</Button>
        </div>
      </div>
    </div>
  </section>

  {/* ===================== Stimmen aus der Ausbildung ===================== */}
  <TestimonialsBlock title="Stimmen aus der Ausbildung" testimonials={reviews} tone={d.testimonials_tone || 'gold'} />

  {/* ===================== Gold claim / quote ===================== */}
  <section class="uquote">
    <div class="uquote__inner">
      <div class="uquote__media">
        <img src={imageUrl(uq.image) || '/images/placeholder/Placeholder-5.jpg'} alt="" loading="lazy" decoding="async" />
      </div>
      <div class="uquote__content">
        <Heading level={2} variant="h1" class="uquote__text">
          {uq.title || '„Menschen verändern sich nicht, weil man ihnen sagt, was sie tun sollen. Sie verändern sich, wenn sie beginnen zu verstehen, was sie bisher unbewusst getragen hat.“'}
        </Heading>
        <Text size="p1" class="uquote__attribution">{uq.body || 'Theresia Jansen · VitaLunaris'}</Text>
      </div>
    </div>
  </section>

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />

  {/* ===================== Noch nicht sicher? — Newsletter ===================== */}
  <NewsletterBlock
    title={nlx.title || 'Noch nicht sicher?'}
    body={nlx.body || 'Melde dich für den Newsletter an — wir informieren dich, wenn der nächste Ausbildungsstart bekannt ist. Und in der Zwischenzeit laden wir dich ein, in einem unserer Seminare zu schnuppern.'}
    placeholder="E-mail Adresse"
    submitText="Anmelden"
  />
</BaseLayout>

<style>
  /* ============================================================
     STAGES — "Drei Stufen, ein Weg" (image + eyebrow + title + body + CTA)
     ============================================================ */
  .stages {
    background: var(--c-spring-wood);
    padding: 64px 20px;
  }
  @media (min-width: 768px)  { .stages { padding: 96px 32px; } }
  @media (min-width: 1280px) { .stages { padding: 120px 60px; } }
  @media (min-width: 1920px) { .stages { padding: 90px; } }

  .stages__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1920px) { .stages__inner { gap: 64px; } }

  .stages__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
    width: 100%;
    max-width: 862px;
  }
  @media (min-width: 768px) { .stages__header { gap: 40px; } }

  .stages__title { color: var(--c-cherrywood); margin: 0; text-align: center; width: 100%; }
  .stages__intro { color: var(--c-cherrywood); text-align: center; width: 100%; }

  .stages__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    width: 100%;
  }
  @media (min-width: 768px)  { .stages__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1280px) { .stages__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; } }

  .stage-card {
    box-sizing: border-box;
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    border-radius: var(--radius-card-sm);
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    height: 100%;
  }
  @media (min-width: 1280px) { .stage-card { padding: 24px; gap: 32px; border-radius: var(--radius-card); } }
  @media (min-width: 1920px) { .stage-card { padding: 32px; gap: 40px; border-radius: var(--radius-card-lg); } }

  .stage-card__media {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--c-pale-gold);
  }
  @media (min-width: 1280px) { .stage-card__media { border-radius: var(--radius-md); } }
  .stage-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .stage-card__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    align-self: stretch;
    flex-grow: 1;
  }
  .stage-card__eyebrow { color: var(--c-cherrywood); align-self: stretch; }

  .stage-card__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h2-size);
    line-height: 1.15;
    margin: 0;
    align-self: stretch;
  }
  @media (min-width: 1280px) { .stage-card__title { font-size: 32px; } }

  .stage-card__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; align-self: stretch; }

  .stage-card__cta { align-self: stretch; width: 100%; }
  .stage-card__cta :global(.btn) {
    width: 100%;
    height: 42px;
    min-height: 42px;
    padding: 10px;
    font-size: var(--button-size);
    line-height: 1.2;
    border-radius: var(--radius-pill);
  }
  @media (min-width: 1024px) {
    .stage-card__cta :global(.btn) { height: 56px; min-height: 56px; padding: 18px; }
  }

  /* ============================================================
     OUTCOMES — "Nach dieser Ausbildung arbeitest du anderst."
     Mobile/tablet (<1024): two halves with separate curves (-1, -2)
     Desktop (≥1024): single process-curve.svg
     Desktop++ (≥1072): cards absolutely positioned per Figma
     ============================================================ */
  .outcomes {
    background: var(--c-spring-wood);
    padding: 64px 8px;
    overflow: hidden;
  }
  @media (min-width: 768px)  { .outcomes { padding: 96px 8px; } }
  @media (min-width: 1024px) { .outcomes { padding: 120px 8px; } }

  .outcomes__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 12px;
    max-width: 1106px;
    margin: 0 auto;
  }
  .outcomes__title { text-align: center; color: var(--c-cherrywood); margin: 0; }

  .outcomes__card-title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }
  .outcomes__card-body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }

  .outcomes__desktop { display: none; }
  .outcomes__mobile  { display: block; margin-top: 24px; }

  @media (min-width: 1024px) {
    .outcomes__desktop { display: block; margin-top: 32px; }
    .outcomes__mobile  { display: none; }
    .outcomes__curve { display: block; width: 100%; height: auto; margin: 0; }
  }

  @media (min-width: 1024px) and (max-width: 1071.98px) {
    .outcomes__cards {
      position: relative;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      padding: 0 90px;
      margin-top: 40px;
      min-height: 0;
      box-sizing: border-box;
    }
    .outcomes__card {
      position: static;
      width: auto;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      color: var(--c-cherrywood);
    }
  }

  @media (min-width: 1072px) {
    .outcomes {
      position: relative;
      --cv: min(100vw, 1920px);
      --cx: calc((100vw - var(--cv)) / 2);
      min-height: calc(0.68177 * var(--cv));
      padding: 120px 0;
    }
    .outcomes__header { max-width: 1106px; padding: 0 12px; margin: 0 auto; }

    .outcomes__desktop {
      position: static;
      width: 100%;
      max-width: 1920px;
      margin: 32px auto 0;
    }
    .outcomes__curve { max-width: none; }
    .outcomes__cards { position: static; display: block; padding: 0; margin: 0; }

    .outcomes__card {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(16px, 2.1vw, 40px);
      color: var(--c-cherrywood);
    }
    .outcomes__card--1 { left: calc(var(--cx) + 0.05000 * var(--cv)); top: calc(0.37344 * var(--cv)); width: calc(0.20104 * var(--cv)); }
    .outcomes__card--2 { left: calc(var(--cx) + 0.27552 * var(--cv)); top: calc(0.29792 * var(--cv)); width: calc(0.20104 * var(--cv)); }
    .outcomes__card--3 { left: calc(var(--cx) + 0.50677 * var(--cv)); top: calc(0.28958 * var(--cv)); width: calc(0.20000 * var(--cv)); }
    .outcomes__card--4 { left: calc(var(--cx) + 0.73698 * var(--cv)); top: calc(0.38177 * var(--cv)); width: calc(0.20000 * var(--cv)); }

    .outcomes__card-title { font-size: clamp(28px, 2.5vw, 48px); line-height: 1.15; }
    .outcomes__card-body  { font-size: clamp(16px, 1.2vw, 23px); line-height: 1.5; }
  }

  .outcomes__mobile-section { margin-top: 24px; }
  .outcomes__mobile-section:first-child { margin-top: 0; }

  .outcomes__mobile-curve {
    width: auto;
    aspect-ratio: 600 / 130;
    overflow: visible;
    margin-left: -8px;
    margin-right: -8px;
    padding: 0;
    box-sizing: content-box;
  }
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .outcomes__mobile-curve { padding-top: 16px; }
  }
  .outcomes__mobile-curve img { display: block; width: 100%; height: 100%; }

  .outcomes__mobile-cards {
    display: flex;
    flex-direction: column;
