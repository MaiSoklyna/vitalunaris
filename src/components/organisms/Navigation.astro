---
import { getEmDashEntry } from 'emdash';
import { jsonArray } from '@lib/cms';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

interface NavChild {
  href: string;
  label: string;
  /** Renders the item dimmed + non-interactive (Figma "opacity 0.2" state, e.g. coming soon). */
  disabled?: boolean;
}
interface NavLink {
  href: string;
  label: string;
  children?: NavChild[];
  /** When true, clicking the parent navigates to its href instead of toggling the dropdown. */
  navigateOnClick?: boolean;
}

const FALLBACK_NAV: NavLink[] = [
  {
    href: '/ausbildung',
    label: 'Systemische Ausbildung',
    children: [
      { href: '/ausbildung/uebersicht', label: 'Übersicht' },
      { href: '/ausbildung/soulcoach-level-1', label: 'Systemischer Soulcoach – Level 1' },
      { href: '/ausbildung/soulcoach-level-2', label: 'Systemischer Soulcoach – Level 2' },
      // Hidden until the designer completes the content — re-add when the page exists.
      // { href: '/ausbildung/begleitung-kreis', label: 'Begleitung & Kreis', disabled: true },
      { href: '/ausbildung/infoanlaesse', label: 'Infoanlässe' },
    ],
  },
  {
    href: '/workshops-kurse/kalender-uebersicht',
    label: 'Workshops & Kurse',
    navigateOnClick: true,
    children: [
      { href: '/workshops-kurse/kalender-uebersicht', label: 'Kalender & Übersicht' },
      { href: '/workshops-kurse/aktueller-monatsworkshop', label: 'Aktueller Monatsworkshop' },
    ],
  },
  {
    href: '/praxisangebote',
    label: 'Praxisangebote',
    children: [
      { href: '/praxisangebote', label: 'Übersicht' },
      { href: '/praxisangebote/aufstellungen', label: '1:1 Aufstellungen' },
      { href: '/praxisangebote/hypnose', label: 'Hypnose' },
      { href: '/praxisangebote/numerologieberatung', label: 'Numerologieberatung' },
      { href: '/praxisangebote/fussreflexzonenbehandlung', label: 'Fussreflexzonenbehandlung' },
      { href: '/praxisangebote/jawort-by-jansen', label: 'Jawort by Jansen' },
    ],
  },
  { href: '/neuigkeiten', label: 'News' },
  { href: '/ueber-uns', label: 'Über uns' },
  { href: '/kontakt', label: 'Kontakt' },
];

// Navigation menu is editable in EmDash (site_settings → nav_items).
const { entry: settings } = await getEmDashEntry('site_settings', 'settings');
const sd: Record<string, any> = settings?.data ?? {};
const navLinks: NavLink[] = sd.nav_items?.length
  ? sd.nav_items.map((it: any) => {
      const children = jsonArray(it.children);
      return {
        href: it.href,
        label: it.label,
        navigateOnClick: it.navigate_on_click || undefined,
        children: children.length ? children : undefined,
      } as NavLink;
    })
  : FALLBACK_NAV;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

/** A parent is active when its own route or any of its children match. */
const isGroupActive = (item: NavLink) =>
  isActive(item.href) || (item.children?.some((c) => isActive(c.href)) ?? false);
---

<header id="main-header" class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label="VitaLunaris – Startseite">
      <img src="/logo/logo.svg" alt="VitaLunaris" class="nav__logo-img" />
    </a>

    <!-- Desktop pill nav (≥ 1280px) -->
    <nav class="nav__pill" aria-label="Hauptnavigation">
      {navLinks.map((item) =>
        item.children ? (
          <div class="nav__group" data-nav-group>
            <a
              href={item.href}
              class={`nav__link nav__link--has-menu ${isGroupActive(item) ? 'nav__link--active' : ''}`}
              aria-haspopup="true"
              aria-expanded="false"
              data-nav-navigate={item.navigateOnClick ? 'true' : undefined}
            >
              {item.label}
              <svg class="nav__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <div class="nav__menu" role="menu">
              {item.children.map((child) => (
                <a
                  href={child.disabled ? undefined : child.href}
                  role="menuitem"
                  aria-disabled={child.disabled ? 'true' : undefined}
                  tabindex={child.disabled ? -1 : undefined}
                  class={`nav__menu-link ${child.disabled ? 'nav__menu-link--disabled' : ''} ${
                    isActive(child.href) && !child.disabled ? 'nav__menu-link--active' : ''
                  }`}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class={`nav__link ${isActive(item.href) ? 'nav__link--active' : ''}`}
          >
            {item.label}
          </a>
        )
      )}
    </nav>

    <!-- Mobile/tablet fullscreen menu ( < 1280px ): accordions, one open at a time -->
    <div class="nav__compact" data-compact-menu>
      <button
        type="button"
        class="nav__menu-btn"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="compact-menu"
        data-menu-toggle
      >
        <svg class="nav__menu-icon nav__menu-icon--open" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
        <svg class="nav__menu-icon nav__menu-icon--close" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
      </button>

      <div id="compact-menu" class="nav__overlay" role="dialog" aria-modal="true" aria-label="Hauptnavigation" aria-hidden="true">
        <nav class="nav__overlay-nav" aria-label="Hauptnavigation">
          {navLinks.map((item) =>
            item.children ? (
              <div class="nav__acc" data-acc>
                <button
                  type="button"
                  class={`nav__acc-trigger ${isGroupActive(item) ? 'nav__acc-trigger--active' : ''}`}
                  aria-expanded="false"
                  data-acc-trigger
                >
                  <span>{item.label}</span>
                  <svg class="nav__acc-caret" width="14" height="9" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
                <div class="nav__acc-panel" data-acc-panel>
                  <div class="nav__acc-panel-inner">
                    {item.children.map((child) => (
                      <a
                        href={child.disabled ? undefined : child.href}
                        aria-disabled={child.disabled ? 'true' : undefined}
                        tabindex={child.disabled ? -1 : undefined}
                        class={`nav__acc-link ${child.disabled ? 'nav__acc-link--disabled' : ''} ${
                          isActive(child.href) && !child.disabled ? 'nav__acc-link--active' : ''
                        }`}
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class={`nav__overlay-link ${isActive(item.href) ? 'nav__overlay-link--active' : ''}`}
              >
                {item.label}
              </a>
            )
          )}
        </nav>
      </div>
    </div>
  </div>
</header>

<style>
  /* ============================================================
     NAV — BEM: .nav (block), .nav__* (elements), --modifier (state)
     ============================================================ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 8px 8px 12px;
    background: transparent;
    transition: padding 300ms ease;
  }
  @media (min-width: 768px)  { .nav { padding: 12px 16px 0; } }
  @media (min-width: 1280px) { .nav { padding: 16px 32px; } }
  @media (min-width: 1920px) { .nav { padding: 32px 48px 0; } }

  .nav__inner {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 6px 16px;
    min-height: 24px;
    background: linear-gradient(90.11deg,
      #FFAC8A 2.9%,
      #F5E193 39.98%,
      #E1E2FC 78.48%,
      #8E84B6 108.81%),
      #F9F4EE;
    border-radius: var(--radius-sm);
  }
  @media (min-width: 1024px) {
    .nav__inner {
      padding: 8px 20px;
      min-height: 48px;
      border-radius: var(--radius-md);
    }
  }
  @media (min-width: 1280px) {
    .nav__inner {
      min-height: 60px;
      border-radius: var(--radius-card);
    }
  }
  /* Desktop++ (≥ 1920px) — Figma Header spec */
  @media (min-width: 1920px) {
    .nav__inner {
      padding: 0 0;
      gap: 20px;
      height: 90px;
      border-radius: 24px;
    }
  }

  /* ---------- LOGO (Figma: 220×40 desktop, 110×20 mobile) ---------- */
  .nav__logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .nav__logo-img {
    width: 88px;
    height: 16px;
    transition: width 300ms ease, height 300ms ease;
  }
  @media (min-width: 768px) {
    .nav__logo-img { width: 163.24px; height: 30px; }
  }
  /* Desktop++ logo */
  @media (min-width: 1920px) {
    .nav__logo { padding: 0 43px; }
    .nav__logo-img { width: 217.65px; height: 40px; }
  }

  /* ---------- DESKTOP MENU (≥ 1280px) ---------- */
  .nav__pill { display: none; }
  @media (min-width: 1280px) {
    .nav__pill {
      display: inline-flex;
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: center;
      align-items: center;
      gap: 13px;
      padding: 0;
    }
  }
  @media (min-width: 1440px) { .nav__pill { gap: 32px; } }
  /* Desktop++ menu pill */
  @media (min-width: 1920px) {
    .nav__pill {
      padding: 0 40px;
      gap: 32px;
      height: 90px;
    }
  }

  .nav__link {
    font-family: 'ES Park', serif;
    font-size: var(--link-size);
    font-weight: var(--weight-regular);
    line-height: 1.2;
    text-align: center;
    color: var(--c-cherrywood);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 200ms ease;
  }
  .nav__link:hover { opacity: 0.7; }
  .nav__link--active { font-weight: 600; }
  @media (min-width: 1280px) { .nav__link { font-size: 16px; } }

  /* ---------- DESKTOP DROPDOWN GROUP (≥ 1280px) — Figma w=1920 spec ----------
     One data-driven pattern reused by every nav item that has children. */
  .nav__group {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .nav__link--has-menu {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
  }
  .nav__caret {
    flex-shrink: 0;
    transition: transform 220ms ease;
  }
  .nav__group:hover .nav__caret,
  .nav__group:focus-within .nav__caret,
  .nav__group.is-open .nav__caret { transform: rotate(180deg); }

  .nav__menu {
    box-sizing: border-box;
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    /* Padding / gap / radius scale per breakpoint; font-size stays on the
       global --link-size token (Figma's 18px is ignored on purpose). */
    gap: 20px;
    padding: 24px;
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    border-radius: 24px;
    box-shadow: 0 16px 40px rgba(96, 29, 29, 0.14);
    z-index: 20;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 220ms ease, transform 220ms ease, visibility 220ms ease;
  }
  /* Hover bridge: keep the gap between trigger and panel "hot" so the
     cursor can travel down without the menu closing. */
  .nav__menu::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 0;
    right: 0;
    height: 12px;
  }
  /* Desktop++ (≥ 1920px) — exact Figma box: 32px padding / 32px gap / 32px radius */
  @media (min-width: 1920px) {
    .nav__menu { gap: 32px; padding: 32px; border-radius: 32px; }
  }

  .nav__group:hover .nav__menu,
  .nav__group:focus-within .nav__menu,
  .nav__group.is-open .nav__menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav__menu-link {
    font-family: 'ES Park', serif;
    font-size: var(--link-size);
    font-weight: var(--weight-regular);
    line-height: 1.2;
    color: var(--c-cherrywood);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 180ms ease;
  }
  .nav__menu-link:hover { opacity: 0.6; }
  .nav__menu-link--active { font-weight: 600; }
  .nav__menu-link--disabled { opacity: 0.2; pointer-events: none; cursor: default; }

  /* ---------- MOBILE / TABLET FULLSCREEN MENU ( < 1280px ) ---------- */
  .nav__compact {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  @media (min-width: 1280px) { .nav__compact { display: none; } }

  .nav__menu-btn {
    position: relative;
    z-index: 110; /* stays above the overlay so it doubles as the close button */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    background: transparent;
    border: 0;
    color: var(--c-cherrywood);
    cursor: pointer;
  }
  @media (min-width: 768px) {
    .nav__menu-btn { width: 40px; height: 40px; }
  }
  .nav__menu-icon { width: 24px; height: 24px; display: block; }
  @media (min-width: 768px) { .nav__menu-icon { width: 32px; height: 32px; } }
  /* Icon swap: hamburger by default, X when the menu is open */
  .nav__menu-icon--close { display: none; }
  .nav__compact.is-open .nav__menu-icon--open { display: none; }
  .nav__compact.is-open .nav__menu-icon--close { display: block; }

  /* Fullscreen overlay */
  .nav__overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: flex;
    flex-direction: column;
    padding: 88px 20px 40px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--c-spring-wood);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 280ms ease, transform 280ms ease, visibility 280ms ease;
  }
  @media (min-width: 768px) { .nav__overlay { padding: 116px 40px 48px; } }

  .nav__compact.is-open .nav__overlay {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav__overlay-nav {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Shared baseline for top-level links and accordion triggers */
  .nav__overlay-link,
  .nav__acc-trigger {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: 24px;
    line-height: 1.3;
    color: var(--c-cherrywood);
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .nav__overlay-link,
    .nav__acc-trigger { font-size: 28px; }
  }

  .nav__overlay-link {
    display: block;
    padding: 16px 0;
    border-bottom: 1px solid rgba(96, 29, 29, 0.15);
  }
  .nav__overlay-link--active { font-weight: 600; }

  .nav__acc { border-bottom: 1px solid rgba(96, 29, 29, 0.15); }

  .nav__acc-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    padding: 16px 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
  }
  .nav__acc-trigger--active { font-weight: 600; }

  .nav__acc-caret {
    flex-shrink: 0;
    color: var(--c-cherrywood);
    transition: transform 240ms ease;
  }
  .nav__acc.is-open .nav__acc-caret { transform: rotate(180deg); }

  /* Animate open/close via grid-template-rows 0fr → 1fr */
  .nav__acc-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms ease;
  }
  .nav__acc.is-open .nav__acc-panel { grid-template-rows: 1fr; }

  .nav__acc-panel-inner {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .nav__acc-link {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: 18px;
    line-height: 1.4;
    color: var(--c-cherrywood);
    opacity: 0.85;
    text-decoration: none;
    padding: 10px 0 10px 16px;
  }
  @media (min-width: 768px) { .nav__acc-link { font-size: 20px; } }
  .nav__acc-link:last-child { padding-bottom: 18px; }
  .nav__acc-link--active { font-weight: 600; opacity: 1; }
  .nav__acc-link--disabled { opacity: 0.25; pointer-events: none; }

  /* Lock background scroll while the fullscreen menu is open */
  :global(body.nav-open) { overflow: hidden; }
</style>

<script>
  // Compact menu: hover handled by CSS; clicks/keyboard handled here for a11y.
  const header = document.getElementById('main-header');
  const compact = document.querySelector<HTMLElement>('[data-compact-menu]');
  const toggle = compact?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const dropdown = document.getElementById('compact-menu');

  // Accordion items inside the fullscreen overlay: only one open at a time.
  const accordions = Array.from(dropdown?.querySelectorAll<HTMLElement>('[data-acc]') ?? []);

  function closeAccordions(except?: HTMLElement) {
    accordions.forEach((acc) => {
      if (acc === except) return;
      acc.classList.remove('is-open');
      acc.querySelector('[data-acc-trigger]')?.setAttribute('aria-expanded', 'false');
    });
  }

  function setMenu(open: boolean) {
    if (!compact || !toggle || !dropdown) return;
    compact.classList.toggle('is-open', open);
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Menü schliessen' : 'Menü öffnen');
    dropdown.setAttribute('aria-hidden', open ? 'false' : 'true');
    document.body.classList.toggle('nav-open', open);
    if (!open) closeAccordions();
  }

  toggle?.addEventListener('click', () => {
    const open = compact?.classList.contains('is-open');
    setMenu(!open);
  });

  accordions.forEach((acc) => {
    const trigger = acc.querySelector<HTMLButtonElement>('[data-acc-trigger]');
    trigger?.addEventListener('click', () => {
      const open = !acc.classList.contains('is-open');
      closeAccordions(acc); // enforce single-open
      acc.classList.toggle('is-open', open);
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });

  // close the overlay when any navigation link is clicked
  dropdown?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => setMenu(false))
  );

  // close on Escape / outside click
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenu(false);
  });
  document.addEventListener('click', (e) => {
    if (!compact) return;
    if (!compact.contains(e.target as Node)) setMenu(false);
  });

  // Desktop dropdown groups: hover/focus reveal is CSS-driven. A click on the
  // parent trigger should NOT navigate — it opens (sticks) the submenu so the
  // user can pick a child page. Clicking again, outside, or Escape closes it.
  const navGroups = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-group]'));

  function closeGroups(except?: HTMLElement) {
    navGroups.forEach((group) => {
      if (group === except) return;
      group.classList.remove('is-open');
      group.querySelector('.nav__link--has-menu')?.setAttribute('aria-expanded', 'false');
    });
  }

  navGroups.forEach((group) => {
    const trigger = group.querySelector<HTMLElement>('.nav__link--has-menu');
    if (!trigger) return;
    const sync = (open: boolean) => trigger.setAttribute('aria-expanded', open ? 'true' : 'false');

    // Click the parent: stick the menu open instead of following its href.
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      const open = !group.classList.contains('is-open');
      closeGroups(group);
      group.classList.toggle('is-open', open);
      sync(open);
    });

    group.addEventListener('mouseenter', () => sync(true));
    group.addEventListener('mouseleave', () => { if (!group.classList.contains('is-open')) sync(false); });
    group.addEventListener('focusin', () => sync(true));
    group.addEventListener('focusout', () => {
      window.requestAnimationFrame(() => {
        if (!group.contains(document.activeElement) && !group.classList.contains('is-open')) sync(false);
      });
    });
  });

  // Close stuck submenus on outside click or Escape.
  document.addEventListener('click', (e) => {
    if (!navGroups.some((g) => g.contains(e.target as Node))) closeGroups();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeGroups();
  });

  // logo collapse on scroll
  function onScroll() {
    if (!header) return;
    header.classList.toggle('is-scrolled', window.scrollY > 80);
  }
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
