---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

interface Props {
  icon?: string;
  iconAlt?: string;
  /** When true, render `icon` as a full card-cover photo instead of a floating illustration. */
  imageIsCover?: boolean;
  title: string;
  description: string;
  price?: string;
  priceCaption?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  icon,
  iconAlt = '',
  imageIsCover = false,
  title,
  description,
  price,
  priceCaption,
  ctaText = 'Mehr erfahren',
  ctaHref = '/praxisangebote',
} = Astro.props;

const showCover = imageIsCover && !!icon;
---

<article class:list={['offer-card', showCover && 'offer-card--cover']}>
  {showCover ? (
    <div class="offer-card__cover">
      <img src={icon} alt={iconAlt || title} loading="lazy" decoding="async" />
    </div>
  ) : icon ? (
    <div class="offer-card__icon" aria-hidden="true">
      <img src={icon} alt={iconAlt} />
    </div>
  ) : null}
  <div class="offer-card__title-block">
    <Heading level={3} class="offer-card__title">{title}</Heading>
    <Text size="p2" class="offer-card__body">{description}</Text>
  </div>

  {price && (
    <div class="offer-card__price">
      <Heading level={4} class="offer-card__price-value">{price}</Heading>
      {priceCaption && <Text size="p3" class="offer-card__price-caption">{priceCaption}</Text>}
    </div>
  )}

  <div class="offer-card__cta">
    <Button href={ctaHref} variant="primary" size="lg" fullWidth>{ctaText}</Button>
  </div>
</article>

<style>
  /* ============================================================
     OFFER CARD — Figma spec at Desktop+ (w=1920):
     - Card: 420.5×724, padding 40px 41px, gap 59px, radius 25px, 1px border
     - Inner title-stack gap 17.55px
     - Icon: 136×190
     - Title H3: 32/120 weight 500
     - Body P2: 18/140 weight 400
     - Price row gap 80px (value H3 32/120, caption P2 18/140)
     - Button L: 338.5×61, padding 20×40, font 18/21, radius 100
     Scales down at smaller breakpoints.
     ============================================================ */
  .offer-card {
    box-sizing: border-box;
    position: relative;
    background: var(--c-spring-wood);
    color: var(--c-cherrywood);
    border: 0.667px solid var(--c-cherrywood);
    border-radius: var(--radius-card-sm);
    padding: 26.67px 27.33px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 39.33px;
    height: 100%;
  }
  @media (min-width: 1280px) {
    .offer-card {
      border-width: 1px;
      border-radius: var(--radius-card-lg);
      padding: 200px 24px 24px;
      gap: 24px;
      justify-content: space-between;
      isolation: isolate;
    }
  }
  /* Desktop++ (Figma w=1920): CARD 558.67×803, padding 284 32 32, gap 24, radius 25 */
  @media (min-width: 1920px) {
    .offer-card {
      padding: 284px 32px 32px;
      gap: 24px;
    }
  }

  /* ----- title block: H3 + body, tight 18px gap (Figma Frame 48095967) ----- */
  .offer-card__title-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    align-self: stretch;
    flex-grow: 1;
  }
  .offer-card__title { color: var(--c-cherrywood); }

  .offer-card__icon {
    width: 90.67px;
    height: 126.31px;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
  }
  .offer-card__icon img { width: 100%; height: 100%; object-fit: contain; display: block; }
  /* Desktop+ — icon floats absolutely, centered above the title (Figma Ebene_2) */
  @media (min-width: 1280px) {
    .offer-card__icon {
      position: absolute;
      top: 28px;
      left: 50%;
      transform: translateX(-50%);
      width: 122px;
      height: 171px;
      justify-content: center;
      z-index: 2;
    }
  }
  /* Desktop++ (Figma w=1920): Ebene_2 145×203, top 36px, horizontally centered */
  @media (min-width: 1920px) {
    .offer-card__icon { top: 36px; width: 145px; height: 203px; }
  }

  /* Title — H3 token on mobile/tablet; Figma custom 48px/120% w500 at desktop */
  .offer-card__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-medium);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }
  @media (min-width: 1280px) { .offer-card__title { font-size: 40px; } }
  @media (min-width: 1920px) { .offer-card__title { font-size: 48px; } }

  /* Body — P2 per Figma (18px at Desktop++ via --p1-size token) */
  .offer-card__body {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.4;
    color: var(--c-cherrywood);
    opacity: 1;
    align-self: stretch;
  }

  /* ----- price row — H3 + P2 inline ----- */
  .offer-card__price {
    border-top: 0;
    padding-top: 0;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 53.33px;
    width: 100%;
    align-self: stretch;
  }
  @media (min-width: 1920px) { .offer-card__price { gap: 80px; } }

  .offer-card__price-value {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-medium);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }

  .offer-card__price-caption {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p3-size);
    line-height: 1.4;
    color: var(--c-cherrywood);
    opacity: 1;
    text-align: right;
  }

  /* ----- CTA button — full-width, primary cherrywood ----- */
  .offer-card__cta { margin-top: 0; align-self: stretch; width: 100%; }
  .offer-card__cta :global(.btn) {
    width: 100%;
    height: 42px;
    min-height: 42px;
    padding: 10px;
    font-size: var(--button-size);
    line-height: 1.2;
    border-radius: var(--radius-pill);
  }
  @media (min-width: 1024px) {
    .offer-card__cta :global(.btn) {
      height: 61px;
      min-height: 61px;
      padding: 20px;
      gap: 11.26px;
      border-width: 1.4px;
    }
  }
  @media (min-width: 1920px) {
    .offer-card__cta :global(.btn) {
      height: 61px;
      min-height: 61px;
      padding: 20px;
      gap: 11.26px;
      border-width: 1.40784px;
    }
  }

  /* ============================================================
     COVER VARIANT — when the tile's image is a photo pulled from
     the linked page (auto-fill), show it as a full-bleed card
     cover at the top instead of the floating illustration slot.
     Double-class selectors override the base padding/float rules
     regardless of source order; card `overflow:hidden` clips the
     image to the rounded corners, so text gets its own padding.
     ============================================================ */
  .offer-card.offer-card--cover {
    padding: 0;
    gap: 20px;
    overflow: hidden;
  }
  .offer-card__cover { align-self: stretch; line-height: 0; }
  .offer-card__cover img {
    display: block;
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .offer-card--cover > .offer-card__title-block,
  .offer-card--cover > .offer-card__price {
    padding-left: 26.67px;
    padding-right: 26.67px;
  }
  .offer-card--cover > .offer-card__title-block { padding-top: 4px; }
  .offer-card--cover > .offer-card__cta { padding: 0 26.67px 26.67px; }

  @media (min-width: 1280px) {
    .offer-card.offer-card--cover { padding: 0; gap: 24px; }
    .offer-card--cover .offer-card__cover img { height: 260px; }
    .offer-card--cover > .offer-card__title-block,
    .offer-card--cover > .offer-card__price { padding-left: 24px; padding-right: 24px; }
    .offer-card--cover > .offer-card__title-block { padding-top: 8px; }
    .offer-card--cover > .offer-card__cta { padding: 0 24px 24px; }
  }
  @media (min-width: 1920px) {
    .offer-card.offer-card--cover { padding: 0; gap: 24px; }
    .offer-card--cover .offer-card__cover img { height: 320px; }
    .offer-card--cover > .offer-card__title-block,
    .offer-card--cover > .offer-card__price { padding-left: 32px; padding-right: 32px; }
    .offer-card--cover > .offer-card__cta { padding: 0 32px 32px; }
  }
</style>
