---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

type ImageSide = 'left' | 'right';

interface Props {
  eyebrow?: string;
  /** Page H1. May contain inline HTML (e.g. <br/>). */
  title: string;
  /** One or more intro paragraphs. */
  paragraphs?: string[];
  image: string;
  imageAlt?: string;
  imageSide?: ImageSide;
  /** Aspect ratio of the media frame. Default landscape-ish portrait. */
  mediaAspect?: string;
  /** object-position focal point for the mobile (cropped) hero image. */
  imageFocus?: string;
}

const {
  eyebrow,
  title,
  paragraphs = [],
  image,
  imageAlt = '',
  imageSide = 'right',
  mediaAspect = '5 / 6',
  imageFocus = 'center 30%',
} = Astro.props;
---

<section class={`about-hero about-hero--image-${imageSide}`} style={`--hero-focus: ${imageFocus};`}>
  <div class="about-hero__inner">
    <div class="about-hero__content">
      {eyebrow && <Heading variant="eyebrow" class="about-hero__eyebrow">{eyebrow}</Heading>}
      <Heading level={1} variant="h1" class="about-hero__title"><Fragment set:html={title} /></Heading>
      {paragraphs.map((p) => (
        <Text size="p1" class="about-hero__body"><Fragment set:html={p} /></Text>
      ))}
    </div>

    <div class="about-hero__media" style={`aspect-ratio: ${mediaAspect};`}>
      <img src={image} alt={imageAlt} class="about-hero__image" loading="eager" decoding="async" />
    </div>
  </div>
</section>

<style>
  /* ============================================================
     ABOUT HERO — eyebrow + H1 + intro paragraphs beside a portrait.
     Top padding clears the fixed Navigation. Spring Wood surface.
     Responsive: 360 / 768 / 1024 / 1280 / 1920.
     ============================================================ */
  .about-hero { background: var(--c-spring-wood); padding: 60px 20px 56px; }
  @media (min-width: 768px)  { .about-hero { padding: 90px 32px 72px; } }
  /* At exactly 1280 the fixed nav is shorter — use a tighter 90px top. */
  @media (min-width: 1280px) { .about-hero { padding: 90px 60px 90px; } }
  /* From 1290 up the full 180px top clearance applies. */
  @media (min-width: 1290px) { .about-hero { padding: 120px 60px 90px; } }
  /* 1920+ keeps the 60px left/right of 1919 (only top/bottom grow). */
  @media (min-width: 1920px) { .about-hero { padding: 160px 90px 120px; } }

  .about-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .about-hero__inner { flex-direction: row; align-items: center; gap: 64px; }
    .about-hero--image-right .about-hero__media   { order: 2; }
    .about-hero--image-right .about-hero__content { order: 1; }
    .about-hero--image-left  .about-hero__media   { order: 1; }
    .about-hero--image-left  .about-hero__content { order: 2; }
  }
  /* 1920+: content + image cap below the 1740 inner width, so push the
     leftover space into the middle (image flush right) instead of after it. */
  @media (min-width: 1920px) { .about-hero__inner { gap: 100px; justify-content: space-between; } }

  /* ----- content ----- */
  .about-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
    order: 1;
  }
  @media (min-width: 1024px) { .about-hero__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .about-hero__content { gap: 32px; max-width: 813px; } }

  .about-hero__eyebrow { color: var(--c-cherrywood); }
  .about-hero__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .about-hero__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }

  /* ----- media ----- */
  .about-hero__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: 16.67px;
    background: var(--c-pale-gold);
    order: 0;
  }
  @media (min-width: 1024px) { .about-hero__media { width: 46%; border-radius: 20px; } }
  @media (min-width: 1920px) { .about-hero__media { width: 711px; border-radius: 25px; } }
  .about-hero__image { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Mobile: ~half height, focal point on the face (overrides the inline aspect-ratio) */
  @media (max-width: 767.98px) {
    .about-hero__media { aspect-ratio: 8 / 5 !important; }
    .about-hero__image { object-position: var(--hero-focus, center 30%); }
  }
</style>
