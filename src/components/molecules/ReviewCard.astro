---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

interface Props {
  quote: string;
  name: string;
}

const { quote, name } = Astro.props;
---

<article class="review-card">
  <div class="review-card__inner">
    <Heading level={3} class="review-card__quote">{quote}</Heading>
    <Text size="p1" class="review-card__name">{name}</Text>
  </div>
</article>

<style>
  .review-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    background: var(--c-spring-wood);
    border: 1px solid var(--c-cherrywood);
    border-radius: 16.67px;
    padding: 24px;
    height: 100%;
  }
  @media (min-width: 1280px) {
    .review-card {
      border-radius: 20px;
      padding: 32px;
    }
  }
  @media (min-width: 1920px) {
    .review-card {
      border-radius: 25px;
      padding: 40px;
      border-width: 1.25px;
    }
  }

  .review-card__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    flex-grow: 1;
  }
  @media (min-width: 1280px) {
    .review-card__inner { gap: 26px; }
  }
  @media (min-width: 1920px) {
    .review-card__inner { gap: 30px; }
  }

  .review-card__quote {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-medium);
    font-size: var(--h3-size);
    line-height: 1.2;
    color: var(--c-cherrywood);
    margin: 0;
  }

  .review-card__name {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    color: var(--c-cherrywood);
  }
</style>
