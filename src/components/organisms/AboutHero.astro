---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';

type ImageSide = 'left' | 'right';

interface Props {
  eyebrow?: string;
  /** Page H1. May contain inline HTML (e.g. <br/>). */
  title: string;
  /** One or more intro paragraphs. */
  paragraphs?: string[];
  image: string;
  imageAlt?: string;
  imageSide?: ImageSide;
  /** Aspect ratio of the media frame. Default landscape-ish portrait. */
  mediaAspect?: string;
}

const {
  eyebrow,
  title,
  paragraphs = [],
  image,
  imageAlt = '',
  imageSide = 'right',
  mediaAspect = '5 / 6',
} = Astro.props;
---

<section class={`about-hero about-hero--image-${imageSide}`}>
  <div class="about-hero__inner">
    <div class="about-hero__content">
      {eyebrow && <Heading variant="eyebrow" class="about-hero__eyebrow">{eyebrow}</Heading>}
      <Heading level={1} variant="h1" class="about-hero__title"><Fragment set:html={title} /></Heading>
      {paragraphs.map((p) => (
        <Text size="p1" class="about-hero__body"><Fragment set:html={p} /></Text>
      ))}
    </div>

    <div class="about-hero__media" style={`aspect-ratio: ${mediaAspect};`}>
      <img src={image} alt={imageAlt} class="about-hero__image" loading="eager" decoding="async" />
    </div>
  </div>
</section>

<style>
  /* ============================================================
     ABOUT HERO — eyebrow + H1 + intro paragraphs beside a portrait.
     Top padding clears the fixed Navigation. Spring Wood surface.
     Responsive: 360 / 768 / 1024 / 1280 / 1920.
     ============================================================ */
  .about-hero { background: var(--c-spring-wood); padding: 120px 20px 56px; }
  @media (min-width: 768px)  { .about-hero { padding: 160px 32px 72px; } }
  @media (min-width: 1280px) { .about-hero { padding: 180px 60px 90px; } }
  @media (min-width: 1920px) { .about-hero { padding: 220px 90px 120px; } }

  .about-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .about-hero__inner { flex-direction: row; align-items: center; gap: 64px; }
    .about-hero--image-right .about-hero__media   { order: 2; }
    .about-hero--image-right .about-hero__content { order: 1; }
    .about-hero--image-left  .about-hero__media   { order: 1; }
    .about-hero--image-left  .about-hero__content { order: 2; }
  }
  @media (min-width: 1920px) { .about-hero__inner { gap: 100px; } }

  /* ----- content ----- */
  .about-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
    order: 1;
  }
  @media (min-width: 1024px) { .about-hero__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .about-hero__content { gap: 32px; max-width: 813px; } }

  .about-hero__eyebrow { color: var(--c-cherrywood); }
  .about-hero__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .about-hero__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }

  /* ----- media ----- */
  .about-hero__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: 16.67px;
    background: var(--c-pale-gold);
    order: 0;
  }
  @media (min-width: 1024px) { .about-hero__media { width: 46%; border-radius: 20px; } }
  @media (min-width: 1920px) { .about-hero__media { width: 711px; border-radius: 25px; } }
  .about-hero__image { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
