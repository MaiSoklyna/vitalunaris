---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@organisms/Hero.astro';
import Blocks from '@organisms/Blocks.astro';
import { getEmDashEntry } from 'emdash';
import { imageUrl } from '@lib/cms';

// Home is a block page — editable at /_emdash/admin/content/pages (slug "home").
// Sections render through Blocks.astro; the fallback below keeps the page intact
// if the CMS row is ever cleared.
const { entry } = await getEmDashEntry('pages', 'home');
const d: Record<string, any> = entry?.data ?? {};

const FALLBACK_SECTIONS = [
  {
    type: 'offer_cards',
    title: 'Wie können wir dir helfen?',
    items: [
      { icon: '/images/ebene/Ebene-14.svg', title: 'Ich will Systemisches Aufstellen lernen', description: 'Du willst systemisches Aufstellen nicht nur selbst erleben, sondern auch anwenden oder weitergeben. Wir begleiten dich Schritt für Schritt – von deiner eigenen Aufstellungsreise bis zur Ausbildung zum Systemic Soulcoach.', ctaText: 'Zu den Ausbildungen →', ctaHref: '/ausbildung' },
      { icon: '/images/ebene/Ebene_2.svg', title: 'Ich will meine Praxis vertiefen oder Neues lernen', description: 'Du möchtest neue Methoden kennenlernen oder dein bestehendes Wissen erweitern? Aus unserem jahrzehntelangen Erfahrungsschatz geben wir praxisnahes Wissen weiter – in Weiterbildungen und Kursen.', ctaText: 'Zu den Workshops & Kursen →', ctaHref: '/workshops-kurse/kalender-uebersicht' },
      { icon: '/images/ebene/Ebene_2-8.svg', title: 'Ich suche Veränderung oder Unterstützung', description: 'Etwas in deinem Leben fühlt sich nicht mehr stimmig an. Es gibt verschiedene Wege, Klarheit zu gewinnen, neue Perspektiven zu entdecken und wieder in Bewegung zu kommen.', ctaText: 'Unsere Praxisangebote →', ctaHref: '/praxisangebote' },
    ],
  },
  {
    type: 'narrative', tone: 'light', image_side: 'left', image: '/images/placeholder/Placeholder-6.jpg',
    title: 'Mehr als eine Praxis. <br/> Ein Ort wo Erfahrung auf Tiefe trifft.',
    body: 'VitaLunaris ist aus über 30 Jahren Erfahrung in der Begleitung von Menschen gewachsen. Ein Ort für alle, die verstehen möchten, warum sich manche Themen im Leben wiederholen, weshalb Beziehungen herausfordernd sein können oder was hinter den eigenen Herausforderungen und Lebenswegen wirkt.<br/><br/>Systemisches Aufstellen, Hypnose und Numerologie sind für uns keine Gegensätze. Sie sind verschiedene Wege, Zusammenhänge sichtbar zu machen, neue Perspektiven zu gewinnen und Veränderung möglich werden zu lassen.',
  },
  {
    type: 'narrative', tone: 'purple', image_side: 'right', image: '/images/placeholder/placeholder-3.jpg',
    title: '“VitaLunaris ist ein Raum, in dem Veränderung möglich werden darf. Ein Raum für neue Perspektiven, ehrliche Begegnungen und tiefe Prozesse – auf eine Weise, die zu dir passt.”',
    body: 'Theresia & Axel Jansen · VitaLunaris',
  },
  {
    type: 'testimonials', eyebrow: 'Stimmen', title: 'Was Menschen sagen.',
    items: [
      { quote: '“Nach einer sehr schweren Zeit fand ich bei VitaLunaris einen geschützten Raum für meinen Weg. Durch die Begleitung von Theresia wurden Zusammenhänge sichtbar, die ich vorher nicht erkennen konnte. Schritt für Schritt fand ich zurück zu Vertrauen und neuer Lebensfreude.”', name: 'Claudia N.' },
      { quote: '“Ich stand vor einer wichtigen Entscheidung und war unsicher. Das Numeroskop von Axel hat mir neue Perspektiven eröffnet und mir geholfen, meine Stärken klarer zu erkennen. Heute weiss ich, dass ich die richtige Entscheidung getroffen habe.”', name: 'Erika B.' },
      { quote: '“Ich hätte nie gedacht, dass man mit ein bisschen Klopfen so viel erreichen kann. Schon nach dem EFT-Grundkurs konnte ich die Methode im Alltag anwenden. Eine echte Bereicherung für unsere ganze Familie.”', name: 'Ramona K.' },
      { quote: '“Die Ausbildung zum Systemic Soulcoach war für mich weit mehr als eine Ausbildung. Theresia hält einen unglaublich sicheren und vertrauensvollen Raum, sodass man sich wirklich auf die eigenen Prozesse einlassen kann.”', name: 'Corina B.' },
    ],
  },
  {
    type: 'newsletter', eyebrow: 'Newsletter', title: 'Impulse für deine<br />innere Reise.',
    body: 'Unser Newsletter ist kein gewöhnlicher Newsletter. Unsere Geschichten. Axels Zahlenmagie. Die feinen Impulse von Theresia.<br/><br/>Dazu neue Kurstermine, Podcast-Episoden, Inspirationen und kleine Einblicke hinter die Kulissen von VitaLunaris – direkt in deiner Inbox.',
    items: { placeholder: 'E-mail adresse', submitText: 'Kostenlos abonnieren' },
  },
];

const sections = d.sections?.length ? d.sections : FALLBACK_SECTIONS;
---

<BaseLayout
  title={d.seo_title || 'VitaLunaris – Erforsche die Systeme der Seele'}
  description={d.seo_description || 'VitaLunaris in Buchs SG begleitet dich in Tiefenarbeit, Integration und Transformation — mit klarem Vorgehen und geschützten Räumen.'}
  currentPath="/"
>
  <Hero
    eyebrow={d.hero_eyebrow || 'Willkommen bei VitaLunaris'}
    title={d.hero_title || "Erforsche die<br class='hero__br--md' /> Systeme der<br class='hero__br--md' />Seele"}
    subtitle={d.hero_subtitle || 'VitaLunaris ist dein Ort für systemische Aufstellungsarbeit, Hypnose, Numerologie und persönliche Entwicklung. Hier verbinden sich systemisches Wissen, intuitive Wahrnehmung und die Erfahrung aus jahrzehntelanger Arbeit mit Menschen – getragen von Theresia und Axel Jansen.'}
    ctaText={d.hero_primary_cta_text || 'Zu den Ausbildungen'}
    ctaHref={d.hero_primary_cta_href || '/ausbildung'}
    secondaryCtaText={d.hero_secondary_cta_text || 'Zu den Angeboten'}
    secondaryCtaHref={d.hero_secondary_cta_href || '/praxisangebote'}
    image={imageUrl(d.hero_image) || '/images/placeholder/Placeholder_1.jpg'}
  />

  <Blocks sections={sections} />
</BaseLayout>
