---
import BaseLayout from '@layouts/BaseLayout.astro';
import CourseHero from '@organisms/CourseHero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import ProcessSteps from '@organisms/ProcessSteps.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import PersonBio from '@organisms/PersonBio.astro';
import BrandCtaBlock from '@organisms/BrandCtaBlock.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';

const steps = [
  { number: '01', title: 'Buchen', description: 'Termin anfragen und dein vollständiges Geburtsdatum sowie deinen Geburtsnamen mitteilen. Axel bereitet die Beratung individuell vor.' },
  { number: '02', title: 'Vorbereitung', description: 'Axel berechnet und analysiert deine Zahlen im Vorfeld — damit die Beratungszeit vollständig für das Gespräch genutzt wird.' },
  { number: '03', title: 'Beratung', description: 'Deine Lebenszahl, deine persönlichen Zahlen, deine Themen — Axel erklärt, was die Zahlen zeigen und was du damit anfangen kannst.' },
  { number: '04', title: 'Erkenntnisse', description: 'Du gehst mit einer klaren Karte — Stärken, Themen, Anlagewege. Nicht als Vorhersage, sondern als Orientierung.' },
];

const testimonials = [
  { quote: '«Ich habe mein Numeroskop bereits dreimal gelesen und bin noch immer fasziniert. Es fühlt sich unglaublich stimmig an — immer wieder dieses: Ja, genau so ist es. Es hat mir geholfen, mich selbst besser zu verstehen und einiges mit mehr Ruhe und Klarheit zu betrachten. Von Herzen danke.»', name: 'Carmen G.' },
  { quote: '«Ich bin so berührt, ich danke dir von Herzen Axel. Diese, deine, Beschreibung fühlt sich so stimmig und gleichzeitig verheißungsvoll an - wie ein Leitstern ins Neue - schon jetzt. Und ich fühle es tatsächlich genau so, aber deine Worte haben es nochmal „runter" geholt auf den Boden, es greifbar gemacht, was ich fühle und manchmal aus Angst oder Vorsicht kaum zulassen konnte. Danke von Herzen.»', name: 'Monika S.' },
  { quote: '«Die Auswertung für meine Tochter war ein richtiges Geschenk. Endlich verstehe ich, warum sie manchmal so dickköpfig und gleichzeitig so kreativ ist. Früher hat mich das gestresst — heute reagiere ich gelassener, weil ich weiss: Es ist Teil ihrer Energie. Es ist, als hätte ich mein Kind noch einmal neu kennengelernt. Dafür bin ich unglaublich dankbar.»', name: 'Andrea G.' },
];

const faqItems = [
  { question: 'Muss ich an Numerologie glauben?', answer: 'Nein. Du musst nichts glauben. Die Numerologie ist ein Deutungssystem, das dir Orientierung und neue Perspektiven anbietet — was du daraus mitnimmst, entscheidest du selbst.' },
  { question: 'Was benötigst du für die Beratung?', answer: 'Dein vollständiges Geburtsdatum und deinen Geburtsnamen. Damit berechnet Axel deine Zahlen im Vorfeld.' },
  { question: 'Kann ich auch eine Beratung für mein Kind buchen?', answer: 'Ja. Gerade für Kinder kann die Numerologie helfen, Anlagen, Stärken und Bedürfnisse besser zu verstehen und liebevoll zu begleiten.' },
  { question: 'Kann Numerologie bei Entscheidungen helfen?', answer: 'Ja. Sie macht Lebensthemen, Stärken und Möglichkeiten sichtbar und schafft so Klarheit, wenn du vor einer wichtigen Entscheidung stehst.' },
  { question: 'Kann ich auch meine Partnerschaft analysieren lassen?', answer: 'Ja. Aus euren Zahlen lassen sich Dynamiken, Gemeinsamkeiten und Spannungsfelder ablesen — eine wertvolle Perspektive auf eure Beziehung.' },
  { question: 'Kann Numerologie die Zukunft vorhersagen?', answer: 'Nein. Numerologie ist keine Vorhersage, sondern Orientierung. Sie zeigt Muster und Möglichkeiten — gestalten tust du deinen Weg selbst.' },
];
---

<BaseLayout
  title="Numerologie-Beratung mit Axel Jansen | VitaLunaris"
  description="Numerologie-Beratung mit Axel Jansen — Orientierung über Zahlen. Präzise, ohne Esoterik-Kitsch, mit systemischem Blick auf das, was sich in deinem Leben zeigt."
  currentPath="/praxisangebote/numerologieberatung"
>
  <CourseHero
    categoryMeta="Numerologie · Lebensweg-Beratung"
    title="Numerologie mit<br /> Axel Jansen"
    description="Zahlen haben eine Sprache — Axel Jansen liest sie mit einem klaren, systemischen Blick. Dabei gehts nicht um Schicksalsvorhersagen, sondern ein tieferes Verständnis deiner Talente, Herausforderungen und aktuellen Lebensthemen. Viele erleben die Beratung als überraschend präzise und gewinnen neue Perspektiven auf sich und ihren Weg."
    durationMeta="Einzelsitzung | 90 Min. | Online oder in der Praxis"
    price="CHF 180.–"
    ctaText="Termin buchen"
    ctaHref="/kontakt"
    image="/images/placeholder/Placeholder-26.jpg"
  />

  {/* ===================== Orientierung über Zahlen (lavender gradient, image left) ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image="/images/placeholder/Placeholder-27.jpg"
    imageAlt=""
    title="Was ist Numerologie?"
    body="Numerologie ist ein Deutungssystem, das Zahlen eine symbolische Bedeutung zuordnet. Grundlage dafür sind dein Geburtsdatum und dein Name. Aus diesen Zahlen lassen sich bestimmte Muster, Potenziale, Talente und Lebensthemen ableiten, die sich oft wie ein roter Faden durch das Leben ziehen.<br/><br/>Dabei geht es nicht darum, die Zukunft vorherzusagen oder Menschen in Schubladen zu stecken. Numerologie versteht sich vielmehr als eine Art Landkarte, die Orientierung geben kann.<br/><br/>Sie kann helfen zu verstehen,<br/>• was dich antreibt<br/>• wo deine natürlichen Stärken liegen<br/>• welche Herausforderungen dich begleiten<br/>• warum bestimmte Themen immer wieder auftauchen<br/>• und welche Potenziale in dir angelegt sind"
  />

  {/* ===================== Process ===================== */}
  <ProcessSteps steps={steps} ctaText="Termin buchen" ctaHref="/kontakt" />

  {/* ===================== Testimonials ===================== */}
  <TestimonialsBlock title="Was unsere Kunden sagen" testimonials={testimonials} />

  {/* ===================== Bio ===================== */}
   <PersonBio
    eyebrow="wer dich begleitet"
    name="Axel Jansen"
    paragraphs={[
      'Für mich sind Zahlen keine Etiketten. Sie helfen mir, Menschen besser zu verstehen.vielen Jahren beschäftige ich mich intensiv mit Numerologie und den Zusammenhängen zwischen Zahlen, Persönlichkeit und Lebensweg.',
      'Was mich bis heute fasziniert: Oft zeigen Zahlen Themen, Talente und Herausforderungen auf, die Menschen tief in sich bereits kennen – aber vielleicht noch nie bewusst betrachtet haben.In meinen Beratungen geht es nicht darum, die Zukunft vorherzusagen. Vielmehr möchte ich Menschen dabei unterstützen, sich selbst besser zu verstehen und neue Perspektiven auf ihr Leben zu gewinnen.',
      ,
    ]}
    image="/images/persons/AxelJansen.jpg" 
    imageSide="right"
  />

  {/* ===================== Brand CTA ===================== */}
  <BrandCtaBlock
    title="Bereit, tiefer<br />zu gehen?"
    body="Deine Zahlen verraten mehr über dich als du denkst. Axel liest sie — klar, direkt, ohne Hokuspokus."
    ctaText="Termin buchen"
    ctaHref="/kontakt"
  />

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />

  {/* ===================== Newsletter ===================== */}
  <NewsletterBlock
    eyebrow="Newsletter"
    title="Die Magie der Zahlen <br/> – jede Woche neu"
    body="Jeden Freitag wirft Axel einen Blick auf die Zahlenqualität des kommenden Wochenendes — überraschend präzise und oft erstaunlich nah an den eigenen Erfahrungen. Ergänzt durch Impulse zu Numerologie, systemischem Denken und persönlicher Entwicklung. Wir freuen uns, wenn du dabei bist."
    placeholder="E-mail Adresse"
    submitText="Newsletter anmelden"
  />
</BaseLayout>
