---
import BaseLayout from '@layouts/BaseLayout.astro';
import CourseHero from '@organisms/CourseHero.astro';
import InfoCardsRow from '@organisms/InfoCardsRow.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import EventCard from '@molecules/EventCard.astro';
import Faq from '@organisms/Faq.astro';
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';
import { getEmDashEntry, getEmDashCollection } from 'emdash';
import { nl2br, jsonArray, imageUrl, textLines } from '@lib/cms';

/* ============================================================
   Workshop detail page — content lives in the EmDash `workshops`
   collection (editable at /_emdash/admin/content/workshops).
   Rendered on-demand by slug; the calendar + cards read the same
   collection so everything stays in sync.
   ============================================================ */
const { slug } = Astro.params;
const { entry } = await getEmDashEntry('workshops', slug!);
if (!entry) return new Response('Not found', { status: 404 });
const w: Record<string, any> = entry.data ?? {};

const bulletGroups = (w.narrative_bullet_groups ?? []).map((g: any) => ({
  heading: g.heading || undefined,
  items: textLines(g.items),
  text: g.text || undefined,
}));

/* "Weitere Kurse" grid — every other workshop, by date. */
const { entries: all } = await getEmDashCollection('workshops', { orderBy: { date: 'asc' } });
const furtherCourses = (all ?? [])
  // Exclude the current course and the two dateless overview pages.
  .filter((e: any) => e.id !== slug && e.data?.date)
  .map((e: any) => ({
    image: imageUrl(e.data?.card_image),
    eyebrow: e.data?.card_eyebrow,
    title: e.data?.card_title,
    description: e.data?.card_description,
    price: e.data?.hero_price,
    duration: e.data?.card_duration,
    ctaText: 'Mehr erfahren',
    ctaHref: `/workshops-kurse/${e.id}`,
  }));

/* Shared "Was Teilnehmer sagen" reviews — same set as the calendar page. */
const testimonials = [
  { quote: '„Numerologie Workshop – Anfangs war ich neugierig – am Ende begeistert. Plötzlich ergaben viele Verhaltensweisen viel mehr Sinn. Als Lehrerin kann ich die Numerologie sogar im Schulalltag anwenden: Die Zahlen helfen mir, Stärken und Bedürfnisse meiner Schülerinnen und Schüler besser zu verstehen. Voller Aha-Momente und ein neuer Blick auf Menschen.“', name: 'Marianne S.' },
  { quote: '„Ich bin ohne grosse Erwartungen in den Numerologie Workshop gekommen und wurde definitiv übertroffen. Der Workshop war klar strukturiert, verständlich und mit viel Herz gestaltet. Besonders das liebevoll gestaltete Workbook hat mich begeistert. Vielen Dank für diesen inspirierenden Tag!“', name: 'Marina C.' },
  { quote: '„Ich bin noch immer erstaunt, wie viel Kraft hinter dieser einfachen Klopftechnik steckt. Der Kurs war informativ, abwechslungsreich und die Zeit verging wie im Flug. Besonders wertvoll: Ich habe ein Werkzeug, das ich jederzeit anwenden kann. Herzlichen Dank für diesen praxisnahen Kurs!“', name: 'Sandra M.' },
  { quote: '„SoulReset@home hat mich begeistert. Die Atemübungen und das Tapping helfen mir konkret, wenn Druck entsteht. Ich merke, dass ich im Familienalltag ruhiger bin und weniger Druck verspüre. Viele praktische Werkzeuge, die sich leicht umsetzen lassen. Herzlichen Dank!“', name: 'Desiree Z.' },
];

/* Shared FAQ. */
const faqItems = [
  { question: 'Für wen sind die Workshops geeignet?', answer: 'Für alle, die systemische Arbeit erleben möchten — ob als Einstieg, zur Vertiefung oder einfach aus Neugier. Vorwissen ist nicht nötig.' },
  { question: 'Was ist der Unterschied zwischen einem Workshop und der Ausbildung?', answer: 'Ein Workshop ist ein einzelnes, in sich geschlossenes Erlebnis. Die Ausbildung ist ein aufeinander aufbauender, längerer Weg mit Abschluss.' },
  { question: 'Brauche ich Vorkenntnisse für die Monats-Workshops?', answer: 'Nein. Die Workshops sind so gestaltet, dass du jederzeit einsteigen kannst — mit oder ohne Vorerfahrung.' },
  { question: 'Wie melde ich mich an?', answer: 'Du klickst auf «Jetzt anmelden», füllst das kurze Formular aus und erhältst alle Infos sowie den Zoom-Link per E-Mail.' },
  { question: 'Werden die Kosten von der Krankenkasse übernommen?', answer: 'Workshops sind in der Regel keine kassenpflichtige Leistung — manche Zusatzversicherungen unterstützen Bildungsangebote, frag im Einzelfall nach.' },
  { question: 'Kann ich einen Workshop stornieren?', answer: 'Ja, bis zu einer bestimmten Frist vor Beginn. Die genauen Bedingungen findest du in der Anmeldebestätigung.' },
  { question: 'Gibt es auch Online-Formate?', answer: 'Ja. Dieser Workshop findet online via Zoom statt — den Link bekommst du nach der Anmeldung per E-Mail.' },
  { question: 'Was passiert wenn ein Workshop ausgebucht ist?', answer: 'Du kannst dich auf die Warteliste setzen. Wird ein Platz frei oder kommt ein Zusatztermin, informieren wir dich zuerst.' },
];
---

<BaseLayout
  title={`${w.card_title || w.title} | VitaLunaris`}
  description={w.hero_description}
  currentPath={`/workshops-kurse/${slug}`}
>
  <CourseHero
    categoryMeta={w.category_meta}
    durationMeta={w.duration_meta}
    title={w.title}
    description={w.hero_description}
    price={w.hero_price}
    ctaText="Jetzt anmelden"
    ctaHref={w.hero_cta_href || '/kontakt'}
    image={imageUrl(w.hero_image)}
  />

  <InfoCardsRow cards={w.info_cards ?? []} />

  {/* ===================== Was wir anschauen — lavender ===================== */}
  <NarrativeBlock
    tone="lavender-gradient"
    imageSide="left"
    image={imageUrl(w.narrative_image)}
    imageAlt=""
    eyebrow="Was wir anschauen"
    title={w.narrative_title}
    bulletGroups={bulletGroups}
    body={nl2br(w.narrative_body)}
  />

  {/* ===================== Was Teilnehmer sagen ===================== */}
  <TestimonialsBlock
    title="Was Teilnehmer sagen"
    testimonials={testimonials}
    tone={w.testimonials_tone || 'gold'}
  />

  {/* ===================== Theresia & Axel Jansen — light, image right ===================== */}
  <section class="about">
    <div class="about__inner">
      <div class="about__content">
        <Heading level={2} variant="h1" class="about__name">Theresia &<br /><em>Axel Jansen</em></Heading>
        <Text size="p1" class="about__body">
          Theresia Jansen begleitet seit über 30 Jahren Menschen zu mehr Klarheit und Veränderung – gestützt auf umfangreiche Ausbildungen und jahrzehntelange Praxiserfahrung. Axel Jansen bringt Hypnose, Numerologie und einen präzisen Blick für Zusammenhänge ein – humorvoll und geerdet.
        </Text>
        <Text size="p1" class="about__body">
          Als Ehepaar und Team ergänzen sich ihre Stärken auf natürliche Weise. Was sie verbindet: die Überzeugung, dass Veränderung dort beginnt, wo Menschen sich gesehen und sicher fühlen. So entstehen Räume für Erkenntnis und neue Perspektiven – ehrlich, menschlich, mit echter Lebenserfahrung.
        </Text>
        <div class="about__cta">
          <Button href="/ueber-uns" variant="primary" size="lg">Mehr über uns</Button>
        </div>
      </div>
      <div class="about__media">
        <img src={imageUrl(w.about_image) || '/images/placeholder/placeholder-4.jpg'} alt="Theresia & Axel Jansen" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  {/* ===================== Weitere Kurse und Workshops — dark ===================== */}
  <section class="further">
    <div class="further__inner">
      <Heading level={2} variant="h1" class="further__title">Weitere Kurse und Workshops:</Heading>
      <div class="further__grid">
        {furtherCourses.map((e) => <EventCard {...e} />)}
      </div>
    </div>
  </section>

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />
</BaseLayout>

<style>
  /* Info cards — body text in full black per design */
  :global(.info-cards .info-cards__body) {
    color: #000000;
  }

  /* ============================================================
     ABOUT — "Theresia & Axel Jansen" (Spring Wood, text left / image right)
     ============================================================ */
  .about { background: var(--c-spring-wood); padding: 60px 20px; }
  @media (min-width: 768px)  { .about { padding: 80px 32px; } }
  @media (min-width: 1280px) { .about { padding: 90px 60px; } }
  @media (min-width: 1920px) { .about { padding: 90px; } }

  .about__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 1740px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) { .about__inner { flex-direction: row; align-items: center; gap: 64px; } }
  @media (min-width: 1920px) { .about__inner { gap: 100px; } }

  .about__media {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-card-sm);
    background: rgba(96, 29, 29, 0.06);
    aspect-ratio: 4 / 5;
    order: -1;
  }
  @media (min-width: 1024px) { .about__media { width: 46%; border-radius: var(--radius-card); order: 0; } }
  @media (min-width: 1920px) { .about__media { width: 711px; border-radius: var(--radius-card-lg); aspect-ratio: 711 / 826; } }
  .about__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .about__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
  }
  @media (min-width: 1024px) { .about__content { gap: 26.67px; } }
  @media (min-width: 1920px) { .about__content { gap: 32px; max-width: 813px; } }

  .about__name {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }
  .about__name :global(em) { font-style: italic; }
  .about__body { color: var(--c-cherrywood); font-size: var(--p1-size); line-height: 1.5; }
  .about__cta { margin-top: 8px; }

  /* ============================================================
     FURTHER — "Weitere Kurse und Workshops:" (Cherrywood, 3 cards)
     ============================================================ */
  .further { background: var(--c-cherrywood); padding: 60px 20px; }
  @media (min-width: 768px)  { .further { padding: 80px 32px; } }
  @media (min-width: 1280px) { .further { padding: 90px 60px; } }
  @media (min-width: 1920px) { .further { padding: 120px 90px; } }

  .further__inner {
    max-width: 1740px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  @media (min-width: 1920px) { .further__inner { gap: 64px; } }

  .further__title {
    color: var(--c-spring-wood);
    text-align: center;
    margin: 0;
    max-width: 862px;
  }

  .further__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    width: 100%;
  }
  @media (min-width: 640px)  { .further__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
  @media (min-width: 1024px) { .further__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
</style>
