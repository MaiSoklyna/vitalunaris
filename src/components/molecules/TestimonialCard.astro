---
interface Props {
  icon?: string;
  quote: string;
  name: string;
  rating?: number;
}

const {
  quote,
  name,
  rating = 5,
} = Astro.props;

const stars = Array.from({ length: rating });
---

<article class="t-card">
  <div class="t-card__inner">
    <div class="t-card__stars" aria-label={`${rating} von 5 Sternen`}>
      {stars.map(() => (
        <svg class="t-card__star" viewBox="0 0 32 31" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M16 0 L19.6 10.4 L30.7 10.7 L21.8 17.4 L25 28.1 L16 21.8 L7 28.1 L10.2 17.4 L1.3 10.7 L12.4 10.4 Z"
            fill="#601D1D"
          />
        </svg>
      ))}
    </div>

    <p class="t-card__quote">{quote}</p>

    <div class="t-card__author">
      <span class="t-card__name">{name}</span>
    </div>
  </div>
</article>

<style>
  /* ============================================================
     TESTIMONIAL CARD — Figma Desktop+:
     - 418.5×478, white, radius 25, padding 40, inner gap 30, width 338.5
     - Stars: 5x #EC9F27, ~32×31 each, row gap ~7.35
     - Quote: P1 23/150 black
     - Author row gap 20: 48×48 #FFD869 circle with initial, then name P1
     Scales down across breakpoints.
     ============================================================ */
  .t-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    background: var(--c-white);
    border: 0.8px solid var(--c-cherrywood);
    border-radius: var(--radius-card-sm);
    padding: 24px;
    /* No explicit height — `align-items: stretch` on the track equalizes
       every card to the tallest one. Setting height:100% here would resolve
       to content height and defeat the stretch (cards ended up uneven). */
    min-height: 320px;
  }
  @media (min-width: 1024px) { .t-card { padding: 32px; min-height: 480px; border-radius: var(--radius-card); border-width: 1px; } }
  @media (min-width: 1920px) { .t-card { padding: 40px; min-height: 625.85px; border-radius: var(--radius-card-lg); border-width: 1.25px; } }

  .t-card__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    width: 100%;
    flex: 1 1 auto;
  }
  @media (min-width: 1024px) { .t-card__inner { gap: 24px; } }
  @media (min-width: 1920px) { .t-card__inner { gap: 30px; } }

  /* ----- stars ----- */
  .t-card__stars {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
  }
  @media (min-width: 1920px) { .t-card__stars { gap: 7.35px; } }

  .t-card__star {
    width: 20px;
    height: 19px;
    flex: 0 0 auto;
  }
  @media (min-width: 1024px) { .t-card__star { width: 26px; height: 25px; } }
  @media (min-width: 1920px) { .t-card__star { width: 32.32px; height: 30.85px; } }

  /* ----- quote (P1 black) ----- */
  .t-card__quote {
    margin: 0;
    color: var(--c-black);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    align-self: stretch;
  }

  /* ----- author row (pinned to the bottom of every card) ----- */
  .t-card__author {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    align-self: stretch;
    width: 100%;
    margin-top: auto;
  }
  @media (min-width: 1920px) { .t-card__author { gap: 20px; } }

  .t-card__name {
    color: var(--c-black);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
  }
</style>
