---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import TestimonialCard from '@molecules/TestimonialCard.astro';

interface Testimonial {
  icon?: string;
  quote: string;
  name: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  testimonials: Testimonial[];
  /** Background gradient of the block. Editors pick this in the admin. */
  tone?: 'gold' | 'spring-wood' | 'purple' | 'cherrywood' | string;
}

const { eyebrow, title, intro, testimonials, tone } = Astro.props;

// Normalize tone (incl. aliases from the shared `sections.tone` select) to one of
// the four background variants. Unknown/empty → 'gold' (the original default).
const TONE_ALIASES: Record<string, 'gold' | 'spring-wood' | 'purple' | 'cherrywood'> = {
  gold: 'gold', 'pale-gold': 'gold',
  'spring-wood': 'spring-wood', light: 'spring-wood',
  purple: 'purple', lavender: 'purple',
  cherrywood: 'cherrywood', dark: 'cherrywood',
};
const toneClass = TONE_ALIASES[tone ?? ''] ?? 'gold';
---

<section class={`t-block t-block--${toneClass}`}>
  <div class="t-block__inner max-w-layout container-x">
    <header class="t-block__header">
      {eyebrow && <Heading variant="eyebrow" class="t-block__eyebrow">{eyebrow}</Heading>}
      <Heading level={2} variant="h1" class="t-block__title">{title}</Heading>
      {intro && <Text size="p1" class="t-block__intro">{intro}</Text>}
    </header>

    <div class="t-block__carousel" data-t-carousel>
      <div class="t-block__track" data-t-track>
        {testimonials.map((t) => <TestimonialCard {...t} />)}
      </div>

      <button
        type="button"
        class="t-block__nav t-block__prev"
        data-t-prev
        aria-label="Vorherige Stimmen anzeigen"
      >
        <img src="/images/symbol/Button.svg" alt="" width="80" height="80" aria-hidden="true" />
      </button>

      <button
        type="button"
        class="t-block__nav t-block__next"
        data-t-next
        aria-label="Weitere Stimmen anzeigen"
      >
        <img src="/images/symbol/Button.svg" alt="" width="80" height="80" aria-hidden="true" />
      </button>
    </div>
  </div>
</section>

<script>
  function initTestimonialCarousel() {
    document.querySelectorAll('[data-t-carousel]').forEach((root) => {
      const track = root.querySelector('[data-t-track]');
      const next = root.querySelector('[data-t-next]');
      const prev = root.querySelector('[data-t-prev]');
      if (!track || !next || next.dataset.bound) return;
      next.dataset.bound = 'true';

      const stepSize = () => {
        const card = track.querySelector('.t-card');
        const gap = parseFloat(getComputedStyle(track).columnGap) || 0;
        return card ? card.offsetWidth + gap : track.clientWidth;
      };

      next.addEventListener('click', () => {
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 4;
        if (atEnd) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: stepSize(), behavior: 'smooth' });
        }
      });

      prev?.addEventListener('click', () => {
        const atStart = track.scrollLeft <= 4;
        if (atStart) {
          track.scrollTo({ left: track.scrollWidth, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: -stepSize(), behavior: 'smooth' });
        }
      });
    });
  }

  initTestimonialCarousel();
  document.addEventListener('astro:page-load', initTestimonialCarousel);
</script>

<style>
  /* ============================================================
     TESTIMONIALS — Figma Narrative Block 4 spec (Desktop+):
     gradient Spring Wood → Pale Gold, padding 90px, gap 90px
     Header centered, H1 90/110, max-width 862, gap 40
     4 white cards in a row, gap 22, radius 25, padding 40
     ============================================================ */
  .t-block {
    background: var(--gradient-spring-gold);
    padding: 60px 20px;
    display: flex;
    flex-direction: column;
  }
  /* Selectable background gradients (editor picks the tone in the admin). */
  .t-block--gold        { background: var(--gradient-spring-gold); }
  .t-block--spring-wood { background: var(--gradient-spring-wood); }
  .t-block--purple      { background: var(--gradient-lavender); }
  .t-block--cherrywood  { background: var(--gradient-cherrywood); }
  /* Dark background needs light header text (the white cards stay unchanged). */
  .t-block--cherrywood .t-block__eyebrow,
  .t-block--cherrywood .t-block__title,
  .t-block--cherrywood .t-block__intro { color: var(--c-spring-wood); }
  @media (min-width: 768px)  { .t-block { padding: 60px 32px; } }
  @media (min-width: 1024px) { .t-block { padding: 80px 40px; } }
  @media (min-width: 1280px) { .t-block { padding: 90px 60px; } }
  @media (min-width: 1920px) { .t-block { padding: 90px; } }

  .t-block__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
    max-width: 1740px;
    margin: 0 auto;
    width: 100%;
  }
  @media (min-width: 1024px) { .t-block__inner { gap: 64px; } }
  @media (min-width: 1280px) {
    .t-block__inner {
      gap: 80px;
      max-width: none;
      padding-left: 0;
      padding-right: 0;
    }
  }
  @media (min-width: 1920px) { .t-block__inner { gap: 64px; max-width: none; padding-left: 0; padding-right: 0; } }

  .t-block__header {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 26.67px;
    max-width: 574.67px;
    text-align: center;
    margin: 0 auto;
  }
  @media (min-width: 1280px) { .t-block__header { gap: 32px; max-width: 862px; } }
  @media (min-width: 1920px) { .t-block__header { gap: 40px; max-width: 862px; } }

  .t-block__eyebrow {
    color: var(--c-cherrywood);
    text-align: center;
    align-self: stretch;
  }
  .t-block__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    text-align: center;
    align-self: stretch;
    margin: 0;
  }

  .t-block__intro {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    text-align: center;
    align-self: stretch;
  }

  /* ----- carousel ----- */
  .t-block__carousel {
    position: relative;
    width: 100%;
  }

  /* horizontal scroll track: cards scroll left → right, snap into place */
  .t-block__track {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 16px;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    /* leave room so the floating next button never sits on top of text */
    padding-bottom: 4px;
    scrollbar-width: none;            /* Firefox */
    -ms-overflow-style: none;         /* IE/Edge */
  }
  .t-block__track::-webkit-scrollbar { display: none; } /* Chrome/Safari */
  @media (min-width: 640px)  { .t-block__track { gap: 18px; } }
  @media (min-width: 1920px) { .t-block__track { gap: 22px; } }

  /* each card is a fixed-width, non-shrinking slide.
     Figma w=1920: content area 1740px holds ~3 cards of 576.5px (gap 22).
     => show 1 (peek) on phones, 2 on small tablets, 3 from 1024px up. */
  .t-block__track > :global(.t-card) {
    flex: 0 0 86%;
    scroll-snap-align: start;
  }
  @media (min-width: 640px)  { .t-block__track > :global(.t-card) { flex: 0 0 calc((100% - 18px) / 2); } }
  @media (min-width: 1024px) { .t-block__track > :global(.t-card) { flex: 0 0 calc((100% - 2 * 18px) / 3); } }
  @media (min-width: 1920px) { .t-block__track > :global(.t-card) { flex: 0 0 calc((100% - 2 * 22px) / 3); } }

  /* ----- nav buttons (circular cherrywood arrow — SVG from Figma) ----- */
  .t-block__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: block;
    width: 56px;
    height: 56px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-pill);
    box-shadow: 0 6px 20px rgba(96, 29, 29, 0.25);
    transition: transform 0.2s ease;
    z-index: 2;
  }
  .t-block__next { right: 4px; }
  .t-block__prev { left: 4px; }
  /* the SVG points right; mirror it for the "back" button */
  .t-block__prev img { transform: scaleX(-1); }
  .t-block__nav img {
    display: block;
    width: 100%;
    height: 100%;
  }
  .t-block__nav:hover { transform: translateY(-50%) scale(1.06); }
  .t-block__nav:active { transform: translateY(-50%) scale(0.96); }
  .t-block__nav:focus-visible { outline: 2px solid var(--c-cherrywood); outline-offset: 3px; }
  @media (min-width: 1024px) {
    .t-block__nav { width: 64px; height: 64px; }
    .t-block__next { right: 8px; }
    .t-block__prev { left: 8px; }
  }
  @media (min-width: 1920px) { .t-block__nav { width: 80px; height: 80px; } }
</style>
