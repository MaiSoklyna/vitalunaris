---
import '@/styles/global.css';
import Navigation from '@organisms/Navigation.astro';
import Footer from '@organisms/Footer.astro';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'VitaLunaris — Erforsche die Systeme der Seele.',
  currentPath = Astro.url.pathname,
  ogImage = '/logo/logo.svg',
  noindex = false,
} = Astro.props;

const siteBase = (Astro.site ?? new URL('https://vitalunaris.ch')).toString().replace(/\/$/, '');
const canonical = new URL(currentPath, siteBase + '/').toString();
const ogImageAbs = new URL(ogImage, siteBase + '/').toString();

// Site-wide organization / local-business structured data (helps Google + AI engines).
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': siteBase + '/#organization',
  name: 'VitaLunaris',
  description:
    'Systemische Praxis und Ausbildung von Theresia & Axel Jansen in Buchs SG: systemisches Aufstellen, Hypnose, Numerologie, Fussreflexzonenmassage und die Ausbildung zum Systemic Soulcoach.',
  url: siteBase + '/',
  email: 'info@vitalunaris.ch',
  telephone: '+41792917402',
  image: siteBase + '/logo/logo.svg',
  logo: siteBase + '/logo/logo.svg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Eichenaustrasse 32',
    postalCode: '9470',
    addressLocality: 'Buchs',
    addressRegion: 'SG',
    addressCountry: 'CH',
  },
  areaServed: 'CH',
  founder: [
    { '@type': 'Person', name: 'Theresia Jansen' },
    { '@type': 'Person', name: 'Axel Jansen' },
  ],
  sameAs: [
    'https://www.facebook.com/JansenBuchs/',
    'https://www.instagram.com/vitalunaris_by_jansen/',
  ],
};

// Alchemy Scribe — first-party analytics; also drives auto-resize of embedded Alchemy form iframes.
const trackingApiUrl = import.meta.env.PUBLIC_TRACKING_API_URL || 'https://opus.alchemy.zuerich';
const trackingSiteId = import.meta.env.PUBLIC_TRACKING_SITE_ID || 'site_vitalunaris';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VitaLunaris" />
    <meta property="og:locale" content="de_CH" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Structured data: organization / local business -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo/logo-compact.svg" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/ESPark-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Preconnect to Alchemy (tracking + embedded forms) -->
    <link rel="preconnect" href="https://opus.alchemy.zuerich" />

    <!-- Alchemy Scribe — analytics + embedded-form iframe auto-resize -->
    <script define:vars={{ trackingApiUrl, trackingSiteId }}>
      (function (w, d, s, l) {
        w[l] = w[l] || [];
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s);
        j.async = true;
        j.src = trackingApiUrl + '/static/scribe.js';
        j.setAttribute('data-site-id', trackingSiteId);
        j.setAttribute('data-api-url', trackingApiUrl);
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'AlchemyScribe');
    </script>
  </head>
  <body>
    <Navigation currentPath={currentPath} />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
