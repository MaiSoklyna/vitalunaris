---
import BaseLayout from '@layouts/BaseLayout.astro';
import CourseHero from '@organisms/CourseHero.astro';
import NarrativeBlock from '@organisms/NarrativeBlock.astro';
import ProcessSteps from '@organisms/ProcessSteps.astro';
import TestimonialsBlock from '@organisms/TestimonialsBlock.astro';
import PersonBio from '@organisms/PersonBio.astro';
import BrandCtaBlock from '@organisms/BrandCtaBlock.astro';
import Faq from '@organisms/Faq.astro';
import NewsletterBlock from '@organisms/NewsletterBlock.astro';
import { getEmDashEntry } from 'emdash';
import { nl2br, jsonArray, imageUrl, getTestimonials, textLines } from '@lib/cms';

// ── CMS: editable at /_emdash/admin (falls back to original copy) ──────────
const { entry } = await getEmDashEntry('praxisangebote', 'fussreflexzonenbehandlung');
const d: Record<string, any> = entry?.data ?? {};
const { entry: person } = await getEmDashEntry('team', d.practitioner || 'marlen-berger');
const pd: Record<string, any> = person?.data ?? {};

const bookingUrl = d.hero_cta_href || 'https://app.healthadvisor.ch/bookings/c815b59850574ec9b9a5f3533b6af7ab';

const steps = d.process_steps?.length ? d.process_steps : [
  { number: '01', title: 'Buchen', description: 'Termin anfragen per Kontaktformular oder E-Mail. Behandlungen finden ausschliesslich in Präsenz statt.' },
  { number: '02', title: 'Ankommen', description: 'Kurzes Erstgespräch: Wie geht es dir? Was beschäftigt dich? Marlen stimmt die Behandlung auf dein aktuelles Befinden ab.' },
  { number: '03', title: 'Behandlung', description: 'Tiefe Entspannung durch gezielte Reflexzonenmassage. Marlen arbeitet intuitiv und präzise — dein Körper zeigt, was er braucht.' },
  { number: '04', title: 'Nachruhen', description: 'Nach der Behandlung kurz zur Ruhe kommen. Viel Wasser trinken — der Körper braucht Zeit, um das Erlebte zu integrieren.' },
];

const bulletGroups = d.narrative_bullet_groups?.length
  ? d.narrative_bullet_groups.map((g: any) => ({
      heading: g.heading || undefined,
      items: textLines(g.items),
      text: g.text || undefined,
    }))
  : [
      { items: [
        'Reflexologie nach Schwester Jeannine und Pater Eugster',
        'Fussreflexzonen-Therapie nach Marquardt',
        'Fussbehandlung nach Pater Eugster',
        'Lymphaktivierung über die Reflexzonen am Fuss',
      ] },
      { text: 'Das Ziel: Körperliche Beschwerden sanft zu beheben oder zu lindern, ein besseres inneres Gleichgewicht und die Unterstützung des natürlichen Wohlbefindens.' },
    ];

const _ts = await getTestimonials('praxis-fussreflex');
const testimonials = _ts.length ? _ts : [
  { quote: '„Eine wunderbare Behandlung und eine rundum positive Erfahrung. Marlen arbeitet mit viel Herz, Feingefühl und Achtsamkeit. Man fühlt sich sofort wohl und gut aufgehoben. Von Herzen danke.“', name: 'Susanna H.' },
  { quote: '„Die Behandlung war unglaublich wohltuend. Nach dem Termin fühlte ich mich leichter, ruhiger und gleichzeitig voller Energie. Eine wunderbare Erfahrung.“', name: 'Ursula B.' },
  { quote: '„Als ausgebildete Fussreflexzonentherapeutin hat mich Marlens Behandlung zutiefst überrascht — deutlich intensiver und tiefgründiger, besonders die Arbeit nach TCM-Prinzipien.“', name: 'Theresia Jansen' },
  { quote: '„Nach wenigen Behandlungen wurde ich endlich frei von meinen schmerzhaften Nierensteinen. Vielen Dank.“', name: 'Erika N.' },
];

const faqItems = d.faq_items?.length ? d.faq_items : [
  { question: 'Für wen eignet sich die Fussreflexzonen-Therapie?', answer: 'Für alle, die tiefe Entspannung, energetische Balance und Regeneration suchen. Bei bestimmten Vorerkrankungen klären wir das vorab im Gespräch.' },
  { question: 'Ist die Behandlung schmerzhaft?', answer: 'Nein. Die Behandlung ist sanft und wohltuend. Marlen passt den Druck jederzeit deinem Empfinden an.' },
  { question: 'Was ist der Unterschied zur klassischen Fussmassage?', answer: 'Die Reflexologie spricht über die Reflexzonen gezielt Organe, Drüsen sowie das Nerven- und Lymphsystem an und arbeitet zusätzlich nach TCM-Prinzipien.' },
  { question: 'Was macht Marlens Behandlung besonders?', answer: 'Marlen verbindet mehrere Methoden — Reflexologie nach Schwester Jeannine, Fussreflexzonen-Therapie nach Marquardt und Lymphaktivierung — zu einer ganzheitlichen Behandlung.' },
  { question: 'Wie viele Behandlungen sind sinnvoll?', answer: 'Das ist individuell. Manche kommen einmalig zur Erholung, andere regelmässig zur Begleitung — gemeinsam finden wir deinen Rhythmus.' },
  { question: 'Muss ich etwas Spezielles zur Behandlung mitbringen?', answer: 'Nein. Komm einfach so, wie du bist. Plane nach der Behandlung etwas Zeit zum Nachruhen ein und trinke danach ausreichend Wasser.' },
];

const bioParagraphs = pd.bio_paragraphs?.length
  ? pd.bio_paragraphs.map((p: any) => p.text)
  : [
      'Die Faszination für die Reflexologie begleitet mich schon seit vielen Jahren. Mich begeistert, wie viel sich über die Füsse erreichen lässt.',
      'Besonders berührt mich immer wieder, wenn Entspannung, Wohlbefinden und neue Energie spürbar werden und körperliche Beschwerden sanft gelöst werden.',
      'In meiner Arbeit verbinde ich verschiedene Methoden der Reflexologie, darunter die Reflexologie nach Schwester Jeannine und die klassische Fussreflexzonen-Therapie.',
      'Mir ist wichtig, dass du dich während der Behandlung wohl, gesehen und gut aufgehoben fühlst.',
    ];
---

<BaseLayout
  title={d.seo_title || 'Fussreflexzonenmassage bei Marlen Berger | VitaLunaris'}
  description={d.seo_description || 'Fussreflexzonenmassage bei Marlen Berger — ganzheitliche Behandlung über die Reflexzonen der Füsse für tiefe Entspannung und energetische Balance.'}
  currentPath="/praxisangebote/fussreflexzonenbehandlung"
>
  <CourseHero
    categoryMeta={d.hero_category || 'Körperarbeit | Fussreflexzonenmassage'}
    title={d.hero_title || 'Fussreflexzonenmassage<br />bei Marlen Berger'}
    description={d.hero_description || 'Die Füsse sind eine Landkarte des Körpers. Über ihre Reflexzonen lassen sich Organe, Drüsen und das Nervensystem erreichen — für tiefe Entspannung, energetische Balance und ganzheitliche Regeneration.'}
    durationMeta={d.hero_duration || '60 Min.'}
    price={d.hero_price || 'CHF 140.–'}
    note={d.hero_note || '75 Min. · CHF 175.–'}
    ctaText={d.hero_cta_text || 'Termin anfragen'}
    ctaHref={bookingUrl}
    image={imageUrl(d.hero_image) || '/images/placeholder/Placeholder-34.jpg'}
  />

  {/* ===================== Wie sie wirkt (image left, bullet groups) ===================== */}
  <NarrativeBlock
    tone="light"
    imageSide="left"
    image={imageUrl(d.narrative_image) || '/images/placeholder/placeholder-2.jpg'}
    imageAlt=""
    title={d.narrative_title || 'Reflexologie – mehr als klassische Fussmassage'}
    body={nl2br(d.narrative_body) || 'Die Reflexologie verbindet das Wissen der klassischen Fussreflexzonen-Therapie mit den Grundlagen der Traditionellen Chinesischen Medizin (TCM) und betrachtet den Menschen als Ganzes.'}
    bulletGroups={bulletGroups}
  />

  {/* ===================== Process ===================== */}
  <ProcessSteps steps={steps} ctaText="Termin anfragen" ctaHref={bookingUrl} />

  {/* ===================== Lavender quote ===================== */}
  <NarrativeBlock
    tone="purple"
    imageSide="right"
    image={imageUrl(d.quote_image) || '/images/placeholder/Placeholder-36.jpg'}
    imageAlt=""
    title={d.quote_text || '„Unsere Füsse tragen uns täglich durchs Leben und verdienen mehr Aufmerksamkeit, als wir ihnen oft schenken. Manchmal beginnt Veränderung dort, wo wir uns bewusst Zeit für uns selbst nehmen.”'}
    body={d.quote_attribution || 'Marlen Berger'}
  />

  {/* ===================== Testimonials ===================== */}
  <TestimonialsBlock title="Was Kundinnen sagen" testimonials={testimonials} />

  {/* ===================== Bio ===================== */}
  <PersonBio
    eyebrow={pd.eyebrow || 'Wer dich begleitet'}
    name={pd.name || 'Marlen Berger'}
    paragraphs={bioParagraphs}
    image={imageUrl(pd.image) || '/images/persons/MarlenBerger.jpg'}
    imageSide="right"
  />

  {/* ===================== Brand CTA ===================== */}
  <BrandCtaBlock
    title={d.brand_cta_title || 'Bereit, tiefer<br />zu gehen?'}
    body={d.brand_cta_body || 'Gönne dir eine Behandlung, die wirklich tief wirkt — körperlich, energetisch, ganzheitlich. Marlen ist da.'}
    ctaText={d.brand_cta_text || 'Termin anfragen'}
    ctaHref={d.brand_cta_href || bookingUrl}
  />

  {/* ===================== FAQ ===================== */}
  <Faq title="FAQ" items={faqItems} />

  {/* ===================== Newsletter ===================== */}
  <NewsletterBlock
    eyebrow="Newsletter"
    title="Von Herzen empfohlen"
    body="Als begeisterte Leserin freue ich mich jede Woche auf den VitaLunaris-Newsletter. Besonders liebe ich die Mischung aus persönlichen Geschichten, wertvollen Impulsen und Axels Zahlenmagie für das Wochenende.<br /><br />Oft genügt ein einziger Gedanke, um etwas in Bewegung zu bringen."
    placeholder="E-Mail Adresse"
    submitText="Kostenlos anmelden"
  />
</BaseLayout>
