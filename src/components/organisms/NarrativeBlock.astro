---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

type Tone = 'light' | 'purple' | 'gold' | 'lavender-gradient';
type ImageSide = 'left' | 'right';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  /** Optional bullet list rendered between body and attribution. */
  bullets?: string[];
  /** Optional grouped content (each with a subheading) rendered after body.
      A group renders as a bullet list (`items`) or a plain inline line (`text`). */
  bulletGroups?: { heading?: string; items?: string[]; text?: string }[];
  image?: string;
  imageAlt?: string;
  imageSide?: ImageSide;
  tone?: Tone;
  attribution?: string;
  /** CSS aspect-ratio for the media (e.g. "4/5", "16/10", "4/3"). Default portrait 4/5. */
  mediaAspect?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  eyebrow,
  title,
  body,
  bullets,
  bulletGroups,
  image,
  imageAlt = '',
  imageSide = 'left',
  tone = 'light',
  attribution,
  mediaAspect = '4 / 5',
  ctaText,
  ctaHref,
} = Astro.props;
---

<section class={`narrative narrative--${tone} narrative--image-${imageSide}`}>
  <div class="narrative__inner max-w-layout container-x">
    {image && (
      <div class="narrative__media" style={`aspect-ratio: ${mediaAspect};`}>
        <img src={image} alt={imageAlt} class="narrative__image" />
      </div>
    )}
    <div class="narrative__content">
      {eyebrow && <Heading variant="eyebrow" class="narrative__eyebrow">{eyebrow}</Heading>}
      <Heading level={2} variant="h1" class="narrative__title">
        <Fragment set:html={title} />
      </Heading>
      {bullets && bullets.length > 0 && (
        <ul class="narrative__list">
          {bullets.map((item) => (
            <li class="narrative__list-item"><Fragment set:html={item} /></li>
          ))}
        </ul>
      )}
      {body && <Text size="p1" class="narrative__body"><Fragment set:html={body} /></Text>}
      {bulletGroups && bulletGroups.length > 0 && (
        <div class="narrative__groups">
          {bulletGroups.map((group) => (
            <div class="narrative__group">
              {group.heading && <Text size="p1" class="narrative__group-heading">{group.heading}</Text>}
              {group.items && group.items.length > 0 && (
                <ul class="narrative__list">
                  {group.items.map((item) => (
                    <li class="narrative__list-item"><Fragment set:html={item} /></li>
                  ))}
                </ul>
              )}
              {group.text && <Text size="p1" class="narrative__group-text"><Fragment set:html={group.text} /></Text>}
            </div>
          ))}
        </div>
      )}
      {attribution && <Text size="p2" class="narrative__attribution">{attribution}</Text>}
      {ctaText && ctaHref && (
        <div class="narrative__cta">
          <Button href={ctaHref} variant="primary" size="lg">{ctaText}</Button>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .narrative { padding: 64px 0; }
  @media (min-width: 768px) { .narrative { padding: 96px 0; } }
  @media (min-width: 1024px) { .narrative { padding: 120px 0; } }

  .narrative--light { background: var(--c-spring-wood); color: var(--c-cherrywood); }
  .narrative--purple { background: var(--c-lavender); color: var(--c-white); }
  .narrative--gold { background: var(--c-pale-gold); color: var(--c-cherrywood); }

  /* ============================================================
     Purple + image-right — text overlays image, white on lavender
     Mobile (360): stacked column, text on top, white card image below
     Tablet (768): image full-bleed background, text overlay top-left
     Desktop (1280+): same overlay pattern, larger type
     ============================================================ */
  .narrative--purple.narrative--image-right { padding: 0; }
  .narrative--purple.narrative--image-right .narrative__inner {
    position: relative;
    display: block;
    padding: 40px 20px;
    gap: 0;
    max-width: none;
    overflow: hidden;
  }
  .narrative--purple.narrative--image-right .narrative__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
    color: var(--c-white);
  }
  .narrative--purple.narrative--image-right .narrative__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h2-size);
    line-height: 1.15;
    color: var(--c-white);
    margin: 0;
    align-self: stretch;
  }
  .narrative--purple.narrative--image-right .narrative__body {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    color: var(--c-white);
    opacity: 1;
    max-width: none;
  }
  .narrative--purple.narrative--image-right .narrative__media {
    position: relative;
    z-index: 1;
    aspect-ratio: auto;
    height: 332px;
    width: 100%;
    border-radius: 16.67px;
    margin-top: 20px;
    overflow: hidden;
  }
  .narrative--purple.narrative--image-right .narrative__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9);
  }

  @media (min-width: 768px) {
    .narrative--purple.narrative--image-right .narrative__inner {
      padding: 60px 46px;
      /* Height tracks the image so it sits bottom-right like the 1920 spec
         (1080/1920 = 720/1280 = 56.25%) instead of leaving empty space below. */
      min-height: 56.25vw;
    }
    .narrative--purple.narrative--image-right .narrative__content {
      position: relative;
      z-index: 2;
      gap: 26.67px;
      max-width: 684px;
    }
    /* Image size + position as exact fractions of the viewport. The Figma 1280
       and 1920 specs are proportionally identical, so these vw values render a
       scaled copy of the 1920 layout at EVERY width ≥768 and resolve to the exact
       1920 pixels at w=1920 — a seamless handoff with no frozen mid-range. */
    .narrative--purple.narrative--image-right .narrative__media {
      position: absolute;
      z-index: 1;
      top: 16.5516vw;    /* 211.86 @ 1280 · 317.79 @ 1920 */
      left: 43.125vw;    /* 552 @ 1280 · 828 @ 1920 */
      right: auto;
      width: 51.5625vw;  /* 660 @ 1280 · 990 @ 1920 */
      height: 32.1354vw; /* 411.33 @ 1280 · 617 @ 1920 */
      margin-top: 0;
      border-radius: 16.67px;
    }
  }

  @media (min-width: 1280px) {
    .narrative--purple.narrative--image-right .narrative__inner {
      padding: 60px;
      min-height: 56.25vw;
    }
    .narrative--purple.narrative--image-right .narrative__content {
      gap: 26.67px;
      max-width: 759.33px;
    }
    .narrative--purple.narrative--image-right .narrative__title {
      font-size: 40px;
      line-height: 46px;
    }
    .narrative--purple.narrative--image-right .narrative__body {
      font-size: 16px;
      line-height: 150%;
    }
    .narrative--purple.narrative--image-right .narrative__media {
      border-radius: 20px;
    }
  }

  /* Desktop++ (≥1920) — Figma Text spec: width 1139, gap 40, H2 60/69, P1 23/150 */
  @media (min-width: 1920px) {
    .narrative--purple.narrative--image-right .narrative__inner {
      padding: 90px;
      min-height: 1080px;
    }
    .narrative--purple.narrative--image-right .narrative__content {
      width: 1139px;
      max-width: 1139px;
      gap: 40px;
      padding: 0;
      align-items: flex-start;
    }
    .narrative--purple.narrative--image-right .narrative__title {
      font-size: 60px;
      line-height: 69px;
      color: #FFFFFF;
    }
    .narrative--purple.narrative--image-right .narrative__body {
      font-size: 23px;
      line-height: 150%;
      color: #FFFFFF;
    }
    .narrative--purple.narrative--image-right .narrative__media {
      top: 317.79px;
      left: 828px;
      right: auto;
      width: 990px;
      height: 617px;
      border-radius: 25px;
    }
  }

  /* ============================================================
     Gold + image-right — same overlay layout as the purple quote
     block, but on solid Pale Gold with Cherrywood text. Used for the
     "Über uns" founders' quote.
     ============================================================ */
  .narrative--gold.narrative--image-right { padding: 0; background: var(--c-pale-gold); color: var(--c-cherrywood); }
  .narrative--gold.narrative--image-right .narrative__inner {
    position: relative;
    display: block;
    padding: 40px 20px;
    gap: 0;
    max-width: none;
    overflow: hidden;
  }
  .narrative--gold.narrative--image-right .narrative__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
    color: var(--c-cherrywood);
  }
  .narrative--gold.narrative--image-right .narrative__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h2-size);
    line-height: 1.15;
    color: var(--c-cherrywood);
    margin: 0;
    align-self: stretch;
  }
  .narrative--gold.narrative--image-right .narrative__body,
  .narrative--gold.narrative--image-right .narrative__attribution {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p2-size);
    line-height: 1.5;
    color: var(--c-cherrywood);
    opacity: 0.8;
    max-width: none;
  }
  .narrative--gold.narrative--image-right .narrative__media {
    position: relative;
    z-index: 1;
    aspect-ratio: auto;
    height: 332px;
    width: 100%;
    border-radius: 16.67px;
    margin-top: 20px;
    overflow: hidden;
  }
  .narrative--gold.narrative--image-right .narrative__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .narrative--gold.narrative--image-right .narrative__inner {
      padding: 60px 46px;
      min-height: 56.25vw;
    }
    .narrative--gold.narrative--image-right .narrative__content {
      gap: 26.67px;
      max-width: 684px;
    }
    .narrative--gold.narrative--image-right .narrative__media {
      position: absolute;
      z-index: 1;
      top: 16.5516vw;
      left: 43.125vw;
      right: auto;
      width: 51.5625vw;
      height: 32.1354vw;
      margin-top: 0;
      border-radius: 16.67px;
    }
  }

  @media (min-width: 1280px) {
    .narrative--gold.narrative--image-right .narrative__inner { padding: 60px; min-height: 56.25vw; }
    .narrative--gold.narrative--image-right .narrative__content { gap: 26.67px; max-width: 759.33px; }
    .narrative--gold.narrative--image-right .narrative__title { font-size: 40px; line-height: 46px; }
    .narrative--gold.narrative--image-right .narrative__media { border-radius: 20px; }
  }

  @media (min-width: 1920px) {
    .narrative--gold.narrative--image-right .narrative__inner { padding: 90px; min-height: 1080px; }
    .narrative--gold.narrative--image-right .narrative__content { width: 1139px; max-width: 1139px; gap: 40px; padding: 0; }
    .narrative--gold.narrative--image-right .narrative__title { font-size: 60px; line-height: 69px; }
    .narrative--gold.narrative--image-right .narrative__body,
    .narrative--gold.narrative--image-right .narrative__attribution { font-size: 23px; line-height: 150%; }
    .narrative--gold.narrative--image-right .narrative__media {
      top: 317.79px; left: 828px; right: auto; width: 990px; height: 617px; border-radius: 25px;
    }
  }

  /* image-left + light variant: gold→cream gradient card */
  .narrative--light.narrative--image-left {
    background: linear-gradient(180deg, #FFD869 0%, #F9F4EE 63.8%);
    border-radius: 16.67px;
    margin: 0 16px;
    padding: 48px 24px;
  }
  @media (min-width: 768px) {
    .narrative--light.narrative--image-left { margin: 0 40px; border-radius: 20px; padding: 64px 40px; }
  }
  @media (min-width: 1280px) {
    .narrative--light.narrative--image-left { margin: 0 60px; border-radius: 25px; padding: 90px 60px; }
  }
  @media (min-width: 1920px) {
    .narrative--light.narrative--image-left { margin: 0 90px; padding: 120px 130px 120px 90px; border-radius: 25px; }
  }

  /* Inner layout: text-on-left + image-on-right at ≥768px; stacked on mobile. */
  /* !important needed to defeat .container-x horizontal padding from global.css */
  /* max-width: none + width: 100% defeats .max-w-layout cap so the row fills section */
  .narrative--light.narrative--image-left .narrative__inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 20px;
    padding: 0 !important;
    max-width: none !important;
    width: 100%;
    margin: 0;
  }
  @media (min-width: 768px) {
    .narrative--light.narrative--image-left .narrative__inner {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: space-between;
      align-items: center;
      padding: 0 !important;
      gap: 40px;
    }
  }
  @media (min-width: 1280px) {
    .narrative--light.narrative--image-left .narrative__inner {
      gap: 40px;
    }
  }
  @media (min-width: 1920px) {
    .narrative--light.narrative--image-left .narrative__inner {
      flex-wrap: wrap;
      align-content: space-between;
      gap: 170px 172px;
    }
  }

  /* Media — image on right at ≥768px. Figma 612x420 reference. */
  .narrative--light.narrative--image-left .narrative__media {
    border-radius: 16.67px;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 612 / 420;
    align-self: stretch;
  }
  @media (min-width: 768px) {
    .narrative--light.narrative--image-left .narrative__media {
      order: 1;
      flex: 1 1 50%;
      max-width: none;
      width: 100%;
      height: auto;
      aspect-ratio: auto;
      border-radius: 20px;
      align-self: stretch;
    }
  }
  @media (min-width: 1280px) {
    .narrative--light.narrative--image-left .narrative__media {
      border-radius: 25px;
      aspect-ratio: 620 / 830;
    }
  }
  @media (min-width: 1920px) {
    .narrative--light.narrative--image-left .narrative__media {
      flex: none;
      width: 620px;
      height: 830px;
      aspect-ratio: auto;
      border-radius: 25px;
    }
  }
  .narrative--light.narrative--image-left .narrative__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Text — H2 40px throughout; P1 16/150 */
  .narrative--light.narrative--image-left .narrative__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
    max-width: 100%;
    align-self: stretch;
  }
  @media (min-width: 768px) {
    .narrative--light.narrative--image-left .narrative__content {
      order: 2;
      flex: 1 1 50%;
      max-width: 574px;
      gap: 26.67px;
      align-self: center;
    }
  }
  .narrative--light.narrative--image-left .narrative__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h2-size);
    line-height: 1.15;
    color: var(--c-cherrywood);
    margin: 0;
    align-self: stretch;
  }
  @media (min-width: 1280px) {
    .narrative--light.narrative--image-left .narrative__content {
      max-width: none;
      gap: 40px;
    }
  }
  @media (min-width: 1920px) {
    .narrative--light.narrative--image-left .narrative__content {
      flex: none;
      width: 712px;
      max-width: 712px;
      gap: 40px;
    }
    .narrative--light.narrative--image-left .narrative__title {
      font-size: 60px;
      line-height: 69px;
    }
    .narrative--light.narrative--image-left .narrative__body {
      font-size: 23px;
      line-height: 150%;
    }
  }
  .narrative--light.narrative--image-left .narrative__body {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    color: var(--c-cherrywood);
    opacity: 1;
    max-width: none;
    align-self: stretch;
  }

  /* ============================================================
     Purple + image-left — text on right, image on left, lavender bg
     Mobile (360): stacked column
     Tablet (768): flex row, image left + text right
     Desktop (1280): proportional sizing
     Desktop++ (1920): full Figma spec
     ============================================================ */
  .narrative--purple.narrative--image-left { padding: 0; background: var(--c-lavender); color: var(--c-white); }
  .narrative--purple.narrative--image-left .narrative__inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 20px;
    padding: 40px 20px;
    max-width: none !important;
    width: 100%;
    margin: 0;
  }
  .narrative--purple.narrative--image-left .narrative__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
    color: var(--c-white);
  }
  .narrative--purple.narrative--image-left .narrative__title {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    color: var(--c-white);
    margin: 0;
    align-self: stretch;
  }
  .narrative--purple.narrative--image-left .narrative__body {
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    color: var(--c-white);
    opacity: 1;
    max-width: none;
  }
  .narrative--purple.narrative--image-left .narrative__media {
    border-radius: 16.67px;
    overflow: hidden;
    width: 100%;
    aspect-ratio: auto;
    align-self: stretch;
  }
  .narrative--purple.narrative--image-left .narrative__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .narrative--purple.narrative--image-left .narrative__inner {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: space-between;
      align-items: center;
      padding: 90px 60px;
      gap: 40px;
    }
    .narrative--purple.narrative--image-left .narrative__media {
      order: 0;
      flex: 1 1 50%;
      border-radius: 20px;
    }
    .narrative--purple.narrative--image-left .narrative__content {
      order: 1;
      flex: 1 1 50%;
      gap: 26.67px;
    }
  }

  @media (min-width: 1280px) {
    .narrative--purple.narrative--image-left .narrative__inner {
      padding: 60px;
      gap: 40px;
    }
    .narrative--purple.narrative--image-left .narrative__media {
      border-radius: 25px;
    }
    .narrative--purple.narrative--image-left .narrative__content {
      max-width: none;
      gap: 40px;
    }
    .narrative--purple.narrative--image-left .narrative__title {
      font-size: 40px;
      line-height: 1.1;
    }
  }

  @media (min-width: 1920px) {
    .narrative--purple.narrative--image-left .narrative__inner {
      padding: 90px 104px 90px 241px;
      gap: 300px;
    }
    .narrative--purple.narrative--image-left .narrative__media {
      flex: none;
      width: 510px;
      height: 832px;
      aspect-ratio: auto;
      border-radius: 25px;
    }
    .narrative--purple.narrative--image-left .narrative__content {
      flex: none;
      width: 844px;
      max-width: 844px;
      gap: 40px;
    }
    .narrative--purple.narrative--image-left .narrative__title {
      font-size: 60px;
      line-height: 1.1;
    }
    .narrative--purple.narrative--image-left .narrative__body {
      font-size: 23px;
      line-height: 150%;
    }
  }

  /* ============================================================
     Lavender-gradient + image-left — mirrors light+image-left
     but uses a lavender→cream gradient background
     ============================================================ */
  .narrative--lavender-gradient { background: linear-gradient(180deg, #8E84B6 0%, #F9F4EE 63.8%); color: var(--c-cherrywood); }

  .narrative--lavender-gradient.narrative--image-left {
    background: linear-gradient(180deg, #8E84B6 0%, #F9F4EE 63.8%);
    border-radius: 16.67px;
    margin: 0 16px;
    padding: 48px 24px;
  }
  @media (min-width: 768px) {
    .narrative--lavender-gradient.narrative--image-left { margin: 0 40px; border-radius: 20px; padding: 64px 40px; }
  }
  @media (min-width: 1280px) {
    .narrative--lavender-gradient.narrative--image-left { margin: 0 60px; border-radius: 25px; padding: 90px 60px; }
  }
  @media (min-width: 1920px) {
    .narrative--lavender-gradient.narrative--image-left { margin: 0 90px; padding: 120px 130px 120px 90px; border-radius: 25px; }
  }

  .narrative--lavender-gradient.narrative--image-left .narrative__inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 20px;
    padding: 0 !important;
    max-width: none !important;
    width: 100%;
    margin: 0;
  }
  @media (min-width: 768px) {
    .narrative--lavender-gradient.narrative--image-left .narrative__inner {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: space-between;
      /* flex-start so the image keeps its own (shorter) height instead of
         stretching to match the taller text column — per Figma spec. */
      align-items: flex-start;
      padding: 0 !important;
      gap: 40px;
    }
  }
  @media (min-width: 1280px) {
    .narrative--lavender-gradient.narrative--image-left .narrative__inner {
      gap: 40px;
