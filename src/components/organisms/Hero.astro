---
import Heading from '@atoms/Heading.astro';
import Text from '@atoms/Text.astro';
import Button from '@atoms/Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  image?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  ctaText = 'Termin buchen',
  ctaHref = '/kontakt',
  secondaryCtaText,
  secondaryCtaHref,
  image,
} = Astro.props;
---

<section class="hero">
  <div class="hero__inner max-w-layout container-x">
    {image && (
      <div class="hero__media">
        <img src={image} alt="" class="hero__image" />
      </div>
    )}
    <div class="hero__content">
      {eyebrow && <Heading variant="eyebrow" class="hero__eyebrow">{eyebrow}</Heading>}
      <Heading level={1} class="hero__title"><Fragment set:html={title} /></Heading>
      {subtitle && <Text size="p1" class="hero__subtitle">{subtitle}</Text>}
      <div class="hero__cta">
        <Button href={ctaHref} variant="primary" size="lg" class="hero__cta-btn">
          {ctaText}
        </Button>
        {secondaryCtaText && secondaryCtaHref && (
          <Button href={secondaryCtaHref} variant="header" size="lg" class="hero__cta-btn">
            {secondaryCtaText}
          </Button>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     HERO — responsive per Figma specs (360 / 768 / 1280 / 1920)
     ============================================================ */
  .hero { padding: 72px 0 64px; }
  @media (min-width: 768px)  { .hero { padding: 120px 0 80px; } }
  @media (min-width: 1280px) { .hero { padding: 80px 0 80px; } }
  /* Desktop++ (≥ 1920px) — Figma section padding */
  @media (min-width: 1920px) {
    .hero { padding: 175px 90px 90px 151px; }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  /* Image on top of card text for mobile/tablet (per spec) */
  .hero__media   { order: 0; }
  .hero__content { order: 1; }

  @media (min-width: 1024px) {
    .hero__inner { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 64px; }
    .hero__media   { order: 2; }   /* image right of text on desktop */
    .hero__content { order: 1; }
  }
  /* Desktop++ — horizontal flow, fixed 170px gap, image right of text */
  @media (min-width: 1920px) {
    .hero__inner {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: space-between;
      align-items: center;
      gap: 170px;
      max-width: none;
      padding: 0;
    }
    .hero__content { order: 1; }
    .hero__media   { order: 2; }
  }

  /* ----- TEXT CONTENT ----- */
  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 26.67px;
  }
  @media (min-width: 1920px) {
    .hero__content {
      justify-content: center;
      gap: 40px;
      width: 780px;
      flex: 0 0 780px;
    }
  }

  /* Eyebrow — uses --eyebrow-size token */
  .hero__eyebrow {
    display: block;
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    font-size: var(--eyebrow-size);
    line-height: 1.2;
    letter-spacing: 0.08em;
  }

  /* Title — H1 token */
  .hero__title {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--h1-size);
    line-height: 1.1;
    margin: 0;
  }

  /* Forced line break before "Systeme" only at tablet (768–1023.98px) */
  .hero__br--md { display: none; }
  @media (min-width: 768px) and (max-width: 1023.98px) {
    .hero__br--md { display: inline; }
  }

  /* Subtitle — P1 token */
  .hero__subtitle {
    color: var(--c-cherrywood);
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--p1-size);
    line-height: 1.5;
    max-width: 56ch;
  }
  @media (min-width: 1920px) {
    .hero__subtitle { max-width: 780px; align-self: stretch; }
  }

  /* ----- CTA GROUP — Figma Button Group S (gap 12, w=473 at 768) ----- */
  .hero__cta {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
  }
  /* Desktop++ Button Group L — 780px wide, 20px gap, no wrap */
  @media (min-width: 1920px) {
    .hero__cta {
      flex-wrap: nowrap;
      justify-content: center;
      gap: 20px;
      width: 780px;
      align-self: stretch;
      height: 61px;
      margin-top: 0;
    }
  }

  /* CTA buttons — size driven by --button-size token */
  .hero__cta-btn {
    box-sizing: border-box;
    display: inline-flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 7.62px;
    padding: 13.5328px;
    min-height: 42px;
    height: 42px;
    font-family: 'ES Park', serif;
    font-weight: var(--weight-regular);
    font-size: var(--button-size);
    line-height: 1.2;
    border-radius: 67.6638px;
    border-width: 0.541311px;
    white-space: nowrap;
  }
  @media (min-width: 768px) {
    .hero__cta-btn { width: 231px; padding: 13.5328px; }
  }
  @media (min-width: 1920px) {
    .hero__cta-btn {
      width: 380px;
      flex: 1 1 0;
      height: 61px;
      min-height: 61px;
      padding: 20px;
      gap: 11.26px;
      border-radius: 100px;
      border-width: 0.8px;
    }
  }

  /* ----- MEDIA ----- */
  .hero__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 25px;
    background: var(--c-pale-gold);
    width: 100%;
  }
  @media (min-width: 1024px) { .hero__media { aspect-ratio: 1 / 1; } }
  /* Desktop++ media: fixed 748×826 per Figma */
  @media (min-width: 1920px) {
    .hero__media {
      width: 748px;
      height: 826px;
      aspect-ratio: auto;
      flex: 0 0 748px;
    }
  }
  .hero__image { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
